@article{thangarajComputationalPhenomappingRandomized2025,
  title = {Computational {{Phenomapping}} of {{Randomized Clinical Trial Participants}} to {{Enable Assessment}} of {{Their Real-World Representativeness}} and {{Personalized Inference}}},
  author = {Thangaraj, P.M. and Oikonomou, E.K. and Dhingra, L.S. and Aminorroaya, A. and Jayaram, R.H. and Suchard, M.A. and Khera, R.},
  year = 2025,
  journal = {Circulation: Cardiovascular Quality and Outcomes},
  volume = {18},
  number = {5},
  pages = {e011306},
  publisher = {{Lippincott Williams and Wilkins}},
  issn = {19417705 (ISSN); 19417713 (ISSN)},
  doi = {10.1161/CIRCOUTCOMES.124.011306},
  abstract = {BACKGROUND: Assessing the generalizability of randomized clinical trials (RCTs) to real-world patients remains challenging. We propose a multidimensional metric to quantify the representativeness of an RCT cohort in an electronic health record (EHR) population and estimate real-world effects based on individualized treatment effects observed in the RCT. METHODS: We identified 65 clinical prerandomization characteristics of patients with heart failure with preserved ejection fraction within the TOPCAT (Treatment of Preserved Cardiac Function Heart Failure with an Aldosterone Antagonist Trial) and extracted those features in similar patients in EHR data from 4 hospitals in the Yale New Haven Health System. We then assessed the real-world generalizability of TOPCAT by developing a novel statistic, the phenotypic distance metric, to quantify the representation of TOPCAT participants within EHR patients. Finally, applying a machine learning method to learn individualized treatment effect in TOPCAT participants stratified by region, the United States (US) and Eastern Europe (EE), we predicted spironolactone benefit within the EHR cohorts. RESULTS: There were 3445 patients in TOPCAT (median age 69, interquartile range [IQR], 61-76 years, 52\% women) and 8121 patients with heart failure with preserved ejection fraction across 4 hospitals (median age range 77, IQR, 68-86; years to 85; IQR, 77-91 years, 54\% to 62\% women). Across covariates, the EHR patients were more similar to each other than the TOPCAT-US participants (median standardized mean difference 0.065, IQR, 0.011-0.144 versus median standardized mean difference 0.186, IQR, 0.040-0.479). The phenotypic distance metric found a higher generalizability of the TOPCAT-US participants to the EHR patients than the TOPCAT-EE participants. Using a TOPCAT-US-derived model of individualized treatment effect, all EHR patients were predicted to derive benefit from spironolactone treatment, while a TOPCAT-EE-derived model predicted 13\% of EHR patients to derive benefit. CONCLUSIONS: This novel multidimensional metric evaluates the real-world representativeness of RCT participants against corresponding patients in the EHR, enabling the evaluation of an RCT's implication for real-world patients. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,antihypertensive agent,Antihypertensive Agent,Article,atrial fibrillation,Atrial Fibrillation,beta adrenergic receptor blocking agent,Beta Adrenergic Receptor Blocking Agent,brain natriuretic peptide,Brain Natriuretic Peptide,cardiac agent,Cardiac Agent,clinical trial,Clinical Trial,cohort analysis,Cohort Analysis,Connecticut,controlled study,Controlled Study,data mining,Data Mining,diagnosis,Diagnosis,drug effect,Drug Effect,drug therapy,Drug Therapy,Eastern Europe,echocardiography,Echocardiography,electronic health record,Electronic Health Record,Electronic Health Records,epidemiology,Epidemiology,female,Female,health care system,Health Care System,heart failure,Heart Failure,heart failure with preserved ejection fraction,Heart Failure With Preserved Ejection Fraction,heart function,Heart Function,heart infarction,Heart Infarction,heart stroke volume,Heart Stroke Volume,hospitalization,Hospitalization,human,Human,Humans,hydroxymethylglutaryl coenzyme A reductase inhibitor,Hydroxymethylglutaryl Coenzyme A Reductase Inhibitor,Icd-10,ICD-10,leukocyte count,Leukocyte Count,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,mineralocorticoid antagonist,Mineralocorticoid Antagonist,Mineralocorticoid Receptor Antagonists,multicenter study,Multicenter Study,nitric acid derivative,Nitric Acid Derivative,outcome assessment,Outcome Assessment,pathophysiology,Pathophysiology,patient selection,Patient Selection,percutaneous coronary intervention,Percutaneous Coronary Intervention,personalized medicine,Personalized Medicine,personalized nutrition,Personalized Nutrition,phenotype,Phenotype,pilot study,Pilot Study,placebo,Placebo,Precision Medicine,randomized controlled trial,Randomized Controlled Trial,randomized controlled trial (topic),Randomized Controlled Trial (topic),Randomized Controlled Trials,Randomized Controlled Trials as Topic,Randomized Controlled Trials As Topic,spironolactone,Spironolactone,Stroke Volume,systolic blood pressure,Systolic Blood Pressure,therapy effect,Therapy Effect,treatment outcome,Treatment Outcome,United States}
