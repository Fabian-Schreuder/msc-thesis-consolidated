  publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
  issn = {20726643 (ISSN)},
  doi = {10.3390/nu16132023},
  abstract = {Emerging evidence suggests that personalized dietary supplement regimens can significantly influence lipid metabolism and cardiovascular risk. The efficacy of AI-guided dietary supplement prescriptions, compared with standard physician-guided prescriptions, remains underexplored. In a randomized, parallel-group pilot study, 70 patients aged 40--75 years with LDL-C levels between 70 and 190 mg/dL were enrolled. Participants were randomized to receive either AI-guided dietary supplement prescriptions or standard physician-guided prescriptions for 90 days. The primary endpoint was the percent change in LDL-C levels. Secondary endpoints included changes in total cholesterol, HDL-C, triglycerides, and hsCRP. Supplement adherence and side effects were monitored. Sixty-seven participants completed the study. The AI-guided group experienced a 25.3\% reduction in LDL-C levels (95\% CI: -28.7\% to -21.9\%), significantly greater than the 15.2\% reduction in the physician-guided group (95\% CI: -18.5\% to -11.9\%; p {$<$} 0.01). Total cholesterol decreased by 15.4\% (95\% CI: -19.1\% to -11.7\%) in the AI-guided group compared with 8.1\% (95\% CI: -11.5\% to -4.7\%) in the physician-guided group (p {$<$} 0.05). Triglycerides were reduced by 22.1\% (95\% CI: -27.2\% to -17.0\%) in the AI-guided group versus 12.3\% (95\% CI: -16.7\% to -7.9\%) in the physician-guided group (p {$<$} 0.01). HDL-C and hsCRP changes were not significantly different between groups. The AI-guided group received a broader variety of supplements, including plant sterols, omega-3 fatty acids, red yeast rice, coenzyme Q10, niacin, and fiber supplements. Side effects were minimal and comparable between groups. AI-guided dietary supplement prescriptions significantly reduce LDL-C and triglycerides more effectively than standard physician-guided prescriptions, highlighting the potential for AI-driven personalization in managing hypercholesterolemia. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,Ai-guided Prescriptions,algorithm,Algorithm,Article,biochemical marker,Biochemical Marker,blood,Blood,C reactive protein,C Reactive Protein,cardiovascular disease,Cardiovascular Disease,Cardiovascular Health,cardiovascular risk,Cardiovascular Risk,cholesterol blood level,Cholesterol Blood Level,Cholesterol Hdl,Cholesterol HDL,Cholesterol Ldl,Cholesterol LDL,cholestin,Cholestin,controlled study,Controlled Study,deep learning,Deep Learning,diarrhea,Diarrhea,dietary supplement,Dietary Supplement,Dietary Supplements,drug therapy,Drug Therapy,female,Female,follow up,Follow Up,gastrointestinal symptom,Gastrointestinal Symptom,generative artificial intelligence,Generative Artificial Intelligence,genetic polymorphism,Genetic Polymorphism,genetic profile,Genetic Profile,genetic screening,Genetic Screening,genetic variability,Genetic Variability,genetic variation,Genetic Variation,genotype,Genotype,headache,Headache,high density lipoprotein cholesterol,High Density Lipoprotein Cholesterol,hormone determination,Hormone Determination,human,Human,Humans,hydrocortisone,Hydrocortisone,hypercholesterolemia,Hypercholesterolemia,insulin,Insulin,Ldl-c,lipid fingerprinting,Lipid Fingerprinting,lipid metabolism,Lipid Metabolism,low density lipoprotein cholesterol,Low Density Lipoprotein Cholesterol,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,malonaldehyde,Malonaldehyde,medical history,Medical History,metabolic fingerprinting,Metabolic Fingerprinting,middle aged,Middle Aged,myalgia,Myalgia,nausea,Nausea,nicotinic acid,Nicotinic Acid,nutrition,Nutrition,omega 3 fatty acid,Omega 3 Fatty Acid,oxidative stress,Oxidative Stress,personalized medicine,Personalized Medicine,phospholipid,Phospholipid,phytosterol,Phytosterol,Pilot Projects,pilot study,Pilot Study,prescription,Prescription,randomized controlled trial,Randomized Controlled Trial,sphingolipid,Sphingolipid,treatment outcome,Treatment Outcome,triacylglycerol,