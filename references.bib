@article{strettonImpactFrailtyMalnutrition2024,
  title = {Impact of Frailty, Malnutrition and Socioeconomic Status on Perioperative Outcomes},
  author = {Stretton, B. and Booth, A.E.C. and Kovoor, J. and Gupta, A. and Edwards, S. and Hugh, T. and Maddison, J. and Talley, N.J. and Plummer, M. and Meyer, E.},
  year = 2024,
  journal = {Age and Ageing},
  volume = {53},
  number = {12},
  publisher = {Oxford University Press},
  issn = {14682834 (ISSN); 00020729 (ISSN)},
  doi = {10.1093/ageing/afae263},
  abstract = {Background: Frailty, malnutrition and low socioeconomic status may mutually perpetuate each other in a self-reinforcing and interdependent manner. The intertwined nature of these factors may be overlooked when investigating impacts on perioperative outcomes. This study aimed to investigate the impact of frailty, malnutrition and socioeconomic status on perioperative outcomes. Methods: A multicentre cohort study involving six Australian tertiary hospitals was undertaken. All consecutive surgical patients who underwent an operation were included. Frailty was defined by the Hospital Frailty Risk Score, malnutrition by the Malnutrition Universal Screening Tool (MUST) and low socioeconomic status by the Index of Relative Socioeconomic Disadvantage. Linear mixed-effects and binary logistic generalised estimated equation models were performed for the outcomes: inpatient mortality, length of stay, 30-day readmission and re-operation. Results: A total of 21 976 patients were included. After controlling for confounders, malnutrition and socioeconomic status, patients at high risk of frailty have a mean hospital length of stay 3.46 times longer (mean ratio = 3.46; 95\% confidence interval (CI): 3.20, 3.73; P value {$<$}.001), odds of 30-day readmission 2.4 times higher (odds ratio = 2.40; 95\% CI: 2.19, 2.63; P value {$<$}.001) and odds of in-hospital mortality 12.89 times greater than patients with low risk of frailty (odds ratio = 12.89; 95\% CI: 4.51, 36.69; P value {$<$}.001). Elevated MUST scores were also significantly associated with worse outcomes, but to a lesser extent. Socioeconomic status had no association with outcomes. Conclusion: Perioperative risk evaluation should consider both frailty and malnutrition as separate, significant risk factors. Despite strong causal links with frailty and malnutrition, socioeconomic disadvantage is not associated with worse postoperative outcomes. Additional studies regarding the prospective identification of these patients with implementation of strategies to mitigate frailty and malnutrition and assessment of perioperative risk are required. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adverse event,Adverse Event,age,Age,Age Factors,aged,Aged,Aged 80 and over,Aged 80 And Over,Article,artificial intelligence,Artificial Intelligence,Australia,body mass,Body Mass,cardiovascular risk,Cardiovascular Risk,Charlson Comorbidity Index,clinical outcome,Clinical Outcome,clinical practice,Clinical Practice,clinical trial,Clinical Trial,cognition,Cognition,cohort analysis,Cohort Analysis,complication,Complication,creatinine,Creatinine,diagnosis,Diagnosis,electronic medical record,Electronic Medical Record,epidemiology,Epidemiology,ethnicity,Ethnicity,female,Female,frail elderly,Frail Elderly,frailty,Frailty,geriatric assessment,Geriatric Assessment,health care delivery,Health Care Delivery,health care policy,Health Care Policy,health care system,Health Care System,health disparity,Health Disparity,heart rate,Heart Rate,hemoglobin,Hemoglobin,hospital mortality,Hospital Mortality,hospital readmission,Hospital Readmission,hospitalization,Hospitalization,human,Human,Humans,length of stay,Length of Stay,Length Of Stay,leukocyte count,Leukocyte Count,life expectancy,Life Expectancy,Linear Models,Logistic Models,low socioeconomic status,Low Socioeconomic Status,major clinical study,Major Clinical Study,male,Male,malnutrition,Malnutrition,Malnutrition Universal Screening Tool,middle aged,Middle Aged,morbidity,Morbidity,mortality,Mortality,multicenter study,Multicenter Study,nutritional status,Nutritional Status,odds ratio,Odds Ratio,Older People,Outcomes,Patient Readmission,perioperative complication,Perioperative Complication,Perioperative Medicine,potassium,Potassium,predictive value,Predictive Value,prevalence,Prevalence,reoperation,Reoperation,risk assessment,Risk Assessment,risk factor,Risk Factor,Risk Factors,Sas,sensitivity and specificity,Sensitivity And Specificity,Short Form 36,social class,Social Class,social determinants of health,Social Determinants of Health,Social Determinants Of Health,social status,Social Status,Socioeconomic Status,socioeconomics,Socioeconomics,statistical model,Statistical Model,surgery,Surgery,Surgical Procedures Operative,systolic blood pressure,Systolic Blood Pressure,tertiary care center,Tertiary Care Center,Tertiary Care Centers,time factor,Time Factor,Time Factors,time series analysis,Time Series Analysis,total quality management,Total Quality Management,treatment outcome,Treatment Outcome,urea,Urea,very elderly,Very Elderly}
