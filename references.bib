@inproceedings{pandeyAssessingAIPoweredModel2025,
  title = {Assessing the {{AI-Powered Model}} for the {{Impact}} of {{Wearable Devices}} on the {{Human Body}}},
  author = {Pandey, K. and Priyanka, S. and Dwivedi, A.},
  year = 2025,
  pages = {1163--1168},
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  doi = {10.1109/ICDT63985.2025.10986664},
  abstract = {We all know the significance and role of Artificial Intelligence and Machine learning in our lives. They have created huge impacts on our day-to-day lives. AI is revolutionising various aspects of modern life, spanning healthcare, entertainment, transportation, and education sectors. Numerous advantages of the technology include improved accuracy, efficiency, and personalisation. With so many benefits, in this paper, we will be discussing an AI-based model to analyse and predict Human activity using sensors, will identify the barriers to the adoption of wearable devices in healthcare and propose strategies to overcome them using a multidisciplinary approach and evaluate the impacts of wearable devices on the human physique comprehensively and at an expansive magnitude. The effectiveness of combining data from wearable devices and neuroimaging data requires further research. Wearables present potential opportunities because they monitor human behaviour and vitals, aid in medical diagnostics, and benefit elderly care, clinical services, and diagnostics. New models and frameworks for wearable technology have emerged due to recent technological advancements, AI mechanisms and technologies, the extensive use of smart devices, and booming data and computing device vogues. The scrutiny examines a broad realm of AI and machine learning enabling technologies for wearables and investigation instances. Hence, the paper concludes with some research procedures and strategies to discover the influence and significance of wearable devices on the person's body, their pros and cons, and the potential future study. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9798331519582 (ISBN)},
  langid = {english},
  keywords = {Active learning,Active Learning,Artificial intelligence,Artificial Intelligence,Artificial Intelligence (ai),Artificial intelligence learning,Artificial Intelligence Learning,Diagnosis,Education sectors,Education Sectors,Healthcare,Healthcare sectors,Healthcare Sectors,Human bodies,Human Bodies,Human Body,Machine Learning,Machine-learning,Nutrition,Patient treatment,Patient Treatment,Personalized medicine,Personalized Medicine,Prediction,Sensors,Smart wearables,Smart Wearables,Transportation sector,Transportation Sector,Wearable devices,Wearable Devices}
