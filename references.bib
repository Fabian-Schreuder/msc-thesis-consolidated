@article{wuCementaugmentedPedicleScrew2019,
  title = {Cement-Augmented Pedicle Screw Insertion Assisted by Spinal Robotic Systems for Widespread Spinal Metastases},
  author = {Wu, C. and Lee, C.-Y. and Huang, T.-J. and Wu, M.-H.},
  year = 2019,
  journal = {Journal of Robotic Surgery},
  volume = {13},
  number = {4},
  pages = {595--598},
  publisher = {Springer London},
  issn = {18632491 (ISSN); 18632483 (ISSN)},
  doi = {10.1007/s11701-018-0886-2},
  abstract = {Widespread spinal metastases can obscure bone landmarks and severely hinder surgical safety during pedicle screw insertion. Robot-assisted spinal surgery has demonstrated an excellent safety profile for pedicle screw insertion. Moreover, spinal surgery robotic systems can facilitate pedicle screw insertion with high-accuracy. We present a patient who had breast cancer with widespread spinal metastases, pathological vertebral fracture, and spinal cord compression with a challenge of intraoperative image recognition. To overcome this problem, she received surgical decompression and stabilization through the insertion of cement-augmented pedicle screws with the assistance of a spinal robotic system. At the 1-year follow-up, no implant loosening was observed, and the patient exhibited notable physical improvements, demonstrating that cement-augmented pedicle screw insertion with the assistance of spinal robotic systems is an effective method for treating widespread spinal metastases. \copyright{} 2022 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,Article,bleeding,Bleeding,body weight,Body Weight,bone cement,Bone Cement,Bone landmarks,Bone Landmarks,bone radiography,Bone Radiography,Breast Cancer,Breast Neoplasms,breast tumor,Breast Tumor,cachexia,Cachexia,case report,Case Report,Cement augmentation,Cement Augmentation,Cements,clinical article,Clinical Article,computer assisted tomography,Computer Assisted Tomography,Cortoss,denosumab,Denosumab,devices,Devices,diagnostic imaging,Diagnostic Imaging,diet supplementation,Diet Supplementation,female,Female,fluoroscopy,Fluoroscopy,follow up,Follow Up,fracture fixation,Fracture Fixation,High-accuracy,human,Human,Humans,image alignment,Image Alignment,image analysis,Image Analysis,Image recognition,Image Recognition,image segmentation,Image Segmentation,intensive care unit,Intensive Care Unit,laminectomy,Laminectomy,Medical imaging,Medical Imaging,middle aged,Middle Aged,Navigation,Nova,nuclear magnetic resonance imaging,Nuclear Magnetic Resonance Imaging,pathology,Pathology,pedicle screw,Pedicle Screw,Pedicle screw insertion,Pedicle Screw Insertion,Pedicle screws,Pedicle Screws,postoperative care,Postoperative Care,procedures,Procedures,radiography,Radiography,robot assisted surgery,Robot Assisted Surgery,Robotic,Robotic surgery,Robotic Surgery,robotic surgical procedure,Robotic Surgical Procedure,Robotic Surgical Procedures,Robotic systems,Robotic Systems,Screws,spinal cord compression,Spinal Cord Compression,spinal cord decompression,Spinal Cord Decompression,spinal cord metastasis,Spinal Cord Metastasis,Spinal metastasis,Spinal Metastasis,Spinal Neoplasms,Spinal surgery,Spinal Surgery,spine,Spine,spine fracture,Spine Fracture,Spine Metastases,Spine metastasis,Spine Metastasis,spine stabilization,Spine Stabilization,spine surgery,Spine Surgery,spine tumor,Spine Tumor,tamoxifen,Tamoxifen,visual analog scale,Visual Analog Scale}
