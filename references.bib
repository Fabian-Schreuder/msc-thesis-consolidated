@article{verheyGLP1AgonistsWeight2025,
  title = {{{GLP-1 Agonists}} for {{Weight Loss}}: {{Do They Increase Complications}} in {{Non-diabetic Patients Undergoing Primary Total Hip Arthroplasty}}?},
  author = {Verhey, J.T. and Austin, R.P. and Tarabichi, S. and Paul, B. and Deckey, D.G. and Christopher, Z.K. and Spangehl, M.J. and Bingham, J.S.},
  year = 2025,
  journal = {Journal of Arthroplasty},
  volume = {40},
  number = {8},
  pages = {S101-S107},
  publisher = {Elsevier B.V.},
  issn = {15328406 (ISSN); 08835403 (ISSN)},
  doi = {10.1016/j.arth.2025.03.012},
  abstract = {Background: Glucagon-like peptide 1 (GLP-1) agonists are an effective medication for glycemic control and weight loss. These effects may reduce complications in diabetic patients undergoing total hip arthroplasty (THA). However, there remains a paucity of data on the impact of GLP-1 medications in nondiabetic patients using the medication solely for weight reduction. There is concern that rapid weight loss associated with GLP-1 agonists may lead to malnutrition and increase the risk of postoperative complications in patients undergoing THA. Methods: A retrospective query was performed from January 1, 2010, to January 1, 2022, using an insurance claims database to identify patients undergoing primary THA on GLP-1 agonists (n = 839,715). Patients on GLP-1 therapy (n = 5,345) at the time of surgery were propensity score-matched 1:1 to controls who were not on GLP-1 agonists (n = 5,345) based on age, sex, the Elixhauser Comorbidity Index, and its components. Patients who had diabetes mellitus were excluded. The 90-day outcomes were evaluated, including medical complications, readmission, and reoperation rates. We also examined the incidence of all-cause revision and implant-related complications at a 2-year follow-up. Odds ratios (ORs) were generated using logistic regression analyses. Results: Patients who were on GLP-1 agonist medications were less likely to develop acute blood loss anemia (OR: 0.57; 95\% confidence interval [CI]: 0.34 to 0.96) and require postoperative transfusion (OR: 0.53; 95\% CI: 0.36 to 0.78) or visit the emergency department within 90 days of surgery (OR: 0.81; 95\% CI: 0.69 to 0.92) when compared to patients who did not have GLP-1 therapy. Patients were at comparable risk of deep venous thrombosis, pulmonary embolism, mortality, stroke, myocardial infarction, acute kidney injury, and sepsis regardless of GLP-1 status (P {$>$} 0.05). Notably, the rate of aspiration pneumonia was similar between groups (OR: 1.17; 95\% CI: 0.62 to 2.19). Also, GLP-1 therapy did not put patients at higher risk of surgical complications, including periprosthetic joint infection, instability, fracture, loosening, or all-cause revision, at 90 days and two years (P {$>$} 0.05). Conclusions: Use of a GLP-1 agonist does not appear to increase the odds of postoperative medical and surgical complications after THA in nondiabetic patients taking GLP-1 medications for weight loss alone. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,adverse event,Adverse Event,aged,Aged,anemia,Anemia,Arthroplasty Replacement Hip,Article,blood transfusion,Blood Transfusion,body mass,Body Mass,body weight loss,Body Weight Loss,cerebrovascular accident,Cerebrovascular Accident,comorbidity,Comorbidity,data analysis,Data Analysis,data mining,Data Mining,deep vein thrombosis,Deep Vein Thrombosis,drug effect,Drug Effect,electronic medical record,Electronic Medical Record,Elixhauser comorbidity index,Elixhauser Comorbidity Index,emergency ward,Emergency Ward,epidemiology,Epidemiology,etiology,Etiology,female,Female,follow up,Follow Up,Glp-1 Receptor Agonist,glucagon,Glucagon,glucagon like peptide 1,Glucagon Like Peptide 1,glucagon like peptide 1 receptor agonist,Glucagon Like Peptide 1 Receptor Agonist,Glucagon-like Peptide 1,Glucagon-Like Peptide 1,glucose blood level,Glucose Blood Level,glycemic control,Glycemic Control,health care system,Health Care System,heart infarction,Heart Infarction,hip replacement,Hip Replacement,hospital readmission,Hospital Readmission,hospitalization,Hospitalization,human,Human,Humans,joint instability,Joint Instability,length of stay,Length Of Stay,lung embolism,Lung Embolism,major clinical study,Major Clinical Study,male,Male,malnutrition,Malnutrition,Medical Complications,middle aged,Middle Aged,obesity,Obesity,osteoarthritis,Osteoarthritis,outcome assessment,Outcome Assessment,Outcomes,perioperative period,Perioperative Period,periprosthetic fracture,Periprosthetic Fracture,periprosthetic joint infection,Periprosthetic Joint Infection,postoperative complication,Postoperative Complication,Postoperative Complications,propensity score,Propensity Score,Readmission Rates,reoperation,Reoperation,Retrospective Studies,retrospective study,Retrospective Study,risk factor,Risk Factor,sepsis,Sepsis,statistical analysis,Statistical Analysis,Surgical Complications,Total Hip Arthroplasty,total hip replacement,Total Hip Replacement,training,Training,Weight Loss,wound infection,Wound Infection}
}

@incollection{vermaBioinformaticsHealthcareInformatics2025,
  title = {Bioinformatics, Healthcare Informatics and Analytics: An Imperative for Improved Healthcare System},
  author = {Verma, A.},
  year = 2025,
  pages = {49--75},
  publisher = {Elsevier},
  doi = {10.1016/B978-0-443-26480-1.00014-X},
  abstract = {Health information, knowledge, and data, including collection, processing, analysis, and utilization, are the main topics of healthcare informatics. Examining and analyzing vast biological datasets, comprehending sickness completely, and to understand proteomics and genomics by relating them to medical data, bioinformatics uses computational tools and methodologies. Processing the main priority is on the genetic or peptide data with uses in health care, developing drugs, and in fundamental biological research. Massive volumes of digitized health data have given rise to analytics in the field of healthcare. Improved healthcare, economic savings, better treatment with the best health care system, and life safety are all possible thanks to data analytics. The explosion of records has led to the extensive use of data analysis within health care to mine insights and help individuals make well-informed decisions. The significance of healthcare informatics, analytics, and bioinformatics for a better healthcare system is examined in this chapter. The benefits, ways that each contributes to the enhancement of the healthcare system, the points where bioinformatics, healthcare informatics, and analytics converge, and the future of health data and intelligence are all examined. Informatics applications enhanced outcomes, enabled integrated care, and supported clinical studies and heath informatics at HMH. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9780443264818 (ISBN); 9780443264801 (ISBN)},
  langid = {english},
  keywords = {Analytic,Analytics,Bioinformatics,Biomedical engineering,Biomedical Engineering,Clinical research,Clinical Research,Diseases,Drug therapy,Drug Therapy,Evidence-based medicine,Evidence-based Medicine,Health care informatics,Health Care Informatics,Health data,Health Data,Healthcare Informatics,Healthcare System,Healthcare systems,Healthcare Systems,Independent living systems,Independent Living Systems,Language processing,Language Processing,mHealth,Mhealth,Natural language processing,Natural Language Processing,Natural languages,Natural Languages,Nutrition,Outcomes research,Outcomes Research,Readmission risk,Readmission Risk}
}

@article{villaverdenaveiraDesigningSocialRobot2022,
  title = {Designing a {{Social Robot Companion}} to {{Support Homecare}}: {{Usability Results}}.},
  author = {Villaverde Naveira, Alexandra and {de Masi}, Alexandre and Wac, Katarzyna and Amabili, Giulio and Vastenburg, Martijn and Alberts, Janna and {de Koning}, Judith and Cuijpers, Raymond and Lovis, Christian},
  year = 2022,
  month = jun,
  journal = {Studies in health technology and informatics},
  volume = {295},
  pages = {261--264},
  address = {Netherlands},
  issn = {1879-8365 0926-9630},
  doi = {10.3233/SHTI220712},
  abstract = {Earlier studies show frail seniors often experience loneliness and depression. Moreover, frailty can lead problems with medication and nutrition patterns. The  availability of family care and/or nursing care at home is limited. Digital  companions, such as social robots, could complement homecare nurses, thereby  improving the quality of care to frail seniors. The Guardian project has co-  designed with end-users, a social robot providing social company and health  support. To assess the digital and co-created solution, usability evaluations  have been conducted with 43 participants distributed as fairly as possible  between frail seniors, family carers and professional nurses; in three different  European areas: The Netherlands, Italy and Switzerland. The goal of this study is  to evaluate if the GUARDIAN solution is accepted by the target users and also  gather data on how to improve the system for ensuring added-value in home care.  The iterative method based on user-centered approach put the end-users at the  centre of the usability evaluation. Through thematic analysis of the qualitative  datasets, we conclude that a high number of users accept the solution and  describe it as useful. End-user needs have been mainly addressed but some new  improvements have been pointed out by the participants and some other needs have  been uncovered.},
  langid = {english},
  pmid = {35773858},
  keywords = {*Frailty,*Home Care Services,*Robotics,Caregivers,coaching technology,Humans,Social Interaction,usability evaluation,User-centered design},
  file = {C:\Users\fabian\Zotero\storage\95RV4854\Villaverde Naveira et al. - 2022 - Designing a Social Robot Companion to Support Homecare Usability Results..pdf}
}

@article{vodencarevicPredictionRecurrentIschemic2022,
  title = {Prediction of {{Recurrent Ischemic Stroke Using Registry Data}} and {{Machine Learning Methods}}: {{The Erlangen Stroke Registry}}},
  author = {Voden{\v c}arevi{\'c}, A. and Weing{\"a}rtner, M. and Caro, J.J. and Ukalovic, D. and {Zimmermann-Rittereiser}, M. and Schwab, S. and {Kolominsky-Rabas}, P.},
  year = 2022,
  journal = {Stroke},
  volume = {53},
  number = {7},
  pages = {2299--2306},
  publisher = {{Lippincott Williams and Wilkins}},
  issn = {00392499 (ISSN); 15244628 (ISSN); 9783805590990 (ISBN); 9780470674369 (ISBN); 9781416054788 (ISBN)},
  doi = {10.1161/STROKEAHA.121.036557},
  abstract = {Background: There have been multiple efforts toward individual prediction of recurrent strokes based on structured clinical and imaging data using machine learning algorithms. Some of these efforts resulted in relatively accurate prediction models. However, acquiring clinical and imaging data is typically possible at provider sites only and is associated with additional costs. Therefore, we developed recurrent stroke prediction models based solely on data easily obtained from the patient at home. Methods: Data from 384 patients with ischemic stroke were obtained from the Erlangen Stroke Registry. Patients were followed at 3 and 12 months after first stroke and then annually, for about 2 years on average. Multiple machine learning algorithms were applied to train predictive models for estimating individual risk of recurrent stroke within 1 year. Double nested cross-validation was utilized for conservative performance estimation and models' learning capabilities were assessed by learning curves. Predicted probabilities were calibrated, and relative variable importance was assessed using explainable artificial intelligence techniques. Results: The best model achieved the area under the curve of 0.70 (95\% CI, 0.64-0.76) and relatively good probability calibration. The most predictive factors included patient's family and housing circumstances, rehabilitative measures, age, high calorie diet, systolic and diastolic blood pressures, percutaneous endoscopic gastrotomy, number of family doctor's home visits, and patient's mental state. Conclusions: Developing fairly accurate models for individual risk prediction of recurrent ischemic stroke within 1 year solely based on registry data is feasible. Such models could be applied in a home setting to provide an initial risk assessment and identify high-risk patients early. \copyright{} 2022 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {acetylsalicylic acid,Acetylsalicylic Acid,aged,Aged,area under the curve,Area Under The Curve,Article,artificial intelligence,Artificial Intelligence,Barthel index,Barthel Index,binary classification,Binary Classification,brain ischemia,Brain Ischemia,cerebrovascular accident,Cerebrovascular Accident,comorbidity,Comorbidity,controlled study,Controlled Study,diastolic blood pressure,Diastolic Blood Pressure,dimensionality reduction,Dimensionality Reduction,disease registry,Disease Registry,family,Family,feasibility study,Feasibility Study,feature selection,Feature Selection,female,Female,follow up,Follow Up,general practitioner,General Practitioner,health care system,Health Care System,high calorie diet,High Calorie Diet,home visit,Home Visit,housing,Housing,human,Human,Humans,hypertension,Hypertension,interview,Interview,ischemic stroke,Ischemic Stroke,k fold cross validation,K Fold Cross Validation,linear support vector machine,Linear Support Vector Machine,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,mental health,Mental Health,Mini Mental State Examination,nested cross validation,Nested Cross Validation,patient risk,Patient Risk,percutaneous endoscopic gastrostomy,Percutaneous Endoscopic Gastrostomy,performance indicator,Performance Indicator,prediction,Prediction,predictive model,Predictive Model,Probability,Recurrence,recurrent disease,Recurrent Disease,register,Register,Registries,Stroke,support vector machine,Support Vector Machine,systolic blood pressure,Systolic Blood Pressure,treatment duration,Treatment Duration,widower,Widower}
}

