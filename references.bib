@article{wangUsing3DFacial2024,
  title = {Using {{3D}} Facial Information to Predict Malnutrition and Consequent Complications},
  author = {Wang, X. and Wang, W. and Chen, M. and Han, M. and Rong, Z. and Fu, J. and Chong, Y. and Yu, N. and Long, X. and Cheng, Z.},
  year = 2024,
  journal = {Nutrition in Clinical Practice},
  volume = {39},
  number = {6},
  pages = {1354--1363},
  publisher = {{John Wiley and Sons Inc}},
  issn = {19412452 (ISSN); 08845336 (ISSN)},
  doi = {10.1002/ncp.11215},
  abstract = {Background: Phase angle (PhA) correlates with body composition and could predict the nutrition status of patients and disease prognosis. We aimed to explore the feasibility of predicting PhA-diagnosed malnutrition using facial image information based on deep learning (DL). Methods: From August 2021 to April 2022, inpatients were enrolled from surgery, gastroenterology, and oncology departments in a tertiary hospital. Subjective global assessment was used as the gold standard of malnutrition diagnosis. The highest Youden index value was selected as the PhA cutoff point. We developed a multimodal DL framework to automatically analyze the three-dimensional (3D) facial data and accurately determine patients' PhA categories. The framework was trained and validated using a cross-validation approach and tested on an independent dataset. Results: Four hundred eighty-two patients were included in the final dataset, including 176 with malnourishment. In male patients, the PhA value with the highest Youden index was 5.55{$^\circ$}, and the area under the receiver operating characteristic curve (AUC) = 0.68; in female patients, the PhA value with the highest Youden index was 4.88{$^\circ$}, and AUC = 0.69. Inpatients with low PhA had higher incidence of infectious complications during the hospital stay (P = 0.003). The DL model trained with 4096 points extracted from 3D facial data had the best performance. The algorithm showed fair performance in predicting PhA, with an AUC of 0.77 and an accuracy of 0.74. Conclusion: Predicting the PhA of inpatients from facial images is feasible and can be used for malnutrition assessment and prognostic prediction. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {3d Photogrammetry,accuracy,Accuracy,adult,Adult,aged,Aged,algorithm,Algorithm,Article,Artificial Intelligence,body composition,Body Composition,calculation,Calculation,chronic obstructive lung disease,Chronic Obstructive Lung Disease,clinical practice,Clinical Practice,computer model,Computer Model,consequent complication,Consequent Complication,controlled study,Controlled Study,cross validation,Cross Validation,data visualization,Data Visualization,deep learning,Deep Learning,diagnosis,Diagnosis,diagnostic test accuracy study,Diagnostic Test Accuracy Study,electronic health record,Electronic Health Record,epidemiology,Epidemiology,face,Face,Facial Imaging,facial recognition,Facial Recognition,Feasibility Studies,feasibility study,Feasibility Study,female,Female,fluid retention,Fluid Retention,gastroenterology,Gastroenterology,Geforce Rtx 3090,hospitalization,Hospitalization,human,Human,Humans,Imaging Three-dimensional,Imaging Three-Dimensional,information processing,Information Processing,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,malnutrition,Malnutrition,middle aged,Middle Aged,muscle atrophy,Muscle Atrophy,Nutrition Assessment,nutritional assessment,Nutritional Assessment,nutritional status,Nutritional Status,oncology,Oncology,outcome variable,Outcome Variable,Phase Angle,photogrammetry,Photogrammetry,physical disease,Physical Disease,prediction,Prediction,predictive value,Predictive Value,Predictive Value of Tests,Predictive Value Of Tests,procedures,Procedures,prognosis,Prognosis,prospective study,Prospective Study,receiver operating characteristic,Receiver Operating Characteristic,risk factor,Risk Factor,Roc Curve,ROC Curve,sensitivity and specificity,Sensitivity And Specificity,Spss Statistics Version 26,subcutaneous fat,Subcutaneous Fat,three dimensional facial information,Three Dimensional Facial Information,three-dimensional imaging,Three-dimensional Imaging,Vectra H1}
