@inproceedings{10099112,
  title = {Career Support Platform for Older Adults Powered by {{AI}}},
  booktitle = {2023 {{IEEE}} 13th Annual Computing and Communication Workshop and Conference ({{CCWC}})},
  author = {Jain, Ashish and Durairaj, Sakthivel and Paduri, Anwesh Reddy and Krishnan, Praveen and Chalaiah, Pramod and Chanda, Jaideep and Darapaneni, Narayana},
  year = 2023,
  month = mar,
  pages = {47--53},
  doi = {10.1109/CCWC57344.2023.10099112},
  abstract = {Global life expectancy has increased rapidly due to mankind's access to better healthcare and nutrition. In the past three decades, the average age of mankind has increased by 9 years. This contributes to many years in post-retirement life. While some might have built sufficient retirement corpus, many might rely on a post-retirement income for their livelihood. In addition, more and more people are open to retire early to pursue options in line with their passion. From an individual stand point, retirees prefer to stay physically and mentally active by engaging themselves in a full or part-time job. From the workforce perspective, the world will face a shortage of younger employees due to a low populated replacement rate, which in turn opens the doors for retirees to apply their experience and expertise across the areas of their interest. While there are many solutions focusing on students and the younger workforce to guide them on career options and job opportunities, there is a strong need to establish an ecosystem to support and counsel the aging population on their post-retirement career options. This paper focuses on an intuitive and intelligent AI-based platform offering holistic career guidance. Our solution is focused on using multiple Random Forest models and NLP techniques to provide suitable career options, available job opportunities, skills gaps, and learning paths to bridge the gaps.},
  keywords = {Aging population,Aging Population,Artificial Intelligence,Average ages,Average Ages,Career guidance,Career Guidance,Career options,Career Options,Engineering profession,Focusing,Forestry,Job opportunities,Job Opportunities,Life expectancies,Life Expectancies,Medical services,Natural language processing systems,Natural Language Processing Systems,Nlp,NLP,older adults,Older adults,Older Adults,Part time jobs,Part Time Jobs,Personnel,Random Forest,Random forests,Random Forests,Recommendation Engine,Replacement rates,Replacement Rates,Sociology,Statistics}
}

