  month = jul,
  pages = {451--456},
  issn = {2159-3477},
  doi = {10.1109/ISVLSI61997.2024.00087},
  abstract = {Type 1 diabetes (T1D) presents an escalating health challenge requiring precise glycemic control within management protocols. The need for energy-efficient wearable medical-grade devices and biosensors, notably continuous glucose monitoring (CGM), facilitates real-time monitoring and augments interest in blood glucose prediction. However, existing research predom-inantly concentrates on short-term blood glucose forecasting, overlooking the critical need for accurate long-term prediction. This work addresses this gap by exploring the feasibility and efficacy of long-term blood glucose prediction (60, 120, and 240 minutes) leveraging deep multitask learning (DMTL). In addition, long-short-term memory (LSTM) based recurrent neural network (RNN) architecture has been explored within the shared layers of the DMTL framework. The predictive model effectively captures blood glucose trends, achieving a root mean square error (RMSE) of 56.66\textpm 6.96 mg/dL at the 240-minute (four-hour) mark while maintaining 90.36\textpm 4.22},
  keywords = {Accuracy,Biomedical monitoring,Blood,Blood glucose,Blood Glucose,Clinical research,Clinical Research,continuous glucose monitoring,Continuous glucose monitoring,Continuous Glucose Monitoring,Diabetes,Energy efficient,Energy Efficient,Glucose,Glucose sensing,Glucose Sensing,Glucose sensors,Glucose Sensors,glycemic control,Glycemic control,Glycemic Control,Long short-term memory,Long Short-term Memory,Management protocols,Management Protocols,Multilayer neural networks,Multilayer Neural Networks,Multitask learning,Multitask Learning,Neural-networks,Predictive analytics,predictive modeling,Predictive Modeling,Predictive models,Predictive Models,recurrent neural network,Recurrent Neural Network,Recurrent neural networks,Strategic planning,Strategic Planning,type 1 diabetes,Type 1 diabetes,Type 1 Diabetes,Wearable technology,Wearable Technology}
