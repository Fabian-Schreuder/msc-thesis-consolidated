  author = {Golubnitschaja, O. and Pol{\'i}vka, J. and Potu{\v z}n{\'i}k, P. and Pe{\v s}ta, M. and {\v S}t{\v e}tk{\'a}{\v r}ov{\'a}, I. and Mazur{\'a}kov{\'a}, A. and Lackova, L. and Kubatka, P. and Kropp, M. and Thumann, G.},
