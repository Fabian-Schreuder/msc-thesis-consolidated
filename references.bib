@article{elhaddArtificialIntelligenceAI2020,
  title = {Artificial {{Intelligence}} ({{AI}}) Based Machine Learning Models Predict Glucose Variability and Hypoglycaemia Risk in Patients with Type 2 Diabetes on a Multiple Drug Regimen Who Fast during Ramadan ({{The PROFAST}} -- {{IT Ramadan}} Study)},
  author = {Elhadd, T. and Mall, R. and Bashir, M. and Palotti, J. and {Fernandez-Luque}, L. and Farooq, F. and Mohanadi, D.A. and Dabbous, Z. and Malik, R.A. and {Abou-Samra}, A.B.},
  year = 2020,
  journal = {Diabetes Research and Clinical Practice},
  volume = {169},
  publisher = {Elsevier Ireland Ltd},
  issn = {01688227 (ISSN); 18728227 (ISSN)},
  doi = {10.1016/j.diabres.2020.108388},
  abstract = {Objective: To develop a machine-based algorithm from clinical and demographic data, physical activity and glucose variability to predict hyperglycaemic and hypoglycaemic excursions in patients with type 2 diabetes on multiple glucose lowering therapies who fast during Ramadan. Patients and methods: Thirteen patients (10 males and three females) with type 2 diabetes on 3 or more anti-diabetic medications were studied with a Fitbit-2 pedometer device and Freestyle Libre (Abbott Diagnostics) 2 weeks before and 2 weeks during Ramadan. Several machine learning techniques were trained to predict blood glucose levels in a regression framework utilising physical activity and contemporaneous blood glucose levels, comparing Ramadan to non-Ramadan days. Results: The median age of participants was 51 years (IQR 49--52); median BMI was 33.2 kg/m2 (IQR 33.0--35.9) and median HbA1c was 7.3\% (IQR 6.7--7.8). The optimal model using physical activity achieved an R2 of 0.548 and a mean absolute error (MAE) of 30.30. The addition of electronic health record (ehr) information increased R2 to 0.636 and reduced MAE to 26.89 and the time of the day feature further increased R2 to 0.768 and reduced MAE to 20.55. Combining all the features together resulted in an optimal XGBoost model with an R2 of 0.836 and MAE of 17.47. This model accurately estimated normal glucose levels in 2584/2715 (95.2\%) readings and hyperglycaemic events in 852/1031 (82.6\%) readings, but fewer hypoglycaemic events (48/172 (27.9\%)). The optimal XGBoost model prioritized age, gender, BMI and HbA1c followed by glucose levels and physical activity. Interestingly, the blood glucose level prediction by our model was influenced by use of SGLT2i. Conclusion: XGBoost, a machine learning AI algorithm achieves high predictive performance for normal and hyperglycaemic excursions, but has limited predictive value for hypoglycaemia in patients on multiple therapies who fast during Ramadan. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,age,Age,aged,Aged,antidiabetic agent,Antidiabetic Agent,Article,artificial intelligence,Artificial Intelligence,blood,Blood,body mass,Body Mass,clinical article,Clinical Article,Diabetes Mellitus,Diabetes Mellitus Type 2,diet restriction,Diet Restriction,dipeptidyl peptidase IV inhibitor,Dipeptidyl Peptidase Iv Inhibitor,electronic medical record,Electronic Medical Record,Fasting,female,Female,Fitbit 2,Flash Glucose Monitoring System,Freestyle Libre,gender,Gender,glucagon like peptide 1 receptor agonist,Glucagon Like Peptide 1 Receptor Agonist,glucose,Glucose,glucose blood level,Glucose Blood Level,hemoglobin A1c,Hemoglobin A1c,human,Human,Humans,Hyperglycaemia,hyperglycemia,Hyperglycemia,Hypoglycaemia,hypoglycemia,Hypoglycemia,insulin,Insulin,Islam,machine learning,Machine Learning,male,Male,metformin,Metformin,middle aged,Middle Aged,non insulin dependent diabetes mellitus,Non Insulin Dependent Diabetes Mellitus,physical activity,Physical Activity,pioglitazone,Pioglitazone,prediction,Prediction,Ramadan,Ramadan fasting,Ramadan Fasting,risk assessment,Risk Assessment,risk factor,Risk Factor,Risk Factors,sodium glucose cotransporter 2 inhibitor,Sodium Glucose Cotransporter 2 Inhibitor,sulfonylurea derivative,Sulfonylurea Derivative,Type-2 Diabetes}
}

@incollection{esperEnhancedRecoveryPrehabilitation2024,
  title = {Enhanced {{Recovery}} and {{Prehabilitation}} in the {{Perioperative Setting}}},
  author = {Esper, S.A. and {Holder-Murray}, J. and Mahajan, A.},
  year = 2024,
  pages = {73--93},
  publisher = {Springer Nature},
  doi = {10.1007/978-3-031-72862-4_4},
  abstract = {Perioperative care has seen remarkable advancements since the introduction of anesthesia in 1846, with anesthesia-related mortality rates now comparable to commercial aviation safety. However, significant challenges remain, particularly for high-risk patients undergoing major surgeries. This chapter explores critical opportunities to improve perioperative health outcomes by focusing on modifiable risk factors and adopting a more holistic approach to patient care. Key areas addressed include the importance of preoperative risk assessment and optimization, with particular emphasis on addressing modifiable factors such as anemia, malnutrition, opioid use, mood disorders, and frailty. The concept of prehabilitation is introduced as a means to enhance patients' functional capacity before surgery, potentially reducing postoperative complications and improving outcomes. The chapter also discusses institutional approaches to perioperative care, highlighting the need for patient segmentation based on complexity and risk, and the implementation of standardized protocols for low-risk procedures while maintaining flexibility for complex cases. The role of technology in perioperative care is examined, including the use of electronic medical records, clinical decision support systems, and machine learning algorithms to predict and prevent adverse events. Enhanced Recovery Protocols (ERPs) are presented as an innovative approach to improving intraoperative and postoperative care across multiple surgical specialties. The chapter further explores the evolution of preoperative clinics and the development of comprehensive perioperative care centers, which aim to provide personalized risk assessment, optimization, and patient education. Finally, the chapter discusses the importance of digital health solutions and patient engagement platforms in improving protocol adherence and outcomes. By adopting these multifaceted approaches to perioperative care, healthcare providers can potentially reduce complications, improve patient outcomes, and decrease overall healthcare costs, ultimately transitioning from reactive to preventative medicine. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9783031728624 (ISBN); 9783031728617 (ISBN)},
  langid = {english},
  keywords = {Digital Health Solutions,Enhanced Recovery,Perioperative Medicine,Prehabilitation}
}

