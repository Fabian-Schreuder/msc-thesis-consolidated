  author = {Zhong, H. and Hou, C. and Huang, Z. and Chen, X. and Zou, Y. and Zhang, H. and Wang, T. and Wang, L. and Huang, X. and Xiang, Y.},
  year = 2025,
  journal = {Scandinavian Journal of Gastroenterology},
  volume = {60},
