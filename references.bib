@article{spanigVirtualDoctorInteractive2019,
  title = {The Virtual Doctor: {{An}} Interactive Clinical-Decision-Support System Based on Deep Learning for Non-Invasive Prediction of Diabetes},
  author = {Sp{\"a}nig, S. and {Emberger-Klein}, A. and Sowa, J.-P. and Canbay, A. and Menrad, K. and Heider, D.},
  year = 2019,
  journal = {Artificial Intelligence in Medicine},
  volume = {100},
  publisher = {Elsevier B.V.},
  issn = {18732860 (ISSN); 09333657 (ISSN); 9789051991413 (ISBN); 905199141X (ISBN)},
  doi = {10.1016/j.artmed.2019.101706},
  abstract = {Artificial intelligence (AI) will pave the way to a new era in medicine. However, currently available AI systems do not interact with a patient, e.g., for anamnesis, and thus are only used by the physicians for predictions in diagnosis or prognosis. However, these systems are widely used, e.g., in diabetes or cancer prediction. In the current study, we developed an AI that is able to interact with a patient (virtual doctor) by using a speech recognition and speech synthesis system and thus can autonomously interact with the patient, which is particularly important for, e.g., rural areas, where the availability of primary medical care is strongly limited by low population densities. As a proof-of-concept, the system is able to predict type 2 diabetes mellitus (T2DM) based on non-invasive sensors and deep neural networks. Moreover, the system provides an easy-to-interpret probability estimation for T2DM for a given patient. Besides the development of the AI, we further analyzed the acceptance of young people for AI in healthcare to estimate the impact of such a system in the future. \copyright{} 2019 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {agronomy,Agronomy,Article,artificial intelligence,Artificial intelligence,Artificial Intelligence,automatic speech recognition,Automatic Speech Recognition,awareness,Awareness,Behavioral research,Behavioral Research,body height,Body Height,body mass,Body Mass,Body Mass Index,body weight,Body Weight,Cancer prediction,Cancer Prediction,cleaning,Cleaning,clinical decision support system,Clinical Decision Support System,Clinical decision support systems,Clinical Decision Support Systems,computer interface,Computer Interface,Decision support systems,Decision Support Systems,Decision Support Systems Clinical,deep learning,Deep learning,Deep Learning,Deep neural networks,Deep Neural Networks,Diabetes,diabetes mellitus,Diabetes Mellitus,Diabetes Mellitus Type 2,Diagnosis,Diagnostics,E-health,E-learning,engineering,Engineering,female,Female,Forecasting,forestry,Forestry,health care,Health Care,health care need,Health Care Need,hemoglobin A1c,Hemoglobin A1c,human,Human,Humans,Learning systems,Learning Systems,Machine Learning,male,Male,Medical problems,Medical Problems,middle aged,Middle Aged,Neural Networks Computer,non insulin dependent diabetes mellitus,Non Insulin Dependent Diabetes Mellitus,Non-invasive prediction,Non-invasive Prediction,Non-invasive sensors,Non-invasive Sensors,nutritional science,Nutritional Science,physician,Physician,Plasma diagnostics,Plasma Diagnostics,Population densities,Population Densities,population density,Population Density,Population statistics,Population Statistics,prediction,Prediction,primary medical care,Primary Medical Care,priority journal,Priority Journal,probability,Probability,Probability estimation,Probability Estimation,proof of concept,Proof Of Concept,questionnaire,Questionnaire,speech discrimination,Speech Discrimination,Speech recognition,Speech Recognition,Speech Recognition Software,Speech synthesis,Speech Synthesis,Speech synthesis system,Speech Synthesis System,Surveys and Questionnaires,Surveys And Question