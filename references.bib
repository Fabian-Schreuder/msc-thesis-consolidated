@article{yingRealTimeAIAssistedInsulin2025,
  title = {Real-{{Time AI-Assisted Insulin Titration System}} for {{Glucose Control}} in {{Patients}} with {{Type}} 2 {{Diabetes}}: {{A Randomized Clinical Trial}}},
  author = {Ying, Z. and Fan, Y. and Chen, C. and Liu, Y. and Tang, Q. and Chen, Z. and Yang, Q. and Yan, H. and Wu, L. and Lu, J.},
  year = 2025,
  journal = {JAMA Network Open},
  volume = {8},
  number = {5},
  publisher = {American Medical Association},
  issn = {25743805 (ISSN)},
  doi = {10.1001/jamanetworkopen.2025.8910},
  abstract = {Importance: Type 2 diabetes (T2D) is one of the most prevalent chronic diseases in the world. Insulin titration for glycemic control in T2D is crucial but limited by the lack of personalized and real-time tools. Objective: To examine whether an artificial intelligence-based insulin clinical decision support system (iNCDSS) for glycemic control in hospitalized patients with T2D is noninferior to standard insulin therapy administered by senior physicians. Design, Setting, and Participants: This multicenter, single-blind, parallel randomized clinical trial (RCT) was conducted between October 1, 2021, and September 8, 2022, in endocrinology wards of 3 medical centers. Eligible participants were adults (aged {$\geq$}18 years) with glycated hemoglobin levels between 7.0\% and 11.0\% who had received antidiabetic treatments in the previous 3 months. Interventions: Participants were randomized in a 1:1 ratio to receive insulin dosage titration by iNCDSS or senior endocrinology physicians for 5 consecutive days. Main Outcomes and Measures: The primary outcome was the proportion of time in the target glucose range (70-180 mg/dL) during the 5-day study period; the noninferiority margin was 6 percentage points. Secondary outcomes included other glycemic control measurements and adverse events. Results: A total of 149 participants (mean [SD] age, 64.2 [12.0] years; 84 male [56.4\%]) were enrolled and randomized to the iNCDSS group (n = 75) or physician group (n = 74). The mean (SD) target glucose range (primary outcome) was 76.4\% (16.4\%) in the iNCDSS group and 73.6\% (16.8\%) in the physician group, which achieved the prespecified noninferiority criterion (estimated treatment difference, 2.7\%; 95\% CI, -2.7\% to 8.0\%). There were no significant differences in adverse events between the 2 groups. Most physicians were satisfied with the iNCDSS for its clear, time-saving, effective, and safe clinical support. Conclusions and Relevance: In this RCT of an iNCDSS, the system demonstrated noninferiority to senior endocrinology physicians in insulin titration in an inpatient setting, indicating its potential as a favorable tool for insulin titration in patients with T2D. Trial Registration: ClinicalTrials.gov Identifier: NCT04642378. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,antidiabetic agent,Antidiabetic Agent,Article,artificial intelligence,Artificial Intelligence,artificial intelligence-assisted technology,Artificial Intelligence-assisted Technology,blood,Blood,Blood Glucose,clinical decision support system,Clinical Decision Support System,clinical effectiveness,Clinical Effectiveness,clinical trial,Clinical Trial,continuous glucose monitoring,Continuous Glucose Monitoring,controlled study,Controlled Study,decision support system,Decision Support System,Decision Support Systems Clinical,Diabetes Mellitus Type 2,diabetic diet,Diabetic Diet,diabetic patient,Diabetic Patient,drug dose titration,Drug Dose Titration,drug effect,Drug Effect,drug therapy,Drug Therapy,female,Female,Freestyle Libre,glucose,Glucose,glucose blood level,Glucose Blood Level,Glupad,glycated hemoglobin,Glycated Hemoglobin,glycemic control,Glycemic Control,hemoglobin A1c,Hemoglobin A1c,hospital patient,Hospital Patient,human,Human,Humans,hypoglycemia,Hypoglycemia,Hypoglycemic Agents,insulin,Insulin,insulin treatment,Insulin Treatment,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,multicenter study,Multicenter Study,non insulin dependent diabetes mellitus,Non Insulin Dependent Diabetes Mellitus,non-inferiority trial,Non-inferiority Trial,oral antidiabetic agent,Oral Antidiabetic Agent,parallel design,Parallel Design,patient safety,Patient Safety,physician,Physician,procedures,Procedures,randomized controlled trial,Randomized Controlled Trial,single blind procedure,Single Blind Procedure,Single-blind Method,Single-Blind Method,time management,Time Management}
