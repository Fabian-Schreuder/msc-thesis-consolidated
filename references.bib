  doi = {10.23919/INDIACom66777.2025.11115309},
  abstract = {In today's world, with a growing awareness of maintaining a healthy lifestyle, exercise plays an important role. The expanding market of smart wearables and the inclusion of music into workouts, utilises the potential of technology to transform exercise. The domains of music and exercise cohesively have the potential to enhance exercise experience. However, there is a gap that exists between the two domains, with an absence of a platform that effectively combines both to yield a powerful system. This study proposes a novel machine learning solution that aims to bridge this gap, by utilising its user's real-time smartwatch data and music preferences to dynamically regulate the pace of exercise of the user through personalised music playlists. The proposed solution also provides a diet-centric chatbot based on Natural Language Processing, thus resulting in a wholistic health solution. This innovative approach aims to elevate user motivation, improve performance, and ultimately make exercise more enjoyable.},
  keywords = {Accuracy,Chatbots,Classification,Computational modeling,Exercise,Large Language Model,Machine learning,Machine Learning,Machine learning algorithms,Music,Polynomials,Prediction algorithms,Random forests,Regression,Transforms,Wearable Health Monitoring Systems}
}

@inproceedings{11158247,
  title = {{{IoT-enabled}} Health Monitoring Glove with Machine Learning-Based Risk Classification},
  booktitle = {2025 {{IEEE}} Wireless Antenna and Microwave Symposium ({{WAMS}})},
  author = {Narayana, I Lakshmi and Abhinay, Gaddamadugu and Vinitha, Dhara and Charan, Bolapati and Satyanarayana, Boddu Veera Venkata},
  year = 2025,
  month = jun,
  pages = {1--5},
  doi = {10.1109/WAMS64402.2025.11158247},
  abstract = {The rapid advancements in wearable technology and the integration of artificial intelligence have transformed healthcare by enabling real-time health monitoring and early disease detection. This project introduces a Smart Health Monitoring Glove, an innovative wearable device designed to continuously track key physiological parameters and provide comprehensive health assessments. The glove is embedded with multiple biosensors, including a Galvanic Skin Response (GSR) sensor, a temperature sensor, and the MAX30102 heart rate and SpO2 sensor, to measure vital health indicators such as skin conductivity, body temperature, heart rate, and oxygen saturation levels. The collected sensor data is processed using an Arduino microcontroller, ensuring seamless data acquisition and real-time analysis. To enhance its functionality beyond basic health tracking, the system employs a Random Forest machine learning model to classify health conditions into predefined risk categories, including stress levels, dehydration status, cardio-vascular risks, and respiratory concerns. The processed data is visualized on an LCD display for immediate user reference, while an integrated IoT module ensures wireless transmission of health reports to a mobile application. Additionally, the system provides real-time alerts and personalized recommendations based on detected anomalies. These recommendations may include workout plans, dietary modifications, hydration reminders, or medication suggestions, empowering users to take proactive measures in managing their health. By bridging the gap between real-time health monitoring and predictive analytics, this project contributes to the field of preventive healthcare, reducing the likelihood of emergency health crises. With its compact design, ease of use, and intelligent health assessment capabilities, the Smart Health Monitoring Glove serves as a valuable tool for individuals, healthcare professionals, fitness enthusiasts, and elderly caregivers, promoting a healthier and more informed lifestyle.},
  keywords = {Biomedical monitoring,Biomedical Sensors,Galvanic Skin Response (GSR),Heart rate,Heart Rate and SpO2 Monitoring,Internet of Things (IoT),Machine Learning,Mobile Health (mHealth),Monitoring,Personalized Health Recommendations,Physiological Signal Processing,Predictive Healthcare,Random Forest Classifier,Real-Time Health Assessment,Real-time systems,Skin,Smart healthcare,Smart Healthcare Devices,Temperature measurement,Temperature sensors,Wearable Health Monitoring,Wireless communication,Wireless sensor networks}
}

