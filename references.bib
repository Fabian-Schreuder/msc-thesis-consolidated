  keywords = {Architecture validation,Architecture Validation,Article,artificial intelligence,Artificial intelligence,Artificial Intelligence,Cardiology,Chronic heart failures,Chronic Heart Failures,clinical dashboard,Clinical Dashboard,clinical decision support system,Clinical Decision Support System,Computer architecture,Computer Architecture,Coordination reactions,Coordination Reactions,Diagnosis,Digital integrated circuits,Digital Integrated Circuits,digital platform,Digital Platform,Digital platforms,Digital Platforms,digital technology,Digital Technology,Diseases,education,Education,emergency care,Emergency Care,exergaming,Exergaming,Failure management,Failure Management,female,Female,gamification,Gamification,Health care,Health Care,health care personnel,Health Care Personnel,Healthcare systems,Healthcare Systems,Heart,heart failure,Heart Failure,High quality,High Quality,human,Human,Information management,Information Management,Information use,Information Use,integrated health care system,Integrated Health Care System,integration middleware,Integration Middleware,Interoperability,interoperability middleware,Interoperability Middleware,interpersonal communication,Interpersonal Communication,lifestyle,Lifestyle,long term care,Long Term Care,major clinical study,Major Clinical Study,male,Male,Management architectures,Management Architectures,Medical computing,Medical Computing,Medical information,Medical Information,Medical information systems,Medical Information Systems,medication compliance,Medication Compliance,nutritional support,Nutritional Support,Patient care,Patient Care,patient empowerment,Patient Empowerment,Patient population,Patient Population,person centered care,Person Centered Care,self care,Self Care,software,Software,telemonitoring,Telemonitoring,telerehabilitation,Telerehabilitation,validation study,Validation Study,virtual reality,Virtual Reality}
