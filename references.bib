@article{fitzgeraldIncorporatingRealworldEvidence2021,
  title = {Incorporating Real-World Evidence into the Development of Patient Blood Glucose Prediction Algorithms for the {{ICU}}},
  author = {Fitzgerald, O. and {Perez-Concha}, O. and Gallego, B. and Saxena, M.K. and Rudd, L. and {Metke-Jimenez}, A. and Jorm, L.},
  year = 2021,
  journal = {Journal of the American Medical Informatics Association},
  volume = {28},
  number = {8},
  pages = {1642--1650},
  publisher = {Oxford University Press},
  issn = {1527974X (ISSN); 10675027 (ISSN)},
  doi = {10.1093/jamia/ocab060},
  abstract = {Objective: Glycemic control is an important component of critical care. We present a data-driven method for predicting intensive care unit (ICU) patient response to glycemic control protocols while accounting for patient heterogeneity and variations in care. Materials and Methods: Using electronic medical records (EMRs) of 18 961 ICU admissions from the MIMIC-III dataset, including 318 574 blood glucose measurements, we train and validate a gradient boosted tree machine learning (ML) algorithm to forecast patient blood glucose and a 95\% prediction interval at 2-hour intervals. The model uses as inputs irregular multivariate time series data relating to recent in-patient medical history and glycemic control, including previous blood glucose, nutrition, and insulin dosing. Results: Our forecasting model using routinely collected EMRs achieves performance comparable to previous models developed in planned research studies using continuous blood glucose monitoring. Model error, expressed as mean absolute percentage error is 16.5\%-16.8\%, with Clarke error grid analysis demonstrating that 97\% of predictions would be clinically acceptable. The 95\% prediction intervals achieve near intended coverage at 93\%-94\%. Discussion: ML algorithms built on observational data sources, such as EMRs, present a promising approach for personalization and automation of glycemic control in critical care. Future research may benefit from applying a combination of methodologies and data sources to develop robust methodologies that account for the variations seen in ICU patients and difficultly in detecting the extremes of observed blood glucose values. Conclusion: We demonstrate that EMRs can be used to train ML algorithms that may be suitable for incorporation into ICU decision support systems. \copyright{} 2021 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {accounting,Accounting,aged,Aged,algorithm,Algorithm,Algorithms,Article,artificial ventilation,Artificial Ventilation,automation,Automation,Blood Glucose,blood glucose monitoring,Blood Glucose Monitoring,Blood Glucose Self-monitoring,Blood Glucose Self-Monitoring,cardiac surgery intensive care unit,Cardiac Surgery Intensive Care Unit,controlled study,Controlled Study,Critical Care,dietary intake,Dietary Intake,Electronic Health Records,electronic medical record,Electronic Medical Record,enteric feeding,Enteric Feeding,female,Female,forecasting,Forecasting,glucose blood level,Glucose Blood Level,glycemic control,Glycemic Control,hospital admission,Hospital Admission,human,Human,Humans,insulin,Insulin,intensive care unit,Intensive Care Unit,Intensive Care Units,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,medical history,Medical History,outcome assessment,Outcome Assessment,parenteral nutrition,Parenteral Nutrition,prediction,Prediction,time series analysis,Time Series Analysis}
}

@article{formanOntrackDevelopmentFeasibility2019,
  title = {Ontrack: {{Development}} and Feasibility of a Smartphone App Designed to Predict and Prevent Dietary Lapses},
  author = {Forman, E.M. and Goldstein, S.P. and Zhang, F. and Evans, B.C. and Manasse, S.M. and Butryn, M.L. and Juarascio, A.S. and Abichandani, P. and Martin, G.J. and Foster, G.D.},
  year = 2019,
  journal = {Translational Behavioral Medicine},
  volume = {9},
  number = {2},
  pages = {236--245},
  publisher = {Oxford University Press},
  issn = {16139860 (ISSN); 18696716 (ISSN)},
  doi = {10.1093/tbm/iby016},
  abstract = {Given that the overarching goal of weight loss programs is to remain adherent to a dietary prescription, specific moments of nonadherence known as ``dietary lapses'' can threaten weight control via the excess energy intake they represent and by provoking future lapses. Just-in-time adaptive interventions could be particularly useful in preventing dietary lapses because they use real-time data to generate interventions that are tailored and delivered at a moment computed to be of high risk for a lapse. To this end, we developed a smartphone application (app) called OnTrack that utilizes machine learning to predict dietary lapses and deliver a targeted intervention designed to prevent the lapse from occurring. This study evaluated the feasibility, acceptability, and preliminary effectiveness of OnTrack among weight loss program participants. An open trial was conducted to investigate subjective satisfaction, objective usage, algorithm performance, and changes in lapse frequency and weight loss among individuals (N = 43; 86\% female; body mass index = 35.6 kg/m2) attempting to follow a structured online weight management plan for 8 weeks. Participants were adherent with app prompts to submit data, engaged with interventions, and reported high levels of satisfaction. Over the course of the study, participants averaged a 3.13\% weight loss and experienced a reduction in unplanned lapses. OnTrack, the first Just-in-time adaptive intervention for dietary lapses was shown to be feasible and acceptable, and OnTrack users experienced weight loss and lapse reduction over the study period. These data provide the basis for further development and evaluation. \copyright{} 2021 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Diet Reducing/methods/psychology,*Mobile Applications,*Patient Compliance/psychology,*Smartphone,*Telemedicine/methods,adolescent,Adolescent,adult,Adult,aged,Aged,Article,body mass,Body Mass,body weight change,Body Weight Change,body weight loss,Body Weight Loss,clinical article,Clinical Article,computer assisted therapy,Computer Assisted Therapy,controlled study,Controlled Study,Diet,Diet Reducing,dietary pattern,Dietary Pattern,Digital,equipment design,Equipment Design,fatigue,Fatigue,Feasibility Studies,feasibility study,Feasibility Study,feeding behavior,Feeding Behavior,Feeding Behavior/psychology,female,Female,Hispanic,human,Human,Humans,Internet,Lapses,low calorie diet,Low Calorie Diet,machine learning,Machine Learning,male,Male,middle aged,Middle Aged,mobile application,Mobile Application,Mobile Applications,obesity,Obesity,open study,Open Study,Overweight,Overweight/psychology/therapy,patient compliance,Patient Compliance,patient satisfaction,Patient Satisfaction,physical activity,Physical Activity,predictive value,Predictive Value,priority journal,Priority Journal,procedures,Procedures,program acceptability,Program Acceptability,program effectiveness,Program Effectiveness,psychology,Psychology,risk assessment,Risk Assessment,smartphone,Smartphone,Smartphone app,Smartphone App,telemedicine,Telemedicine,Therapy Computer-assisted,Therapy Computer-Assisted,treatment outcome,Treatment Outcome,Weight,Weight Loss,weight loss program,Weight Loss Program,Weight Reduction Programs,Weight Reduction Programs/*methods,young adult,Young Adult}
}

@article{formanRandomizedControlledTrial2019,
  title = {Randomized Controlled Trial of {{OnTrack}}, a Just-in-Time Adaptive Intervention Designed to Enhance Weight Loss},
  author = {Forman, E.M. and Goldstein, S.P. and Crochiere, R.J. and Butryn, M.L. and Juarascio, A.S. and Zhang, F. and Foster, G.D.},
  year = 2019,
  journal = {Translational Behavioral Medicine},
  volume = {9},
  number = {6},
  pages = {989--1001},
  publisher = {Oxford University Press},
  issn = {16139860 (ISSN); 18696716 (ISSN)},
  doi = {10.1093/tbm/ibz137},
  abstract = {Individual instances of nonadherence to reduced calorie dietary prescriptions, that is, dietary lapses, represent a key challenge for weight management. Just-in-time adaptive interventions (JITAIs), which collect and analyze data in real time to deliver tailored interventions during moments of need, may be well suited to promote weight loss by preventing dietary lapses. We developed OnTrack (OT), a smartphone application (app) that collects data on lapses and triggers of lapse, uses a continuously improving machine learning model to predict lapse risk, and delivers tailored interventions when risk is elevated. The current study evaluated the efficacy of OT against an active control in facilitating weight loss. Participants (N = 181) with overweight/obesity (M{$<$}inf{$>$}BMI{$<$}/inf{$>$} = 34.32; 85.1\% female; 73.5\% White) were randomized to receive either the WW (formerly Weight Watchers) Beyond the Scale (BTS) digital program alone or WW plus OnTrack (WW + OT) for 10 weeks. In an unplanned, natural experiment, the WW program changed mid-way through the trial from BTS to a more flexible one, Freestyle (FS). A general linear model revealed a treatment condition \texttimes{} diet plan interaction (F[1, 173] = 9.68, p =. 002) such that OT demonstrated greater efficacy only among those receiving BTS (weight loss M{$<$}inf{$>$}WW + OT{$<$}/inf{$>$} = 4.7\%, standard error [SE] =. 55 versus M{$<$}inf{$>$}WW{$<$}/inf{$>$} = 2.6\%, SE =. 80). Compared to FS, BTS WW + OT participants also reported considerably higher satisfaction with the intervention, engagement was higher, and algorithm accuracy was superior. Overall, results offer qualified support for OT and generally for machine learning-powered JITAIs that facilitate weight loss by predicting and preventing dietary lapses. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,Article,body mass,Body Mass,controlled study,Controlled Study,descriptive research,Descriptive Research,Diet,Digital Health,eating,Eating,false positive result,False Positive Result,female,Female,human,Human,Humans,Lapses,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,marriage,Marriage,middle aged,Middle Aged,mobile application,Mobile Application,Mobile Applications,motivation,Motivation,obesity,Obesity,Outcome and Process Assessment Health Care,Outcome And Process Assessment Health Care,Overweight,patient compliance,Patient Compliance,patient satisfaction,Patient Satisfaction,physical activity,Physical Activity,priority journal,Priority Journal,procedures,Procedures,race difference,Race Difference,randomized controlled trial,Randomized Controlled Trial,risk assessment,Risk Assessment,satisfaction,Satisfaction,self report,Self Report,sex difference,Sex Difference,Smartphone Application,telemedicine,Telemedicine,Weight Loss,weight loss program,Weight Loss Program,Weight Reduction Programs}
}

