}

@article{dingRelationshipCReactiveProtein2025,
  title = {The {{Relationship Between C-Reactive Protein}}--{{Triacylglycerol}}--{{Glucose Index}} and {{All-Cause Mortality}} in {{Patients With Cardiovascular Disease}}: {{A Retrospective Cohort Study}} and {{Development}} of a {{Machine Learning Prediction Model}}},
  author = {Ding, W. and Shi, F. and Wang, Z. and Wang, L. and Fang, C.},
  year = 2025,
  journal = {Cardiovascular Therapeutics},
  volume = {2025},
  number = {1},
  publisher = {{John Wiley and Sons Inc}},
  issn = {17555914 (ISSN); 17555922 (ISSN)},
  doi = {10.1155/cdr/6914985},
  abstract = {Objective: The CTI is increasingly recognized as a new marker for assessing inflammation and insulin resistance. However, the relationship between CTI and all-cause mortality risk in patients with CVD remains unclear. Methods: We analyzed data from the NHANES from 1999 to 2010. The correlation between CTI and all-cause mortality risk in CVD patients was examined using Cox regression analysis. Nonlinear relationships between CTI and all-cause mortality risk were explored through restricted cubic splines and Cox proportional hazards regression. We employed six ML models, including RF, LightGBM, DT, XGBoost, LR, and KNN, to predict all-cause mortality risk in CVD patients based on CTI and SHAP for interpretability. Results: A total of 1429 CVD patients were included, with 849 all-cause deaths recorded during the follow-up period. After adjusting for potential confounding factors, the highest quartile of CTI (Q4) significantly increased the risk of all-cause mortality compared to the lowest quartile (Q1) (HR = 1.38, 95\% CI: 1.04--1.84, p = 0.03). Restricted cubic splines demonstrated a nonlinear relationship between CTI and all-cause mortality risk in CVD patients. Among the machine learning models, the LightGBM model exhibited the best predictive performance, with an ROC of 0.967, accuracy of 0.909, sensitivity of 0.906, specificity of 0.914, F1 score of 0.922, recall of 0.906, and PR of 0.979. SHAP analysis identified age, BU, and CTI as the primary predictive factors, with CTI positively correlated with all-cause mortality risk in CVD patients. Conclusion: There is a nonlinear relationship between CTI and all-cause mortality risk in CVD patients, with elevated CTI levels significantly associated with increased mortality risk. Additionally, for the first time, this study constructed a machine learning model to predict all-cause mortality risk in cardiovascular disease using CTI, with LightGBM demonstrating the best predictive performance. SHAP analysis identified age, BUN, and CTI as critical factors in the prediction, providing valuable references for future related research. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,age distribution,Age Distribution,aged,Aged,all cause mortality,All Cause Mortality,All-cause Mortality,Article,autacoid,Autacoid,biological marker,Biological Marker,Biomarkers,blood,Blood,Blood Glucose,C reactive protein,C Reactive Protein,C reactive protein triglyceride glucose index,C Reactive Protein Triglyceride Glucose Index,C-reactive Protein,C-Reactive Protein,C-reactive Protein-triglyceride-glucose Index,cardiovascular disease,Cardiovascular Disease,Cardiovascular Diseases,cause of death,Cause of Death,Cause Of Death,cohort analysis,Cohort Analysis,confidence interval,Confidence Interval,Cti,Cvd,decision support system,Decision Support System,Decision Support Techniques,decision tree,Decision Tree,diagnosis,Diagnosis,diagnostic accuracy,Diagnostic Accuracy,diagnostic test accuracy study,Diagnostic Test Accuracy Study,epidemiology,Epidemiology,extreme gradient boosting,Extreme Gradient Boosting,female,Female,follow up,Follow Up,glucose,Glucose,glucose blood level,Glucose Blood Level,hazard ratio,Hazard Ratio,human,Human,Humans,Inflammation Mediators,k nearest neighbor,K Nearest Neighbor,light gradient boosting machine,Light Gradient Boosting Machine,logistic regression analysis,Logistic Regression Analysis,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,metabolism,Metabolism,middle aged,Middle Aged,mortality,Mortality,mortality risk,Mortality Risk,nutrition,Nutrition,Nutrition Surveys,predictive model,Predictive Model,predictive value,Predictive Value,Predictive Value of Tests,Predictive Value Of Tests,prognosis,Prognosis,prognostic assessment,Prognostic Assessment,proportional hazards model,Proportional Hazards Model,random forest,Random Forest,Retrospective Studies,retrospective study,Retrospective Study,risk assessment,Risk Assessment,risk factor,Risk Factor,Risk Factors,sensitivity and specificity,Sensitivity And Specificity,Shapley additive explanation,Shapley Additive Explanation,time fact