@inproceedings{kobayashiFrailtyMeterHealthy2021,
  title = {Frailty Meter for Healthy Long Life},
  booktitle = {2021 Thirteenth International Conference on Mobile Computing and Ubiquitous Network ({{ICMU}})},
  author = {Kobayashi, Toru and Kishimoto, Yuta and Kimura, Fukuyoshi and Fukae, Kazuki and Imai, Tetsuo and Arai, Kenichi},
  year = 2021,
  month = nov,
  pages = {1--6},
  doi = {10.23919/ICMU50196.2021.9638958},
  abstract = {Frailty, a concept proposed by the Japanese Geriatrics Society in 2014, is a state of decline in physical and cognitive functions in the middle of the transition from normal health to needing nursing care. By understanding the states and signs of ``frailty,'' appropriate treatment and prevention can be carried out, and there is a possibility of preventing the condition from progressing to need for long-term care. Check sheets and medical interviews have generally been used to determine frailty. However, we developed a smartphone application called ``Frailty Meter'' that collects information on daily activities and diet using a smartwatch or smartphone, and automatically animates the degree of frailty. It visualizes and quantifies frailty.},
