@article{neoUseLargeLanguage2024,
  title = {Use of Large Language Model-Based Chatbots in Managing the Rehabilitation Concerns and Education Needs of Outpatient Stroke Survivors and Caregivers},
  author = {Neo, J.R.E. and Ser, J.S. and Tay, S.S.},
  year = 2024,
  journal = {Frontiers in Digital Health},
  volume = {6},
  publisher = {Frontiers Media SA},
  issn = {2673253X (ISSN)},
  doi = {10.3389/fdgth.2024.1395501},
  abstract = {Background: The utility of large language model-based (LLM) artificial intelligence (AI) chatbots in many aspects of healthcare is becoming apparent though their ability to address patient concerns remains unknown. We sought to evaluate the performance of two well-known, freely-accessible chatbots, ChatGPT and Google Bard, in responding to common questions about stroke rehabilitation posed by patients and their caregivers. Methods: We collected questions from outpatients and their caregivers through a survey, categorised them by theme, and created representative questions to be posed to both chatbots. We then evaluated the chatbots' responses based on accuracy, safety, relevance, and readability. Interrater agreement was also tracked. Results: Although both chatbots achieved similar overall scores, Google Bard performed slightly better in relevance and safety. Both provided readable responses with some general accuracy, but struggled with hallucinated responses, were often not specific, and lacked awareness of the possibility for emotional situations with the potential to turn dangerous. Additionally, interrater agreement was low, highlighting the variability in physician acceptance of their responses. Conclusions: AI chatbots show potential in patient-facing support roles, but issues remain regarding safety, accuracy, and relevance. Future chatbots should address these problems to ensure that they can reliably and independently manage the concerns and questions of stroke patients and their caregivers. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,Article,artificial intelligence,Artificial Intelligence,caregiver,Caregiver,Caregivers,Chatbots,Chatgpt,cohort analysis,Cohort Analysis,computer aided design,Computer Aided Design,data accuracy,Data Accuracy,data base,Data Base,data collection method,Data Collection Method,demographics,Demographics,education,Education,evaluation study,Evaluation Study,Google Bard,health care,Health Care,health survey,Health Survey,human,Human,information processing,Information Processing,language model,Language Model,Large Language Model,Likert scale,Likert Scale,nutrition,Nutrition,outpatient,Outpatient,physical examination,Physical Examination,physician,Physician,prognosis,Prognosis,qualitative analysis,Qualitative Analysis,questionnaire,Questionnaire,Rehabilitation,rehabilitation care,Rehabilitation Care,safety,Safety,smoking,Smoking,social support,Social Support,Stroke,stroke survivor,Stroke Survivor,technology,Technology}
