@article{harperPredictivePerformanceWearable2025,
  title = {Predictive Performance of Wearable Sensors for Mortality Risk in Older Adults: A Model Development and Validation Study.},
  author = {Harper, Charlie and Sturge, Adam D. and Chan, Shing and Maylor, Ben and Shreves, Alaina and Meier, Daniel and Patkee, Prachi and Schoonbee, John and Strange, Adam and Nabholz, Christoph and Bennett, Derrick and Doherty, Aiden},
  year = 2025,
  month = apr,
  journal = {medRxiv : the preprint server for health sciences},
  pages = {2025.04.03.25325101},
  doi = {10.1101/2025.04.03.25325101},
  abstract = {BACKGROUND: Many adults in high-income countries carry a device capable of measuring physical-activity behaviour. Thus, there is public health need to  understand whether such data can enhance prediction of future health outcomes. We  aimed to investigate whether device-measured daily-step count and walking cadence  improve the prediction of mortality beyond traditional risk-factors. METHODS:  Risk models were developed to predict five-year all-cause mortality using data  from the UK Biobank accelerometer sub-study, with external validation in the US  2011-2014 National Health and Nutrition Examination Survey (NHANES). Median  daily-step count and peak one-minute walking cadence were derived using  self-supervised machine learning models from seven-day wrist-worn accelerometer  data. Cox models were used to develop a baseline model incorporating traditional  risk-factors, and a baseline model plus accelerometer data (i.e. daily-steps and  walking cadence). Changes in model performance were assessed using Harrell's  C-index, net reclassification index (NRI; 10\% threshold), and the Nam-D'Agostino  calibration test. FINDINGS: Among 79,717 UK Biobank participants, 1,640 died  within 5-years. Adding accelerometer data to the baseline model modestly improved  risk discrimination and classification with a change in c-index of 0.008 (95\%  confidence interval [CI] 0.005-0.011) and 3.3\% NRI (95\%CI 2.1\%-4.5\%). Greatest  improvements in prediction were observed in participants with prior disease at  baseline, showing a change in c-index of 0.028 (95\%CI 0.019-0.039) and 5.9\% NRI  (95\%CI 3.1\%-8.6\%). In the NHANES external validation cohort (n=4,713;  deaths=378), similar improvements in prediction were observed (change in c-index:  0.015, 95\%CI 0.007-0.025; NRI: 4.0\%, 95\%CI 0.7\%-7.4\%). All models were well  calibrated (Nam-D'Agostino {$\chi$}(2) range: 6.8-13.2). INTERPRETATION: Device-measured  daily-step count and walking cadence consistently demonstrated modest  improvements in predicting mortality risk beyond traditional risk-factors, with  the most significant enhancements seen in individuals with prior disease. These  findings suggest that incorporating information from wearables does provide  important new ways to improve risk stratification for targeted intervention in  high-risk individuals.},
  langid = {english},
  pmcid = {PMC12191095},
  pmid = {40568664},
  keywords = {accelerometer,mortality,physical activity,risk prediction,step count}
}

@inproceedings{harshithaEMOCAREXAIEnabled2025,
  title = {{{EMOCARE}}: {{XAI Enabled Emotion Detection}} and {{Health Guidance}} for {{Pregnancy}} and {{Postpartum Wellness}}},
  author = {Harshitha, N. and Reethika, K. and Krishnaveni, S. and Sahu, M.},
  year = 2025,
  pages = {743--749},
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  doi = {10.1109/ICOEI65986.2025.11013638},
  abstract = {The present study explores a significant need in maternal healthcare by presenting EMOCARE, an explainable AI-based solution aimed at delivering personalized emotional and health assistance throughout pregnancy and the postpartum phase, which entails distinct wellness requirements. EMOCARE accurately identifies emotions via the analysis of physiological and behavioral data, providing clear, personalized health recommendations specifically designed for the emotional and mental well-being of expectant and new mothers. The system employs Long Short-Term Memory (LSTM) networks for temporal data analysis and SHAP (SHapley Additive exPlanations) for model interpretability, hence assuring precision and transparency in its predictions. This openness cultivates trust between healthcare practitioners and patients, empowering women with confidence in AI-generated health data and facilitating more proactive, educated wellness treatments. Future research intends to augment EMOCARE by integrating supplementary data sources and improving its explainability, allowing a more profound understanding of mental health dynamics throughout pregnancy and the postpartum period. Ultimately, EMOCARE aims to enhance maternal well-being by providing accurate, proactive AI-driven assistance, facilitating greater use of wearable health technologies in women's health management. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9798331544607 (ISBN)},
  langid = {english},
  keywords = {Assisted living,Assisted Living,Behavioral data,Behavioral Data,Biomedical engineering,Biomedical Engineering,Diseases,Electrotherapeutics,Emotion detection,Emotion Detection,Emotional detection,Emotional Detection,Explainable artificial intelligence (XAI),Explainable Artificial Intelligence (xai),Geriatrics,mHealth,Mhealth,Nutrition,Obstetrics,Personalized health recommendation,Personalized Health Recommendation,Personalized Health Recommendations,Personalized healths,Personalized Healths,Personalized medicine,Personalized Medicine,Physiological data,Physiological Data,Postpartum wellness,Postpartum Wellness,Short term memory,Short Term Memory,Wearable Technology,Well being,Well Being}
