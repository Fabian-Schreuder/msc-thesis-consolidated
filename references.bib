@article{maPerformanceAIPrediction2025,
  title = {Performance of an {{AI}} Prediction Tool for New-Onset Atrial Fibrillation after Coronary Artery Bypass Grafting},
  author = {Ma, H. and Chen, D. and Lv, W. and Liao, Q. and Li, J. and Zhu, Q. and Zhang, Y. and Deng, L. and Liu, X. and Wu, Q.},
  year = 2025,
  journal = {eClinicalMedicine},
  volume = {81},
  publisher = {Elsevier Ltd},
  issn = {25895370 (ISSN)},
  doi = {10.1016/j.eclinm.2025.103131},
  abstract = {Background: There is lack of tools to predict new-onset postoperative atrial fibrillation (NOAF) after coronary artery bypass grafting (CABG). We aimed to develop and validate a novel AI-based bedside tool that accurately predicts predict NOAF after CABG. Methods: Data from 2994 patients who underwent CABG between March 2015 and July 2024 at two tertiary hospitals in China were retrospectively analyzed. 2486 patients from one hospital formed the derivation cohort, split 7:3 into training and test sets, while the 508 patients from a separate hospital formed the external validation cohort. A stacking model integrating 11 base learners was developed and evaluated using Accuracy, Precision, Recall, F1 score, and Area Under Curve (AUC). SHapley Additive exPlanations (SHAP) values were calculated and plotted to interpret the contributions of individual characteristics to the model's predictions. Findings: Seventy-seven predictive characteristics were analyzed. The stacking model achieved superior performance with AUCs 0{$\cdot$}931 and F1 scores 0{$\cdot$}797 in the independent external validation, outperforming CHA2DS2-VASc, HATCH, and POAF scores (AUC 0{$\cdot$}931 vs. 0{$\cdot$}713, 0{$\cdot$}708, and 0{$\cdot$}667; p {$<$} 0{$\cdot$}05). SHAP value indicate that the importance of predictive features for NOAF, in descending order, include: Brain natriuretic peptide, Left ventricular end-diastolic diameter, Ejection fraction, BMI, {$\beta$}-receptor blockers, Duration of surgery, Age, Neutrophil percentage-to-albumin ratio, Myocardial infarction, Left atrial diameter, Hypertension, and smoking status. Subsequently, we constructed an easy-to-use bedside clinical tool for NOAF risk assessment leveraging these characteristics. Interpretation: The AI-based tool offers superior prediction of NOAF, outperforming three existing predictive tools. Future studies should further explore how various patient characteristics influence the timing of NOAF onset, whether early or late. Funding: This work was funded by Lingnan Nightingale Nursing Research Institute of Guangdong Province, and Guangdong Nursing Society (GDHLYJYZ202401). \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,all cause mortality,All Cause Mortality,Article,artificial intelligence,Artificial Intelligence,atrial fibrillation,Atrial Fibrillation,Barthel index,Barthel Index,Bayesian learning,Bayesian Learning,beta adrenergic receptor blocking agent,Beta Adrenergic Receptor Blocking Agent,body mass,Body Mass,brain natriuretic peptide,Brain Natriuretic Peptide,cardiovascular disease assessment,Cardiovascular Disease Assessment,Cha2ds2-vasc Score,CHA2DS2-VASc score,chronic obstructive lung disease,Chronic Obstructive Lung Disease,cohort analysis,Cohort Analysis,controlled study,Controlled Study,coronary artery bypass graft,Coronary Artery Bypass Graft,Coronary Artery Bypass Grafting,cross validation,Cross Validation,decision making,Decision Making,decision tree,Decision Tree,deep learning,Deep Learning,diagnostic test accuracy study,Diagnostic Test Accuracy Study,electrocardiography,Electrocardiography,estimated glomerular filtration rate,Estimated Glomerular Filtration Rate,female,Female,Hatch Score,HATCH score,heart ejection fraction,Heart Ejection Fraction,heart infarction,Heart Infarction,human,Human,hypertension,Hypertension,intracardiac echocardiography,Intracardiac Echocardiography,k nearest neighbor,K Nearest Neighbor,least absolute shrinkage and selection operator,Least Absolute Shrinkage And Selection Operator,left ventricular end-diastolic diameter,Left Ventricular End-diastolic Diameter,Machine Learning,major clinical study,Major Clinical Study,male,Male,malnutrition,Malnutrition,multilayer perceptron,Multilayer Perceptron,neutrophil percentage,Neutrophil Percentage,new-onset atrial fibrillation,New-onset Atrial Fibrillation,people by smoking status,People By Smoking Status,Poaf Score,POAF score,Postoperative Atrial Fibrillation,prediction,Prediction,Prediction Model,predictive model,Predictive Model,prognostic assessment,Prognostic Assessment,random forest,Random Forest,receiver operating characteristic,Receiver Operating Characteristic,retrospective study,Retrospective Study,risk assessment,Risk Assessment,Rr Interval,RR interval,sensitivity analysis,Sensitivity Analysis,sinus rhythm,Sinus Rhythm,support vector machine,Support Vector Machine,validation process,Validation Process,Web Tool}
