@article{albinodequeirozWearableChatbotbasedModel2023,
  title = {A Wearable Chatbot-Based Model for Monitoring Colorectal Cancer Patients in the Active Phase of Treatment},
  author = {{Albino de Queiroz}, D. and Silva Passarello, R. and {Veloso de Moura F{\'e}}, V. and Rossini, A. and {Folchini da Silveira}, E. and {Aparecida Isquierdo Fonseca de Queiroz}, E. and {Andre da Costa}, C.},
  year = 2023,
  journal = {Healthcare Analytics},
  volume = {4},
  publisher = {Elsevier Inc.},
  issn = {27724425 (ISSN)},
  doi = {10.1016/j.health.2023.100257},
  abstract = {Colorectal cancer is one of the leading causes of death in the world. This study presents the findings of a prospective non-randomized clinical study for evaluating a new computational model for monitoring colorectal cancer patients in the active treatment phase using artificial intelligence and the Internet of Things. For eight weeks, patients self-reported perceived symptoms and adverse effects, practiced physical activity, and data about their diet. The outcome assessment was based on comparing the intervention and control groups. Patients evaluated the model using the User Experience Questionnaire (UEQ) and the System Usability Scale (SUS). Patients who participated in the model reported signs and symptoms more accurately (control: 64.7\%; intervention: 92.3\%; p = 0.1038). In the intervention group, physical activity was more effective, and most patients (61.5\%) interacted with the chatbot for at least 62.5\% of the period. Results indicate that the model contributes to more assertive data collection and greater patient engagement in self-management of symptoms and adverse effects of treatment and cancer. Moreover, the model contributed to increasing the practice of light physical activity by patients. UEQ and SUS scores indicate that the model met users' expectations and has acceptable usability. \copyright{} 2023 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {accuracy,Accuracy,adult,Adult,adverse event,Adverse Event,aged,Aged,Article,artificial intelligence,Artificial Intelligence,artificial intelligence chatbot,Artificial Intelligence Chatbot,bevacizumab,Bevacizumab,cancer chemotherapy,Cancer Chemotherapy,cancer patient,Cancer Patient,cancer radiotherapy,Cancer Radiotherapy,cancer surgery,Cancer Surgery,capecitabine,Capecitabine,capecitabine plus oxaliplatin,Capecitabine Plus Oxaliplatin,cetuximab,Cetuximab,Chatbot,clinical article,Clinical Article,clinical study,Clinical Study,cloud computing,Cloud Computing,cognitive behavioral therapy,Cognitive Behavioral Therapy,colorectal cancer,Colorectal Cancer,controlled study,Controlled Study,data analysis,Data Analysis,data base,Data Base,deterioration,Deterioration,diet,Diet,feedback system,Feedback System,female,Female,fluorouracil,Fluorouracil,folinic acid,Folinic Acid,human,Human,information processing,Information Processing,internet of things,Internet Of Things,machine learning,Machine Learning,male,Male,man machine interaction,Man Machine Interaction,middle aged,Middle Aged,multidisciplinary team,Multidisciplinary Team,natural language processing,Natural Language Processing,nutrition,Nutrition,outcome assessment,Outcome Assessment,oxaliplatin,Oxaliplatin,patient engagement,Patient Engagement,patient monitoring,Patient Monitoring,personalized medicine,Personalized Medicine,physical activity,Physical Activity,physical disease by body function,Physical Disease By Body Function,prospective study,Prospective Study,self care,Self Care,self report,Self Report,symptom,Symptom,system usability scale,System Usability Scale,usability,Usability,usability testing,Usability Testing,User Experience Questionnaire,very elderly,Very Elderly}
}

@article{alfonsiCarbohydrateCountingApp2020,
  title = {Carbohydrate Counting App Using Image Recognition for Youth with {{Type}} 1 Diabetes: {{Pilot}} Randomized Control Trial},
  author = {Alfonsi, J.E. and Choi, E.E.Y. and Arshad, T. and Sammott, S.-A.S. and Pais, V. and Nguyen, C. and Maguire, B.R. and Stinson, J.N. and Palmert, M.R.},
  year = 2020,
  journal = {JMIR mHealth and uHealth},
  volume = {8},
  number = {10},
  publisher = {JMIR Publications Inc.},
  issn = {22915222 (ISSN)},
  doi = {10.2196/22074},
  abstract = {Background: Carbohydrate counting is an important component of diabetes management, but it is challenging, often performed inaccurately, and can be a barrier to optimal diabetes management. iSpy is a novel mobile app that leverages machine learning to allow food identification through images and that was designed to assist youth with type 1 diabetes in counting carbohydrates. Objective: Our objective was to test the app's usability and potential impact on carbohydrate counting accuracy. Methods: Iterative usability testing (3 cycles) was conducted involving a total of 16 individuals aged 8.5-17.0 years with type 1 diabetes. Participants were provided a mobile device and asked to complete tasks using iSpy app features while thinking aloud. Errors were noted, acceptability was assessed, and refinement and retesting were performed across cycles. Subsequently, iSpy was evaluated in a pilot randomized controlled trial with 22 iSpy users and 22 usual care controls aged 10-17 years. Primary outcome was change in carbohydrate counting ability over 3 months. Secondary outcomes included levels of engagement and acceptability. Change in HbA{$<$}inf{$>$}1c{$<$}/inf{$>$} level was also assessed. Results: Use of iSpy was associated with improved carbohydrate counting accuracy (total grams per meal, P=.008), reduced frequency of individual counting errors greater than 10 g (P=.047), and lower HbA{$<$}inf{$>$}1c{$<$}/inf{$>$} levels (P=.03). Qualitative interviews and acceptability scale scores were positive. No major technical challenges were identified. Moreover, 43\% (9/21) of iSpy participants were still engaged, with usage at least once every 2 weeks, at the end of the study. Conclusions: Our results provide evidence of efficacy and high acceptability of a novel carbohydrate counting app, supporting the advancement of digital health apps for diabetes care among youth with type 1 diabetes. Further testing is needed, but iSpy may be a useful adjunct to traditional diabetes management. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adolescent,Adolescent,carbohydrate,Carbohydrate,Carbohydrate Counting,Carbohydrates,child,Child,controlled study,Controlled Study,Diabetes Mellitus Type 1,diet therapy,Diet Therapy,Digital Health Applications (apps),human,Human,Humans,Image Recognition,insulin dependent diabetes mellitus,Insulin Dependent Diabetes Mellitus,Mhealth,mobile application,Mobile Application,Mobile Applications,Nutrition Therapy,Pilot Projects,pilot study,Pilot Study,randomized controlled trial,Randomized Controlled Trial,Type 1 Diabetes,Youth}
}

@article{alharbiPersonalizedChatbotSupport2025,
  title = {A {{Personalized Chatbot}} to {{Support Kidney Disease Patients}} in {{Saudi Arabia}}: {{A Preliminary Study}}},
  author = {Alharbi, D. and Alharb, L. and Alzurayyir, N. and Alharbi, A.},
  year = 2025,
  journal = {Studies in Health Technology and Informatics},
  volume = {329},
  pages = {1909--1913},
  issn = {18798365 (ISSN); 09269630 (ISSN); 9781643685939 (ISBN); 9781643685946 (ISBN); 9781643683409 (ISBN); 1586031430 (ISBN); 9781607508052 (ISBN); 9781586037512 (ISBN); 1586036475 (ISBN); 1586032038 (ISBN); 9051993625 (ISBN); 9781614996521 (ISBN)},
  doi = {10.3233/SHTI251275},
  abstract = {Chronic kidney disease (CKD) is a significant health issue worldwide. This study investigates the potential of personalized chatbots to support kidney disease patients and their caregivers in Saudi Arabia. Using a cross-sectional design, data was collected via an online questionnaire to get insights into patient preferences and willingness to use chatbots in kidney disease care. Findings revealed high acceptance of chatbot technology, with 95.5\% of participants willing to engage with a virtual assistant. Key features identified include dietary guidance, educational content, and psychological support. The study highlights the chatbot's potential to address significant challenges such as limited knowledge, high treatment costs, and dietary management. These insights provide a foundation for developing a prototype chatbot tailored to the needs of kidney disease patients in Saudi Arabia, with the potential to enhance healthcare accessibility and patient quality of life. This record is sourced from MEDLINE/PubMed, a database of the U.S. National Library of Medicine},
  langid = {english},
  keywords = {*Patient Education as Topic/methods,*Renal Insufficiency Chronic/therapy/psychology,adult,Adult,aged,Aged,chatbots,Chatbots,chronic kidney failure,Chronic Kidney Failure,Ckd,CKD,Cross-sectional Studies,Cross-Sectional Studies,cross-sectional study,Cross-sectional Study,female,Female,generative artificial intelligence,Generative Artificial Intelligence,human,Human,Humans,male,Male,middle aged,Middle Aged,patient education,Patient Education,Patient Education as Topic,Patient Education As Topic,patient preference,Patient Preference,Patient Preference/statistics & numerical data,Personalized health,Personalized Health,procedures,Procedures,psychology,Psychology,questionnaire,Questionnaire,Renal Insufficiency Chronic,Saudi Arabia,Surveys and Questionnaires,Surveys And Questionnaires,therapy,Therapy}
