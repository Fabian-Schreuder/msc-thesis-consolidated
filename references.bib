@article{shenAssessingAccuracyWrist2017,
  title = {Assessing the {{Accuracy}} of a {{Wrist Motion Tracking Method}} for {{Counting Bites Across Demographic}} and {{Food Variables}}},
  author = {Shen, Y. and Salley, J. and Muth, E. and Hoover, A.},
  year = 2017,
  journal = {IEEE Journal of Biomedical and Health Informatics},
  volume = {21},
  number = {3},
  pages = {599--606},
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  issn = {21682208 (ISSN); 21682194 (ISSN)},
  doi = {10.1109/JBHI.2016.2612580},
  abstract = {This paper describes a study to test the accuracy of a method that tracks wrist motion during eating to detect and count bites. The purpose was to assess its accuracy across demographic (age, gender, and ethnicity) and bite (utensil, container, hand used, and food type) variables. Data were collected in a cafeteria under normal eating conditions. A total of 271 participants ate a single meal while wearing a watch-like device to track their wrist motion. A video was simultaneously recorded of each participant and subsequently reviewed to determine the ground truth times of bites. Bite times were operationally defined as the moment when food or beverage was placed into the mouth. Food and beverage choices were not scripted or restricted. Participants were seated in groups of 2-4 and were encouraged to eat naturally. A total of 24 088 bites of 374 different food and beverage items were consumed. Overall the method for automatically detecting bites had a sensitivity of 75\% with a positive predictive value of 89\%. A range of 62-86\% sensitivity was found across demographic variables with slower eating rates trending toward higher sensitivity. Variations in sensitivity due to food type showed a modest correlation with the total wrist motion during the bite, possibly due to an increase in head-toward-plate motion and decrease in hand-toward-mouth motion for some food types. Overall, the findings provide the largest evidence to date that the method produces a reliable automated measure of intake during unrestricted eating. \copyright{} 2022 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Food/classification/statistics & numerical data,accelerometer,Accelerometer,Activity recognition,Activity Recognition,activity tracker,Activity Tracker,adolescent,Adolescent,adult,Adult,aged,Aged,algorithm,Algorithm,Article,automated pattern recognition,Automated Pattern Recognition,Beverages,biomedical microelectromechanical system,Biomedical Microelectromechanical System,caloric intake,Caloric Intake,classification,Classification,Demographic variables,Demographic Variables,demography,Demography,devices,Devices,Energy intake,Energy Intake,Energy Intake/*physiology,equipment design,Equipment Design,evaluation study,Evaluation Study,feeding behavior,Feeding Behavior,Feeding Behavior/*physiology,female,Female,Fitness Trackers,food,Food,food intake,Food Intake,gesture,Gesture,Gesture recognition,Gesture Recognition,Gestures,Ground truth,Ground Truth,human,Human,Humans,joint characteristics and functions,Joint Characteristics And Functions,male,Male,mHealth,Mhealth,middle aged,Middle Aged,Monitoring Physiologic,Monitoring Physiologic/instrumentation/methods,motion analysis system,Motion Analysis System,Motion tracking,Motion Tracking,Movement,movement (physiology),Movement (physiology),Movement/physiology,Pattern Recognition Automated,Pattern Recognition Automated/*methods,physiologic monitoring,Physiologic Monitoring,physiology,Physiology,Plate motions,Plate Motions,Population statistics,Population Statistics,Positive predictive values,Positive Predictive Values,predictive value,Predictive Value,procedures,Procedures,sensitivity analysis,Sensitivity analysis,Sensitivity Analysis,statistics and numerical data,Statistics And Numerical Data,Stmicroelectronics Lis344alh,Stmicroelectronics Lpr410al,Video Recording,videorecording,Videorecording,wrist,Wrist,wrist motion,Wrist Motion,Wrist motions,Wrist Motions,Wrist/*physiology,young adult,Young Adult}
