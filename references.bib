@article{shinAutomaticClinicalAssessment2024,
  title = {Automatic {{Clinical Assessment}} of {{Swallowing Behavior}} and {{Diagnosis}} of {{Silent Aspiration Using Wireless Multimodal Wearable Electronics}}},
  author = {Shin, B. and Lee, S.H. and Kwon, K. and Lee, Y.J. and Crispe, N. and Ahn, S.-Y. and Shelly, S. and Sundholm, N. and Tkaczuk, A. and Yeo, M.-K.},
  year = 2024,
  journal = {Advanced Science},
  volume = {11},
  number = {34},
  publisher = {{John Wiley and Sons Inc}},
  issn = {21983844 (ISSN)},
  doi = {10.1002/advs.202404211},
  abstract = {Dysphagia is more common in conditions such as stroke, Parkinson's disease, and head and neck cancer. This can lead to pneumonia, choking, malnutrition, and dehydration. Currently, the diagnostic gold standard uses radiologic imaging, the videofluoroscopic swallow study (VFSS); however, it is expensive and necessitates specialized facilities and trained personnel. Although several devices attempt to address the limitations, none offer the clinical-grade quality and accuracy of the VFSS. Here, this study reports a wireless multimodal wearable system with machine learning for automatic, accurate clinical assessment of swallowing behavior and diagnosis of silent aspirations from dysphagia patients. The device includes a kirigami-structured electrode that suppresses changes in skin contact impedance caused by movements and a microphone with a gel layer that effectively blocks external noise for measuring high-quality electromyograms and swallowing sounds. The deep learning algorithm offers the classification of swallowing patterns while diagnosing silent aspirations, with an accuracy of 89.47\%. The demonstration with post-stroke patients captures the system's significance in measuring multiple physiological signals in real-time for detecting swallowing disorders, validated by comparing them with the VFSS. The multimodal electronics can ensure a promising future for dysphagia healthcare and rehabilitation therapy, providing an accurate, non-invasive alternative for monitoring swallowing and aspiration events. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Deglutition Disorders/diagnosis/physiopathology,*Deglutition/physiology,*Wearable Electronic Devices,aged,Aged,Clinical assessments,Clinical Assessments,Condition,Deep learning,Deep Learning,Deglutition,Deglutition Disorders,devices,Devices,diagnosis,Diagnosis,dysphagia,Dysphagia,E-learning,electromyography,Electromyography,Electromyography/methods/instrumentation,female,Female,Head-and-neck cancer,Head-and-neck Cancer,human,Human,Humans,kirigami structure,Kirigami structure,Kirigami Structure,Learning algorithms,Learning Algorithms,Learning systems,Learning Systems,machine learning,Machine Learning,Machine-learning,male,Male,Multi-modal,Parkinson's disease,Parkinson's Disease,pathophysiology,Pathophysiology,physiology,Physiology,procedures,Procedures,silent aspiration,Silent aspiration,Silent Aspiration,swallowing,Swallowing,swallowing disorder,Swallowing Disorder,Swallowing disorders,Swallowing Disorders,wearable computer,Wearable Computer,Wearable Electronic Devices,wearable electronics,Wearable Electronics,Wearable technology,Wearable Technology,wireless communication,Wireless Communication,Wireless Technology,Wireless Technology/instrumentation}
}

@inproceedings{shiResearchIntelligentRecommendation2022,
  title = {Research on Intelligent Recommendation Method for Health Managementer},
  booktitle = {2022 China Automation Congress ({{CAC}})},
  author = {Shi, Li and Xiao, Wendong and Zhang, Sen and Fang, Yana},
  year = 2022,
  month = nov,
  pages = {368--373},
  issn = {2688-0938},
  doi = {10.1109/CAC57257.2022.10056048},
  abstract = {Aiming at the problem that the application of intelligent technology in the elderly is congenitally inadequate, this paper studies the method of forming intelligent recommendation for the elderly's health management services, and proposes an intelligent recommendation system model for health management. The model is divided into data layer and application layer. The data layer uses knowledge mapping technology to build a knowledge mapping database in the health field, which is stored through Neo4j to provide a data base for the upper application. The application layer forms health intelligent recommendations for users through querying the database. Traditional intelligent recommendation is based on the interactive information between users and items to speculate user preferences, thus forming recommendations. It is consumer oriented intelligent recommendation; The health management intelligent recommendation proposed in this paper is based on health management knowledge, speculates the health needs of users rather than preferences, and thus forms recommendations for users. It is an intelligent recommendation for the served.},
