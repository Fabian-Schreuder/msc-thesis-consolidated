@article{kolckOpportunisticScreeningLongterm2024,
  title = {Opportunistic Screening for Long-Term Muscle Wasting in Critically Ill Patients: Insights from an Acute Pancreatitis Cohort},
  author = {Kolck, J. and Hosse, C. and Leimbach, A. and Beetz, N.L. and Auer, T.A. and Collettini, F. and Fehrenbach, U. and Pille, C. and Geisel, D.},
  year = 2024,
  journal = {European Journal of Medical Research},
  volume = {29},
  number = {1},
  pages = {294},
  issn = {09492321 (ISSN); 2047783X (ISSN)},
  doi = {10.1186/s40001-024-01884-7},
  abstract = {OBJECTIVES: To assess the feasibility of long-term muscle monitoring, we implemented an AI-guided segmentation approach on clinically indicated Computed Tomography (CT) examinations conducted throughout the hospitalization period of patients admitted to the intensive care unit (ICU) with acute pancreatitis (AP). In addition, we aimed to investigate the potential of muscle monitoring for early detection of patients at nutritional risk and those experiencing adverse outcomes. This cohort served as a model for potential integration into clinical practice. MATERIALS: Retrospective cohort study including 100 patients suffering from AP that underwent a minimum of three CT scans during hospitalization, totaling 749 assessments. Sequential segmentation of psoas muscle area (PMA) was performed and was relative muscle loss per day for the entire monitoring period, as well as for the interval between each consecutive scan was calculated. Subgroup and outcome analyses were performed including ANOVA. Discriminatory power of muscle decay rates was evaluated using ROC analysis. RESULTS: Monitoring PMA decay revealed significant long-term losses of 48.20\% throughout the hospitalization period, with an average daily decline of 0.98\%. Loss rates diverged significantly between survival groups, with 1.34\% PMA decay per day among non-survivors vs. 0.74\% in survivors. Overweight patients exhibited significantly higher total PMA losses (52.53 vs. 42.91\%; p\,=\,0.02) and average PMA loss per day (of 1.13 vs. 0.80\%; p\,=\,0.039). The first and the maximum decay rate, in average available after 6.16 and 17.03~days after ICU admission, showed convincing discriminatory power for survival in ROC analysis (AUC 0.607 and 0.718). Both thresholds for maximum loss (at 3.23\% decay per day) and for the initial loss rate (at 1.98\% per day) proved to be significant predictors of mortality. CONCLUSIONS: The innovative AI-based PMA segmentation method proved robust and effortless, enabling the first comprehensive assessment of muscle wasting in a large cohort of intensive care pancreatitis patients. Findings revealed significant muscle wasting (48.20\% on average), particularly notable in overweight individuals. Higher rates of initial and maximum muscle loss, detectable early, correlated strongly with survival. Integrating this tool into routine clinical practice will enable continuous muscle status tracking and early identification of those at risk for unfavorable outcomes. This record is sourced from MEDLINE/PubMed, a database of the U.S. National Library of Medicine},
  langid = {english},
  keywords = {*Critical Illness,*Pancreatitis/diagnostic imaging/complications,*Tomography X-Ray Computed/methods,acute disease,Acute Disease,Acute pancreatitis,Acute Pancreatitis,adult,Adult,aged,Aged,Artificial intelligence,Artificial Intelligence,complication,Complication,Computed tomography,Computed Tomography,Critical care,Critical Care,critical illness,Critical Illness,diagnosis,Diagnosis,diagnostic imaging,Diagnostic Imaging,etiology,Etiology,female,Female,hospitalization,Hospitalization,Hospitalization/statistics & numerical data,human,Human,Humans,intensive care unit,Intensive Care Unit,Intensive Care Units,male,Male,middle aged,Middle Aged,muscle atrophy,Muscle Atrophy,Muscle wasting,Muscle Wasting,Muscular Atrophy,Muscular Atrophy/diagnostic imaging/etiology/diagnosis,pancreatitis,Pancreatitis,procedures,Procedures,psoas muscle,Psoas Muscle,Psoas Muscles,Psoas Muscles/diagnostic imaging,Retrospective Studies,retrospective study,Retrospective Study,Tomography X-ray Computed,Tomography X-Ray Computed,x-ray computed tomography,X-ray Computed Tomography}
}

@article{kongClinicalIssuesRegarding2015,
  title = {Clinical Issues Regarding Misclassification by {{Dixon}} Based {{PET}}/{{MR}} Attenuation Correction},
  author = {Kong, E. and Cho, I.},
  year = 2015,
  journal = {Hellenic Journal of Nuclear Medicine},
  volume = {18},
  number = {1},
  pages = {42--47},
  publisher = {{P.Ziti and Co fgrammar@med.auth.gr}},
  issn = {17905427 (ISSN)},
  abstract = {Objective: The Dixon sequence is acquired for attenuation correction (AC) of positron emission tomography (PET) data in integrated PET/magnetic resonance (MR). However it sometimes misclassifies soft tissue and fat in {$\mu$}-map. In the present study, we investigated factors related to this misclassification and their clinical impacts. Subject and methods: Forty-eight oncological patients (19 males and 29 females, mean age: 59\textpm 11 years old) underwent a single fluorine-18 fluorodeoxyglucose (18F-FDG) injection/dualimaging protocol on PET/computed tomography (CT) and subsequently PET/MR. Patients were assigned to either of two groups; group A with a misclassification in at least one bed position or group B with a correctly classified {$\mu$}-map. We compared body mass index (BMI), lean body mass, fasting duration, volume of hydration and age between group A and group B. In addition, we analyzed the impact of PET quantification using standard uptake ratio (SUR) defined as uptake in volume of interest/uptake in thigh muscle. The Dixon-AC SUR was compared with CT-AC SUR in misclassified bed positions and correctly classified bed positions. All patients were scanned in four bed positions by PET/MR. Ten patients were assigned to group A; six showed misclassification in a bed position (5 in head and 1 in abdomen), three patients in 3 bed positions (head-thorax-abdomen), and one patient in partial bed position in neck. Results: Misclassification was observed in 21\% of 48 patients. Group A and group B showed no statistically significant differences in BMI, lean body mass, fasting duration or age, however the volume of hydration in group A (245mL) was smaller than in group B (452.6mL) (P=0.027). In group A, we analyzed Dixon-AC SUR/CT-AC SUR ratios in 16 misclassified and 24 correctly classified regions, and ratios in these regions were significant different 0.80 and 0.93, respectively (P=0.046). Conclusion: Because no corrective method has been devised after a scan, we recommend that Dixon images with {$\mu$}-maps should be checked before interpreting PET/MR images and emphasize the importance of hydration, pre-examination. Misclassification errors do not change the presence of 18F-FDG uptake but can have significant impacts on PET quantification in affected bed positions. \copyright{} 2015 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {abdomen,Abdomen,adult,Adult,aged,Aged,algorithm,Algorithm,Algorithms,Article,Artifacts,Attenuation Correction,bile duct cancer,Bile Duct Cancer,Biographmmr,body mass,Body Mass,Body Mass Index,body position,Body Position,bone metastasis,Bone Metastasis,breast cancer,Breast Cancer,cancer classification,Cancer Classification,cancer patient,Cancer Patient,clinical article,Clinical Article,clinical protocol,Clinical Protocol,computer assisted emission tomography,Computer Assisted Emission Tomography,computer assisted tomography,Computer Assisted Tomography,controlled study,Controlled Study,decision support system,Decision Support System,Decision Support Systems Clinical,diagnostic error,Diagnostic Error,diagnostic use,Diagnostic Use,diet restriction,Diet Restriction,Discovery St,Dixon sequence,Dixon Sequence,drug effects,Drug Effects,esophagus cancer,Esophagus Cancer,female,Female,fluorodeoxyglucose f 18,Fluorodeoxyglucose F 18,Fluorodeoxyglucose F18,groups by age,Groups By Age,head,Head,human,Human,Humans,image processing,Image Processing,Image Processing Computer-assisted,Image Processing Computer-Assisted,image quality,Image Quality,Imaging Three-dimensional,Imaging Three-Dimensional,lean body weight,Lean Body Weight,liposarcoma,Liposarcoma,liver cell carcinoma,Liver Cell Carcinoma,liver metastasis,Liver Metastasis,lung cancer,Lung Cancer,lymph node metastasis,Lymph Node Metastasis,lymphoma,Lymphoma,Magnetic Resonance Imaging,male,Male,mediastinum lymphadenopathy,Mediastinum Lymphadenopathy,melanoma,Melanoma,middle aged,Middle Aged,multimodal imaging,Multimodal Imaging,Muscle Skeletal,Neoplasms,nuclear magnetic resonance imaging,Nuclear Magnetic Resonance Imaging,nuclear magnetic resonance imaging positron emission tomography,Nuclear Magnetic Resonance Imaging Positron Emission Tomography,Pet-ct Scanner,PET-CT scanner,Pet-mri,Pet-mri Scanner,PET-MRI scanner,positron emission tomography,Positron Emission Tomography,Positron-emission Tomography,Positron-Emission Tomography,procedures,Procedures,prostate cancer,Prostate Cancer,quantitative analysis,Quantitative Analysis,radiological parameters,Radiological Parameters,reference value,Reference Value,Reference Values,scintiscanning,Scintiscanning,skeletal muscle,Skeletal Muscle,stomach cancer,Stomach Cancer,three dimensional imaging,Three Dimensional Imaging,thyroid cancer,Thyroid Cancer,Tomography X-ray Computed,Tomography X-Ray Computed,tonsil cancer,Tonsil Cancer,Vct Scanner}
