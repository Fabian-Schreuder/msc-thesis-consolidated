@article{lianDevelopmentMulticenterCrosssetting2025,
  title = {Development and Multi-Center Cross-Setting Validation of an Explainable Prediction Model for Sarcopenic Obesity: A Machine Learning Approach Based on Readily Available Clinical Features},
  author = {Lian, R. and Tang, H. and Chen, Z. and Chen, X. and Luo, S. and Jiang, W. and Jiang, J. and Yang, M.},
  year = 2025,
  journal = {Aging Clinical and Experimental Research},
  volume = {37},
  number = {1},
  publisher = {{Springer Science and Business Media Deutschland GmbH}},
  issn = {17208319 (ISSN); 15940667 (ISSN)},
  doi = {10.1007/s40520-025-02975-z},
  abstract = {Objectives: Sarcopenic obesity (SO), characterized by the coexistence of obesity and sarcopenia, is an increasingly prevalent condition in aging populations, associated with numerous adverse health outcomes. We aimed to identify and validate an explainable prediction model of SO using easily available clinical characteristics. Setting and participants: A preliminary cohort of 1,431 participants from three community regions in Ziyang city, China, was used for model development and internal validation. For external validation, we utilized data from 832 residents of multi-center nursing homes. Measurements: The diagnosis of SO was based on the European Society for Clinical Nutrition and Metabolism (ESPEN) and the European Association for the Study of Obesity (EASO) criteria. Five machine learning models (support vector machine, logistic regression, random forest, light gradient boosting machine, and extreme gradient boosting) were used to predict SO. The performance of these models was assessed by the area under the receiver operating characteristic curve (AUC). The SHapley Additive exPlanations (SHAP) approach was used for model interpretation. Results: After feature reduction, an 8-feature model demonstrated good predictive ability. Among the five models tested, the support vector machine (SVM) model performed best in SO prediction in both internal (AUC = 0.862) and external (AUC = 0.785) validation sets. The eight key predictors identified were BMI, gender, neck circumference, waist circumference, thigh circumference, time to full tandem standing, time to five-times sit-to-stand, and age. SHAP analysis revealed BMI and gender as the most influential predictors. To facilitate the utilization of the SVM model in clinical setting, we developed a web application (https://svcpredictapp.streamlit.app/). Conclusions: We developed an explainable machine learning model to predict SO in aging community and nursing populations. This model offers a novel, accessible, and interpretable approach to SO prediction with potential to enhance early detection and intervention strategies. Further studies are warranted to validate our model in diverse populations and evaluate its impact on patient outcomes when integrated into comprehensive geriatric assessments. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Machine Learning,*Obesity/diagnosis/epidemiology/complications,*Sarcopenia/diagnosis/epidemiology/complications,adult,Adult,ADULTS,aged,Aged,Aged 80 and over,Aged 80 And Over,anthropometry,Anthropometry,Article,body mass,Body Mass,China,China/epidemiology,clinical feature,Clinical Feature,clinical trial,Clinical Trial,cohort analysis,Cohort Analysis,cross-sectional study,Cross-sectional Study,diagnosis,Diagnosis,diagnostic accuracy,Diagnostic Accuracy,Diagnostic performance,Diagnostic Performance,explainable machine learning,Explainable Machine Learning,face-to-face interview,Face-to-face Interview,feature selection,Feature Selection,female,Female,gender,Gender,human,Human,Humans,least absolute shrinkage and selection operator,Least Absolute Shrinkage And Selection Operator,logistic regression analysis,Logistic Regression Analysis,machine learning,Machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,multicenter study,Multicenter Study,neck circumference,Neck Circumference,nursing home,Nursing Home,Obese sarcopenia,Obese Sarcopenia,obesity,Obesity,pathophysiology,Pathophysiology,Prediction model,Prediction Model,predictive model,Predictive Model,predictive value,Predictive Value,PREVALENCE,prospective study,Prospective Study,random forest,Random Forest,receiver operating characteristic,Receiver Operating Characteristic,ROC Curve,sarcopenia,Sarcopenia,sarcopenic obesity,Sarcopenic Obesity,sensitivity and specificity,Sensitivity And Specificity,Shapley additive explanation,Shapley Additive Explanation,sit-to-stand test,Sit-to-stand Test,socioeconomic background,Socioeconomic Background,support vector machine,Support Vector Machine,thigh circumference,Thigh Circumference,validation study,Validation Study,very elderly,Very Elderly,waist circumference,Waist Circumference}
}

@inproceedings{liangCollaborativeElderlyCare2022,
  title = {A Collaborative Elderly Care System Using a Companion Robot and a Wearable Device},
  booktitle = {2022 {{IEEE}} 17th Conference on Industrial Electronics and Applications ({{ICIEA}})},
  author = {Liang, Fei and Hernandez, Ricardo and Sheng, Weihua},
  year = 2022,
  month = dec,
  pages = {985--990},
  issn = {2158-2297},
  doi = {10.1109/ICIEA54703.2022.10006257},
  abstract = {In this paper, we designed and implemented a collaborative elderly care system (CECAS) using a companion robot and a wearable device. First, we present the overall design of the system. Then, we describe its hardware and software design. Finally, we use three elderly care applications as examples to demonstrate the capability of the proposed system, which include: fall detection and response, conversational assistance, and dietary monitoring. In the fall detection and response application, a two-step method is proposed, which includes a motion data based preliminary detection on the wearable device and a video-based final confirmation on the companion robot. In the conversational assistance application, we implement weather, time, news and jokes skills to test the system. In the dietary monitoring application, in order to reduce the power consumption and improve the accuracy, we develop a wearable- robot-human collaboration mechanism to ensure that the camera captures the best food image at the right time. The results show that the wearable device significantly extended the sensing range of the robot and improved the robot's capability.},
  keywords = {Collaboration,Power demand,Robot vision systems,Sensors,Service robots,Software design,Wearable computers},
  file = {C:\Users\fabian\Zotero\storage\RVNEDZMR\Liang et al. - 2022 - A collaborative elderly care system using a companion robot and a wearable device.pdf}
}

