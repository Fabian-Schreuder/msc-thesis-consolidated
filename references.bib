@article{krakovskaHealthyMemoryAging2021,
  title = {Healthy Memory Aging - the Benefits of Regular Daily Activities Increase with Age},
  author = {Krakovska, O. and Christie, G.J. and Farzan, F. and Sixsmith, A. and Ester, M. and Moreno, S.},
  year = 2021,
  journal = {Aging},
  volume = {13},
  number = {24},
  pages = {25643--25652},
  publisher = {Impact Journals LLC},
  issn = {19454589 (ISSN)},
  doi = {10.18632/aging.203753},
  abstract = {As the number of older adults increases, so does the pressure on health care systems due to age-related disorders. Attempts to reduce cognitive decline have focused on individual interventions such as exercise or diet, with limited success. This study adopted a different approach by investigating the impact of combined daily activities on memory decline. We used data from the National Institute of Aging's Health and Retirement Study to explore two new questions: does combining activities affect memory decline, and if yes, does this impact change across the lifespan? We created a new machine learning model using 33 daily activities and involving 3210 participants. Our results showed that the effect of combined activities on memory decline was stronger than any individual activity's impact. Moreover, this effect increased with age, whereas the importance of historical factors such as education, and baseline memory decreased. The present findings point out the importance of selecting multiple, diverse activities for older adults as they age. These results could have a significant impact on aging health policies promoting new programs such as social prescribing \copyright{} 2022 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {ABILITIES,Activities of Daily Living,Activities Of Daily Living,aged,Aged,Aged 80 and over,Aged 80 And Over,big data,Big Data,cognition,Cognition,Cognition/*physiology,cognitive decline,Cognitive Decline,COGNITIVE DECLINE,cognitive defect,Cognitive Defect,Cognitive Dysfunction,Cognitive Dysfunction/*prevention & control,daily activities,Daily Activities,daily life activity,Daily Life Activity,DEMENTIA,family relation,Family Relation,Family Relations,Family Relations/psychology,female,Female,healthy aging,Healthy Aging,Healthy Aging/*physiology,human,Human,Humans,IMPAIRMENT,leisure,Leisure,Leisure Activities,Leisure Activities/*psychology,machine learning,Machine Learning,male,Male,PHYSICAL-ACTIVITY,physiology,Physiology,psychology,Psychology,RISK,SENIORS,very elderly,Very Elderly}
}

