@article{gerinaRecognitionCookingActivities2020,
  title = {Recognition of Cooking Activities through Air Quality Sensor Data for Supporting Food Journaling},
  author = {Gerina, F. and Massa, S.M. and Moi, F. and Reforgiato Recupero, D. and Riboni, D.},
  year = 2020,
  journal = {Human-centric Computing and Information Sciences},
  volume = {10},
  number = {1},
  publisher = {Springer},
  issn = {21921962 (ISSN)},
  doi = {10.1186/s13673-020-00235-9},
  abstract = {Unhealthy behaviors regarding nutrition are a global risk for health. Therefore, the healthiness of an individual's nutrition should be monitored in the medium and long term. A powerful tool for monitoring nutrition is a food diary; i.e., a daily list of food taken by the individual, together with portion information. Unfortunately, frail people such as the elderly have a hard time filling food diaries on a continuous basis due to forgetfulness or physical issues. Existing solutions based on mobile apps also require user's effort and are rarely used in the long term, especially by elderly people. For these reasons, in this paper we propose a novel architecture to automatically recognize the preparation of food at home in a privacy-preserving and unobtrusive way, by means of air quality data acquired from a commercial sensor. In particular, we devised statistical features to represent the trend of several air parameters, and a deep neural network for recognizing cooking activities based on those data. We collected a large corpus of annotated sensor data gathered over a period of 8 months from different individuals in different homes, and performed extensive experiments. Moreover, we developed an initial prototype of an interactive system for acquiring food information from the user when a cooking activity is detected by the neural network. To the best of our knowledge, this is the first work that adopts air quality sensor data for cooking activity recognition. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {Activity recognition,Activity Recognition,Ai,AI,Air quality,Air Quality,Air quality data,Air Quality Data,Commercial sensors,Commercial Sensors,Cooking,Deep neural networks,Deep Neural Networks,Elderly people,Elderly People,HEALTH,Health risks,Health Risks,Healthcare,Interactive system,Interactive System,Iot,IoT,Machine learning,Machine Learning,Novel architecture,Novel Architecture,Nutrition,Privacy preserving,Privacy Preserving,Statistical features,Statistical Features},
  file = {C:\Users\fabian\Zotero\storage\3WWHUD7N\Gerina et al. - 2020 - Recognition of cooking activities through air quality sensor data for supporting food journaling.pdf}
}

@inproceedings{gerinaSupportingFoodJournaling2019,
