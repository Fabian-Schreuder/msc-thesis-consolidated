@inproceedings{bhatHowAILife2025,
  title = {How {{AI}} in {{Life Insurance}} Can {{Revolutionize Public Health}}: {{A Proactive Approach}} to {{Wellness}} and {{Disease Prevention}}},
  author = {Bhat, A.K. and Das, S. and Quazi, F.},
  year = 2025,
  pages = {1061--1067},
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  doi = {10.1109/ICMLAS64557.2025.10968599},
  abstract = {The growing field of Artificial Intelligence (AI) is penetrating deeper into the soul of healthcare, especially in the field of remote patient monitoring and telemedicine, bringing a paradigm shift. AI is improving the quality of service while also giving patients more power and promoting a more collaborative relationship between providers and their patients through the utilization of technologies such as virtual assistant chatbots, wearable monitoring devices, predictive analytical models, custom treatment and monitoring plans, and wireless appointment scheduling systems. However, this gradual embedding of AI into the healthcare domain brings with it a host of challenges that have never been faced before. As the life insurance industry evolves, technology is taking on a more prominent role in shaping how insurers interact with their policyholders. As we approach the year 2030, Artificial Intelligence (AI) is expected to be an integral part of life insurance strategies, particularly in terms of personalized and proactive health initiatives that not only enhance life outcomes for policyholders but also support the long-term profitability of insurance carriers. This paper explores the ways in which AI can be used to develop proactive health programs that promote healthier living, prevent chronic diseases, and improve customer engagement in the life insurance industry. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9798331505745 (ISBN)},
  langid = {english},
  keywords = {Artificial Intelligence,Assisted living,Assisted Living,Collaborative relationships,Collaborative Relationships,Disease prevention,Disease Prevention,Diseases,Electrotherapeutics,Health Care,Health insurance,Health Insurance,Independent living systems,Independent Living Systems,Insurance,Life insurance,Life Insurance,Life insurance industry,Life Insurance Industry,Machine Learning,Machine-learning,mHealth,Mhealth,Nursing,Nutrition,Paradigm shifts,Paradigm Shifts,Personalization,Personalizations,Personalized medicine,Personalized Medicine,Power,Predictive Analysis,Pro-active approach,Pro-active Approach,Quality-of-service,Surgery}
}

@article{bhavnaniVirtualCare20a2019,
  title = {Virtual {{Care}} 2.0---a {{Vision}} for the {{Future}} of {{Data-Driven Technology-Enabled Healthcare}}},
  author = {Bhavnani, S.P. and Sitapati, A.M.},
  year = 2019,
  journal = {Current Treatment Options in Cardiovascular Medicine},
  volume = {21},
  number = {5},
  publisher = {Springer Healthcare},
  issn = {10928464 (ISSN); 15343189 (ISSN)},
  doi = {10.1007/s11936-019-0727-2},
  abstract = {A busy community cardiologist finished reading eight echocardiograms over lunch and started clinic at 1~pm. As three patients waited, ``Jane,'' a 45-year-old graphic designer was seen for ``skipped heart beat.'' She works about 50~h a week, exercises at the local gym, and enjoys eating a healthy diet. About 4~months ago Jane began experiencing her heart ``skipping beats.'' She initially attributed the symptoms to long hours in the office and caffeine. But, over the holiday, her brother purchased a smart watch and she began digitally recording her cardiac rhythm. About a month ago, the device detected possible atrial fibrillation, so she called and scheduled this visit for a cardiology consultation. Upon that visitation, she and her physician reviewed the device readings. While it appeared to be an irregular rhythm, before either considered a treatment plan, they began to ask questions ranging from the following: ``Is this an accurate diagnosis?'' ``What other data are available to better understand the risk of a cardiac arrhythmia?'' ``How is this data analyzed so that the best treatment plan can be made?'' ``And, what type of clinical decision support system is required to `virtually' monitor people like me using digital health devices to improve the efficiency and quality of care delivered in population health?''. \copyright{} 2019 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,Article,Artificial Intelligence,atrial fibrillation,Atrial Fibrillation,caffeine,Caffeine,cardiologist,Cardiologist,case report,Case Report,clinical article,Clinical Article,Clinical Decision Support,clinical decision support system,Clinical Decision Support System,data science,Data Science,Digital Health,exercise,Exercise,futurology,Futurology,health care,Health Care,health care delivery,Health Care Delivery,health care quality,Health Care Quality,healthy diet,Healthy Diet,heart arrhythmia,Heart Arrhythmia,heart beat,Heart Beat,heart rhythm,Heart Rhythm,human,Human,medical technology,Medical Technology,middle aged,Middle Aged,Patient Engagement,patient monitoring,Patient Monitoring,Population Health,treatment planning,Treatment Planning,Virtual Care,virtual reality,Virtual Reality}
}

@article{bhuiyanArtificialIntelligenceStratify2020,
  title = {Artificial Intelligence to Stratify Severity of Age-Related Macular Degeneration ({{AMD}}) and Predict Risk of Progression to Late {{AMD}}},
  author = {Bhuiyan, A. and Wong, T.Y. and Ting, D.S.W. and Govindaiah, A. and Souied, E.H. and Smith, R.T.},
  year = 2020,
  journal = {Translational Vision Science and Technology},
  volume = {9},
  number = {2},
  pages = {1--12},
  publisher = {{Association for Research in Vision and Ophthalmology Inc. subscriptions@arvo.org}},
  issn = {21642591 (ISSN)},
  doi = {10.1167/TVST.9.2.25},
  abstract = {Purpose: To build and validate artificial intelligence (AI)-based models for AMD screening and for predicting late dry and wet AMD progression within 1 and 2 years. Methods: The dataset of the Age-related Eye Disease Study (AREDS) was used to train and validate our prediction model. External validation was performed on the Nutritional AMD Treatment-2 (NAT-2) study. First Step: An ensemble of deep learning screening methods was trained and validated on 116,875 color fundus photos from 4139 participants in the AREDS study to classify them as no, early, intermediate, or advanced AMD and further stratified them along the AREDS 12 level severity scale. Second step: the resulting AMD scores were combined with sociodemographic clinical data and other automatically extracted imaging data by a logistic model tree machine learning technique to predict risk for progression to late AMD within 1 or 2 years, with training and validation performed on 923 AREDS participants who progressed within 2 years, 901 who progressed within 1 year, and 2840 who did not progress within 2 years. For those found at risk of progression to late AMD, we further predicted the type (dry or wet) of the progression of late AMD. Results: For identification of early/none vs. intermediate/late (i.e., referral level) AMD, we achieved 99.2\% accuracy. The prediction model for a 2-year incident late AMD (any) achieved 86.36\% accuracy, with 66.88\% for late dry and 67.15\% for late wet AMD. For the NAT-2 dataset, the 2-year late AMD prediction accuracy was 84\%. Conclusions: Validated color fundus photo-based models for AMD screening and risk prediction for late AMD are now ready for clinical testing and potential telemedical deployment. Translational Relevance: Noninvasive, highly accurate, and fast AI methods to screen for referral level AMD and to predict late AMD progression offer significant potential improvements in our care of this prevalent blinding disease. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,age related macular degeneration,Age Related Macular Degeneration,aged,Aged,Amd Prediction,area under the curve,Area Under The Curve,Article,artificial intelligence,Artificial Intelligence,controlled study,Controlled Study,deep learning,Deep Learning,diagnostic test accuracy study,Diagnostic Test Accuracy Study,disease classification,Disease Classification,disease exacerbation,Disease Exacerbation,disease severity assessment,Disease Severity Assessment,Dry Amd,female,Female,geographic atrophy,Geographic Atrophy,human,Human,information model,Information Model,interrater reliability,Interrater Reliability,kappa statistics,Kappa Statistics,major clinical study,Major Clinical Study,male,Male,measurement precision,Measurement Precision,receiver operating characteristic,Receiver Operating Characteristic,risk assessment,Risk Assessment,scoring system,Scoring System,sensitivity and specificity,Sensitivity And Specificity,Wet Amd,wet macular degeneration,Wet Macular Degeneration,workflow,Workflow}
}

@article{bibboMEMSIoTHAR2025,
  title = {{{MEMS}} and {{IoT}} in {{HAR}}: {{Effective Monitoring}} for the {{Health}} of {{Older People}}},
  author = {Bibb{\`o}, L. and Angiulli, G. and Lagan{\'a}, F. and Prattic{\`o}, D. and Cotroneo, F. and La Foresta, F. and Versaci, M.},
  year = 2025,
  journal = {Applied Sciences (Switzerland)},
  volume = {15},
  number = {8},
  publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},
  issn = {20763417 (ISSN)},
  doi = {10.3390/app15084306},
  abstract = {The aging population has created a significant challenge affecting the world; social and healthcare systems need to ensure elderly individuals receive the necessary care services to improve their quality of life and maintain their independence. In response to this need, developing integrated digital solutions, such as IoT based wearable devices combined with artificial intelligence applications, offers a technological platform for creating Ambient Intelligence (AI) and Assisted Living (AAL) environments. These advancements can help reduce hospital admissions and lower healthcare costs. In this context, this article presents an IoT application based on MEMS (micro electro-mechanical systems) sensors integrated into a state-of-the-art microcontroller (STM55WB) for recognizing the movements of older individuals during daily activities. human activity recognition (HAR) is a field within computational engineering that focuses on automatically classifying human actions through data captured by sensors. This study has multiple objectives: to recognize movements such as grasping, leg flexion, circular arm movements, and walking in order to assess the motor skills of older individuals. The implemented system allows these movements to be detected in real time, and transmitted to a monitoring system server, where healthcare staff can analyze the data. The analysis methods employed include machine learning algorithms to identify movement patterns, statistical analysis to assess the frequency and quality of movements, and data visualization to track changes over time. These approaches enable the accurate assessment of older people's motor skills, and facilitate the prompt identification of abnormal situations or emergencies. Additionally, a user-friendly technological solution is designed to be acceptable to the elderly, minimizing discomfort and stress associated with using technology. Finally, the goal is to ensure that the system is energy-efficient and cost-effective, promoting sustainable adoption. The results obtained are promising; the model achieved a high level of accuracy in recognizing specific movements, thus contributing to a precise assessment of the motor skills of the elderly. Notably, movement recognition was accomplished using an artificial intelligence model called Random Forest. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {Aging population,Aging Population,Ambient assisted living,Ambient Assisted Living,Assisted living,Assisted Living,Edge machine learning,Edge Machine Learning,Electrotherapeutics,Har,Healthcare,Human activity recognition,Human Activity Recognition,Imu,IMU,Independent living systems,Independent Living Systems,Internet Of Things,Machine-learning,Mems,Mems (microelectromechanical System),MEMS (microelectromechanical system),Motor skills,Motor Skills,Nutrition,Older People,Supervised learning,Supervised Learning}
}

@inproceedings{biroleBitHeartWearableDevice2025,
  title = {Bit-{{Heart}}: {{Wearable Device}} for {{Healthcare Diagnosis Employing IOT}} and {{Machine Learning}}},
  author = {Birole, P.J. and Jain, G. and Jain, S. and Kanoje, V. and Bhattacharya, S. and Kanoje, H.},
  editor = {Kumar, R. and Kumar, R. and Gupta, M. and Gupta, M.},
  year = 2025,
  pages = {478--483},
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  doi = {10.1109/InCACCT65424.2025.11011406},
  abstract = {In this rapidly changing world, timely and cost-effective medical diagnosis is of utmost importance. This article introduces BitHeart, an IoT-based wearable device that tracks health events over time by combining wearable technology with machine learning models. This study proposes two models: first Heart Health Model which is employing IoT sensors such as heart rate monitors, accelerometers, etc. and the K Nearest Neighbor (KNN) method to predict the probability of heart disease based on physical measurements, include heartbeat rate, step count, and calories burned. Another is the body fitness model driven by a classifier called Gradient Boosting Classifier (LightGBM) is used in the evaluation of the patient by examining parameters such as step count, number of thoughts, weight and sleep duration. The hybrid technology processes the data to eliminate uncertainty and increase accuracy. The web-based interface allows users to view health data in real time and gain insights. Experimental studies have shown that the heart health model has 77\% accuracy, while the physical health model can classify functional levels with high confidence. These results demonstrate BitHeart's potential to improve personalized healthcare by providing users with early disease detection and recommendations. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9798331543891 (ISBN)},
  langid = {english},
  keywords = {Cardiology,Diagnosis,Diseases,Fitness assessment,Fitness Assessment,Geriatrics,Heart disease,Heart Disease,Heart disease prediction,Heart Disease Prediction,Iot,IoT,K near neighbor,K Near Neighbor,Knn,Lightgbm,Machine Learning,Machine-learning,mHealth,Mhealth,Nearest-neighbour,Nutrition,Patient treatment,Patient Treatment,Personalized medicine,Personalized Medicine,Wearable devices,Wearable Devices,Wearable healthcare device,Wearable Healthcare Device},
