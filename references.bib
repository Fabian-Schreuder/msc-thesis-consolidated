@article{dedingColonCapsuleEndoscopy2020,
  title = {Colon Capsule Endoscopy versus {{CT}} Colonography after Incomplete Colonoscopy. {{Application}} of Artificial Intelligence Algorithms to Identify Complete Colonic Investigations},
  author = {Deding, U. and Herp, J. and Havshoei, A.-L. and {Kobaek-Larsen}, M. and Buijs, M.M. and Nadimi, E.S. and Baatrup, G.},
  year = 2020,
  journal = {United European Gastroenterology Journal},
  volume = {8},
  number = {7},
  pages = {782--789},
  publisher = {SAGE Publications Ltd info@sagepub.co.uk},
  issn = {20506414 (ISSN); 20506406 (ISSN)},
  doi = {10.1177/2050640620937593},
  abstract = {Background: Guidelines suggest computed tomography colonography (CTC) following incomplete optical colonoscopy (OC). Colon capsule endoscopies (CCE) have been suggested as an alternative, although completion rates have been unsatisfactory. Introduction of artificial intelligence (AI)-based localization algorithms of the camera capsules may enable identification of incomplete CCE investigations overlapping with incomplete OCs. Objective: The study aims to investigate relative sensitivity of CCE compared with CTC following incomplete OC, investigate the completion rate when combining results from the incomplete OC and CCE, and develop a forward-tracking algorithm ensuring a safe completeness of combined investigations. Methods: In this prospective paired study, patients with indication for CTC following incomplete OC were included for CCE and CTC. Location of CCE abortion and OC abortion were registered to identify complete combined investigations. AI-based algorithm for localization of capsules were developed reconstructing the passage of the colon. Results: In 237 individuals with CTC indication; 105 were included, of which 97 underwent both a CCE and CTC. CCE was complete in 66 (68\%). Including CCEs which reached most oral point of incomplete OC, 73 (75\%) had complete colonic investigations; 78 (80\%) had conclusive investigations. Relative sensitivity of CCE compared with CTC was 2.67 (95\% confidence interval (CI) 1.76;4.04) for polyps {$>$}5 mm and 1.91 (95\% CI 1.18;3.09) for polyps {$>$}9 mm. An AI-based algorithm was developed. Conclusion: Sensitivity of CCE following incomplete OC was superior to CTC. Introducing and improving algorithm-based localization of capsule abortion may increase identification of overall complete investigation rates following incomplete OC. ClinicalTrials.gov identifier: NCT02826993 \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,algorithm,Algorithm,Article,artificial intelligence,Artificial Intelligence,bisacodyl,Bisacodyl,camera capsule endoscopy,Camera Capsule Endoscopy,capsule endoscopy,Capsule Endoscopy,clear liquid diet,Clear Liquid Diet,clinical trial,Clinical Trial,colon,Colon,Colon Cancer,colon capsule endoscopy,Colon Capsule Endoscopy,colon polyp,Colon Polyp,Colonic Polyps,Colonography Computed Tomographic,colonoscopy,Colonoscopy,colorectal cancer,Colorectal Cancer,Colorectal Neoplasms,colorectal tumor,Colorectal Tumor,comparative study,Comparative Study,computed tomographic colonography,Computed Tomographic Colonography,Computed Tomography Colonography,Ct Colonography,descending colon,Descending Colon,diagnostic imaging,Diagnostic Imaging,domperidone,Domperidone,early cancer diagnosis,Early Cancer Diagnosis,Early Detection of Cancer,Early Detection Of Cancer,Endoscopy,female,Female,follow up,Follow Up,hepatic flexure,Hepatic Flexure,human,Human,Humans,image processing,Image Processing,Image Processing Computer-assisted,Image Processing Computer-Assisted,Intestinal Mucosa,intestine mucosa,Intestine Mucosa,iohexol,Iohexol,magnesium oxide,Magnesium Oxide,magnesium sulfate plus potassium sulfate plus sodium sulfate,Magnesium Sulfate Plus Potassium Sulfate Plus Sodium Sulfate,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,occult blood test,Occult Blood Test,optical colonoscopy,Optical Colonoscopy,pain,Pain,pathology,Pathology,priority journal,Priority Journal,procedures,Procedures,Prospective Studies,prospective study,Prospective Study,rectum polyp,Rectum Polyp,sensitivity and specificity,Sensitivity and Specificity,Sensitivity And Specificity,sigmoid,Sigmoid,splenic flexure,Splenic Flexure,stenosis,Stenosis,transverse colon,Transverse Colon}
