@article{jafarPersonalizedInsulinDosing2024,
  title = {Personalized Insulin Dosing Using Reinforcement Learning for High-Fat Meals and Aerobic Exercises in Type 1 Diabetes: A Proof-of-Concept Trial},
  author = {Jafar, A. and Kobayati, A. and Tsoukas, M.A. and Haidar, A.},
  year = 2024,
  journal = {Nature Communications},
  volume = {15},
  number = {1},
  publisher = {Nature Research},
  issn = {20411723 (ISSN)},
  doi = {10.1038/s41467-024-50764-5},
  abstract = {In type 1 diabetes, high-fat meals require more insulin to prevent hyperglycemia while meals followed by aerobic exercises require less insulin to prevent hypoglycemia, but the adjustments needed vary between individuals. We propose a decision support system with reinforcement learning to personalize insulin doses for high-fat meals and postprandial aerobic exercises. We test this system in a single-arm 16-week study in 15 adults on multiple daily injections therapy (NCT05041621). The primary objective of this study is to assess the feasibility of the novel learning algorithm. This study looks at glucose outcomes and patient reported outcomes. The postprandial incremental area under the glucose curve is improved from the baseline to the evaluation period for high-fat meals (378 \textpm{} 222 vs 38 \textpm{} 223 mmol/L/min, p = 0.03) and meals followed by exercises (-395 \textpm{} 192 vs 132 \textpm{} 181 mmol/L/min, p = 0.007). The postprandial time spent below 3.9 mmol/L is reduced after high-fat meals (5.3 \textpm{} 1.6 vs 1.8 \textpm{} 1.5\%, p = 0.003) and meals followed by exercises (5.3 \textpm{} 1.2 vs 1.4 \textpm{} 1.1\%, p = 0.003). Our study shows the feasibility of automatically personalizing insulin doses for high-fat meals and postprandial exercises. Randomized controlled trials are warranted. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,adverse event,Adverse Event,aerobic exercise,Aerobic Exercise,algorithm,Algorithm,Algorithms,antidiabetic agent,Antidiabetic Agent,Article,blood,Blood,Blood Glucose,carbohydrate intake,Carbohydrate Intake,clinical article,Clinical Article,clinical trial,Clinical Trial,conceptual framework,Conceptual Framework,decision support system,Decision Support System,diabetes,Diabetes,Diabetes Mellitus Type 1,diabetic ketoacidosis,Diabetic Ketoacidosis,Diet High-fat,Diet High-Fat,disease duration,Disease Duration,dose calculation,Dose Calculation,drug therapy,Drug Therapy,exercise,Exercise,fat,Fat,feasibility study,Feasibility Study,female,Female,Freestyle Libre,glucose,Glucose,glucose blood level,Glucose Blood Level,hemoglobin A1c,Hemoglobin A1c,hormone,Hormone,human,Human,Humans,hypoglycemia,Hypoglycemia,Hypoglycemic Agents,Ibolusv2,insulin,Insulin,insulin dependent diabetes mellitus,Insulin Dependent Diabetes Mellitus,insulin treatment,Insulin Treatment,learning,Learning,lipid diet,Lipid Diet,male,Male,meal,Meal,Meals,metabolism,Metabolism,middle aged,Middle Aged,outpatient care,Outpatient Care,patient-reported outcome,Patient-reported Outcome,personalized medicine,Personalized Medicine,physical activity,Physical Activity,physiology,Physiology,pilot study,Pilot Study,Postprandial Period,postprandial state,Postprandial State,Precision Medicine,prevention and control,Prevention And Control,procedures,Procedures,proof of concept,Proof Of Concept,Proof of Concept Study,Proof Of Concept Study,Q learning,Q Learning,reinforcement (psychology),Reinforcement (psychology),reinforcement learning (machine learning),Reinforcement Learning (machine Learning),Reinforcement Psychology,therapy,Therapy,young adult,Young Adult}
