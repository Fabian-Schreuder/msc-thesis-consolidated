  publisher = {John Libbey},
  issn = {19506945 (ISSN); 12949361 (ISSN)},
  doi = {10.1684/epd.2022.1428},
  abstract = {This is the first known case report of a profound illusionary time dilation produced by direct electrical cortical stimulation. The patient with drug-resistant epilepsy was undergoing invasive EEG evaluation for the localization of the focus prior to resection. Stimulation of the non-dominant claustrum/insula and inferior right frontal gyrus correlated with the equivalent of a pacemaker of an internal clock in the brain. The site exhibited strong outflow connectivity with a wide region of the right fronto-parietal executive network and pre-motor system. The patient described the experience as unique and fascinating, and underwent resection involving the face motor area where seizures arose from, with a substantial decrease in seizure burden {$>$}90\%. Extensive brain networks are employed in evaluation/assessment of time, which may be modulated via electrical stimulation. This is the first of such an incident. Further studies may investigate the potential benefit of neuromodulation of these brain regions in the management of conditions in which time-perception may be impaired. \copyright{} 2022 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,Article,brain,Brain,brain depth stimulation,Brain Depth Stimulation,case report,Case Report,clinical article,Clinical Article,clinical trial,Clinical Trial,cocaine,Cocaine,consciousness,Consciousness,diethylamine,Diethylamine,dilatation,Dilatation,Electrical Cortical Stimulation,electroencephalography,Electroencephalography,epileptic focus,Epileptic Focus,executive network,Executive Network,facial nerve nucleus,Facial Nerve Nucleus,facial recognition,Facial Recognition,frontal gyrus,Frontal Gyrus,functional magnetic resonance imaging,Functional Magnetic Resonance Imaging,human,Human,Human Brain,Human Brain Mapping,Human Brain Network,Humans,hypersalivation,Hypersalivation,illusion,Illusion,Illusions,language test,Language Test,magnetoencephalography,Magnetoencephalography,male,Male,meningitis,Meningitis,middle aged,Middle Aged,motor performance,Motor Performance,motor system,Motor System,nerve cell network,Nerve Cell Network,Neural Networks Computer,neurologic examination,Neurologic Examination,neuropsychological test,Neuropsychological Test,radiology,Radiology,seizure,Seizure,Seizures,stimulation,Stimulation,stimulus response,Stimulus Response,Time Dilation,time perception,Time Perception,videorecording,Videorecording}
