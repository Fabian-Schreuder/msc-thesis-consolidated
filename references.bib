@inproceedings{shuvoLongtermPredictiveAnalytics2024,
  title = {Long-Term Predictive Analytics of Continuous Glucose Sensing for Enhanced Glycemic Control},
  booktitle = {2024 {{IEEE}} Computer Society Annual Symposium on {{VLSI}} ({{ISVLSI}})},
  author = {Shuvo, Md Maruf Hossain and Titirsha, Twisha and Oliva, Giuseppe and Pullano, Salvatore A. and Islam, Syed Kamrul},
