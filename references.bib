@article{changJointEvaluationImpaired2020,
  title = {A {{Joint Evaluation}} of {{Impaired Cardiac Sympathetic Responses}} and {{Malnutrition-Inflammation Cachexia}} for {{Mortality Risks}} in {{Hemodialysis Patients}}},
  author = {Chang, J.-F. and Wu, C.-C. and Hsieh, C.-Y. and Li, Y.-Y. and Wang, T.-M. and Liau, J.-C.},
  year = 2020,
  journal = {Frontiers in Medicine},
  volume = {7},
  publisher = {Frontiers Media S.A. info@frontiersin.org},
  issn = {2296858X (ISSN)},
  doi = {10.3389/fmed.2020.00099},
  abstract = {Background: Cardiac sympathetic response (CSR) and malnutrition-inflammation syndrome (MIS) score are validated assessment tools for patients' health condition. We aim to evaluate the joint effect of CSR and MIS on all-cause and cardiovascular (CV) mortality in patients with hemodialysis (HD). Methods: Changes in normalized low frequency ({$\Delta$}nLF) during HD were utilized for quantification of CSR. Unadjusted and adjusted hazard ratios (aHRs) of mortality risks were analyzed in different groups of {$\Delta$}nLF and MIS score. Results: In multivariate analysis, higher {$\Delta$}nLF was related to all-cause, CV and sudden cardiac deaths [aHR: 0.78 (95\% confidence interval (CI): 0.72--0.85), 0.78 (95\% CI: 0.70--0.87), and 0.74 (95\% CI: 0.63--0.87), respectively]. Higher MIS score was associated with incremental risks of all-cause, CV and sudden cardiac deaths [aHR: 1.36 (95\% CI: 1.13--1.63), 1.33 (95\% CI: 1.06 -- 1.38), and 1.50 (95\% CI: 1.07--2.11), respectively]. Patients with combined lower {$\Delta$}nLF ({$\leq$}6.8 nu) and higher MIS score were at the greatest risk of all-cause and CV mortality [aHR: 5.64 (95\% CI: 1.14--18.09) and 5.86 (95\% CI: 1.64--13.65), respectively]. Conclusion: Our data indicate a joint evaluation of CSR and MIS score to identify patients at high risk of death is more comprehensive and convincing. Considering the extremely high prevalence of cardiac autonomic neuropathy and malnutrition-inflammation cachexia in HD population, a non-invasive monitoring system composed of CSR analyzer and MIS score calculator should be developed in the artificial intelligence-based prediction of clinical events. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,alanine aminotransferase,Alanine Aminotransferase,albumin,Albumin,all cause mortality,All Cause Mortality,Article,aspartate aminotransferase,Aspartate Aminotransferase,Autonomic Neuropathy,C reactive protein,C Reactive Protein,cachexia,Cachexia,calcium phosphate,Calcium Phosphate,Cardiac Sympathetic Response,cardiovascular mortality,Cardiovascular Mortality,cardiovascular risk,Cardiovascular Risk,cohort analysis,Cohort Analysis,comparative study,Comparative Study,controlled study,Controlled Study,creatinine,Creatinine,disease duration,Disease Duration,female,Female,ferritin,Ferritin,follow up,Follow Up,heart function,Heart Function,hemodialysis,Hemodialysis,hemoglobin,Hemoglobin,high density lipoprotein,High Density Lipoprotein,human,Human,hypertension,Hypertension,inflammation,Inflammation,low density lipoprotein,Low Density Lipoprotein,major clinical study,Major Clinical Study,male,Male,malnutrition,Malnutrition,Malnutrition-inflammation Score,middle aged,Middle Aged,Mortality,mortality risk,Mortality Risk,outcome assessment,Outcome Assessment,phosphate,Phosphate,potassium,Potassium,prevalence,Prevalence,prospective study,Prospective Study,Protein Energy Wasting,sudden cardiac death,Sudden Cardiac Death,triacylglycerol,Triacylglycerol,uric acid,Uric Acid}
