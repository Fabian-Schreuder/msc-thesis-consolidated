@inproceedings{samonteConditionalCashTransfer2018,
  title = {Conditional {{Cash Transfer Data Analysis}} of the {{Philippines}}: {{An}} e-{{Government Data Visualization Tool}}},
  author = {Samonte, M.J. and Gabriel Bal, T. and Recio, Z.N. and Mark San Jose, R.},
  year = 2018,
