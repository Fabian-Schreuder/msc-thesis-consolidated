  publisher = {Association for Computing Machinery},
  doi = {10.1145/3706598.3713319},
  abstract = {Artificial intelligence (AI)-based decision support systems hold promise for enhancing diagnostic accuracy and efficiency in computational pathology. However, human-AI collaboration can introduce and amplify cognitive biases, like confirmation bias caused by false confirmation when erroneous human opinions are reinforced by inaccurate AI output. This bias may increase under time pressure, a ubiquitous factor in routine pathology, as it strains practitioners' cognitive resources. We quantified confirmation bias triggered by AI-induced false confirmation and examined the role of time constraints in a web-based experiment, where trained pathology experts (n=28) estimated tumor cell percentages. Our results suggest that AI integration fuels confirmation bias, evidenced by a statistically significant positive linear-mixed-effects model coefficient linking AI recommendations mirroring flawed human judgment and alignment with system advice. Conversely, time pressure appeared to weaken this relationship. These findings highlight potential risks of AI in healthcare and aim to support the safe integration of clinical decision support systems. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9798400713958 (ISBN); 9798400713941 (ISBN)},
  langid = {english},
  keywords = {Artificial Intelligence,Assisted living,Assisted Living,Clinical decision support systems,Clinical Decision Support Systems,Cognitive bias,Cognitive Bias,Computational pathology,Computational Pathology,Confirmation bias,Confirmation Bias,Decision Support Systems,Decision supports,Decision Supports,Diagnosis,Diagnostic accuracy,Diagnostic Accuracy,Diagnostic efficiency,Diagnostic Efficiency,Diseases,eHealth,Ehealth,Healthcare,Independent living systems,Independent Living Systems,Nutrition,Pathology,Patient treatment,Patient Treatment,Support systems,Support Systems,Time Pressure,Time pressures,Time Pressures}
}

@article{rosenbergDigitallySupportedMultimodal2024,
  title = {A Digitally Supported Multimodal Lifestyle Program to Promote Brain Health among Older Adults (the {{LETHE}} Randomized Controlled Feasibility Trial): Study Design, Progress, and First Results},
  author = {Rosenberg, A. and Untersteiner, H. and Guazzarini, A.G. and B{\"o}denler, M. and Bruinsma, J. and {Buchgraber-Schnalzer}, B. and Colombo, M. and Crutzen, R. and {Diaz-Ponce}, A. and Fotiadis, D.I.},
  year = 2024,
  journal = {Alzheimer's Research and Therapy},
  volume = {16},
  number = {1},
  publisher = {BioMed Central Ltd},
  issn = {17589193 (ISSN)},
  doi = {10.1186/s13195-024-01615-4},
  abstract = {Background: The Finnish Geriatric Intervention Study to Prevent Cognitive Impairment and Disability (FINGER) multimodal lifestyle intervention yielded cognitive and other health benefits in older adults at risk of cognitive decline. The two-year multinational randomized controlled LETHE trial evaluates the feasibility of a digitally supported, adapted FINGER intervention among at-risk older adults. Technology is used to complement in-person activities, streamline the intervention delivery, personalize recommendations, and collect digital biomarkers. Methods: Trial includes older adults (60--77~years) with digital readiness/experience with smart devices and increased dementia risk but without substantial cognitive impairment. Participants are enrolled at four sites (Austria, Finland, Italy, Sweden). At baseline, participants were randomized 1:1 ratio to 1) intervention i.e., structured multimodal lifestyle program (including diet, exercise, cognitive training, vascular/metabolic risk management, social stimulation, sleep/stress management) where in-person activities led by professionals are supported with an Android mobile phone application developed by the consortium (the LETHE App); or 2) control i.e., self-guided program (regular health advice; simplified App with no personalized/interactive content). All participants wear smartwatches to gather passive data (e.g., physical activity, sleep). Primary outcomes are retention, adherence, and change in validated dementia risk scores. Secondary outcomes include changes in lifestyle, cognition, stress, sleep, health-related quality of life, and health literacy. Additional outcomes (exploratory) include e.g. participant experiences and dementia-related biomarkers (Alzheimer's disease blood markers, neuroimaging). A sub-study explores the feasibility of novel interactive technology (audio glasses, social robot). Results: Recruitment began in September 2022, and the last participant was randomized in June 2023. In total, 156 individuals were randomized (mean age 69~years, 65\% women; balanced recruitment across the four sites). Vascular and lifestyle risk factors were common (e.g., 65\% with hypertension, 69\% with hypercholesterolemia, 39\% physically inactive), indicating successful recruitment of a population with risk reduction potential. Trial will be completed by summer 2025. Retention until the first post-baseline visit at 6~months is high (n = 2 discontinued, retention 98.7\%). Conclusion: LETHE provides crucial information about the feasibility of technology and a digitally supported FINGER lifestyle program to promote brain health. Digital tools specifically designed for older adults could offer potential for large-scale, cost-effective prevention programs. Trial registration: ClinicalTrials.gov (NCT05565170). \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,Alzheimer disease,Alzheimer Disease,Article,artificial intelligence,Artificial Intelligence,Austria,biological marker,Biological Marker,brain,Brain,clinical outcome,Clinical Outcome,clinical trial,Clinical Trial,cognition,Cognition,Cognitive Decline,cognitive defect,Cognitive Defect,Cognitive Dysfunction,cognitive rehabilitation,Cognitive Rehabilitation,controlled study,Controlled Study,Dementia,diet therapy,Diet Therapy,Ehealth,exercise,Exercise,Feasibility Studies,feasibility study,Feasibility Study,female,Female,Finland,health care personnel,Health Care Personnel,health literacy,Health Literacy,health promotion,Health Promotion,human,Human,Humans,hypercholesterolemia,Hypercholesterolemia,hypertension,Hypertension,Italy,Life Style,lifestyle,Lifestyle,major clinical study,Major Clinical Study,male,Male,Mhealth,middle aged,Middle Aged,mobile application,Mobile Application,Mobile Applications,multicenter study,Multicenter Study,neuroimaging,Neuroimaging,neuroprotection,Neuroprotection,patient compliance,Patient Compliance,personal experience,Personal Experience,physical activity,Physical Activity,physiological stress,Physiological Stress,physiology,Physiology,pilot study,Pilot Study,Prevention,prevention and control,Prevention And Control,procedures,Procedures,quality of life,Quality Of Life,randomized controlled trial,Randomized Controlled Trial,risk factor,Risk Factor,risk management,Risk Management,risk reduction,Risk Reduction,scoring system,Scoring System,sleep parameters,Sleep Parameters,social interaction,Social Interaction,stress management,Stress Management,Sweden,Technology,telehealth,Telehealth},
  file = {C:\Users\fabian\Zotero\storage\G8EC8SIP\Rosenberg et al. - 2024 - A digitally supported multimodal lifestyle program to promote brain health among older adults (the L.pdf}
}

@article{ruiz-leonEfficacyMobileHealth2025,
  title = {Efficacy of a {{Mobile Health}}--{{Based Behavioral Treatment}} for {{Lifestyle Modification}} in {{Type}} 2 {{Diabetes Self-Management}}: {{Greenhabit Randomized Controlled Trial}}},
  author = {{Ruiz-Le{\'o}n}, A.M. and Casas, R. and {Castro-Barquero}, S. and {Alfaro-Gonz{\'a}lez}, S. and Radeva, P. and Sacanella, E. and {Casanovas-Garriga}, F. and {P{\'e}rez-Gesal{\'i}}, A. and Estruch Riba, R.},
  year = 2025,
  journal = {Journal of Medical Internet Research},
  volume = {27},
  publisher = {JMIR Publications Inc.},
  issn = {14388871 (ISSN)},
  doi = {10.2196/58319},
  abstract = {Background: Enhancing self-management in health care through digital tools is a promising strategy to empower patients with type 2 diabetes (T2D) to improve self-care. Objective: This study evaluates whether the Greenhabit (mobile health [mHealth]) behavioral treatment enhances T2D outcomes compared with standard care. Methods: A 12-week, parallel, single-blind randomized controlled trial was conducted with 123 participants (62/123, 50\%, female; mean age 58.25 years, SD 9.46 years) recently diagnosed with T2D. Participants were recruited face-to-face from primary care centers in Barcelona, Spain, between July 2021 and March 2022. They were randomly assigned to 1 of 2 groups: (1) an intervention group (n=61) instructed to use the Greenhabit mobile app alongside standard care, or (2) a control group (n=62) who received advice on maintaining a healthy diet and followed standard care. The Greenhabit app incorporates serious gaming technology. Participants received daily messages and challenges focused on promoting a healthy lifestyle, including nutrition, exercise, relaxation, a positive mindset, and a supportive social environment. The app encouraged participants to set weekly goals and awarded points for completing challenges. Data on nutrition, anthropometrics, and blood and urine samples were collected at baseline, 6 weeks, and 12 weeks. Questionnaires assessing quality of life, work-life balance, and social environment were administered at baseline and during the final visit. The primary outcomes were HbA1c and fasting plasma glucose (FPG). Repeated-measures analysis of variance was used to compare changes over time (baseline to 6 weeks and baseline to 12 weeks) between the 2 intervention groups. Analysis of covariance was performed to evaluate changes at 6 and 12 weeks, adjusted for baseline levels of each variable. Multiple contrasts were corrected using a Bonferroni post hoc test. Results: Both groups showed significant reductions in HbA1c after 6 and 12 weeks (mean change in the intervention group [n=50] --0.4\%, P{$<$}.001 vs --0.3\% in the control group [n=53], P=.001) and in FPG after 6 weeks (mean change in the intervention group --5.3 mg/dL, P=.01 vs control group --5.8 mg/dL, P=.01). At 12 weeks, the intervention group also showed significant reductions in systolic and diastolic blood pressures (mean change --4.5, P=.049 and --2.4 mmHg, P=.03, respectively), body weight (mean change --0.8 kg, P=.03), BMI (mean change --0.3 kg/m2, P=.03), waist circumference (mean change --1.0 cm, P=.046), and triglyceride concentration (mean change --20.0 mg/dL, P=.03). There was also a significant increase in high-density lipoprotein-cholesterol concentrations (mean change 2 mg/dL, P=.049). Finally, improvements were noted in 3 out of the 5 elements of balance: positivity, social environment, and work-life balance. Conclusions: The 12-week intervention with the Greenhabit behavioral treatment mHealth app showed beneficial effects on T2D outcomes and reduced the burden of cardiovascular risk factors. Although larger studies are warranted, these results suggest that mHealth apps can be a promising tool for improving T2D self-management. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Behavior Therapy,*Diabetes Mellitus Type 2/therapy,*Mobile Applications,*Self Care,*Self-Management,adult,Adult,aged,Aged,analysis of covariance,Analysis Of Covariance,anthropometry,Anthropometry,antihypertensive agent,Antihypertensive Agent,antilipemic agent,Antilipemic Agent,Article,artificial intelligence,Artificial Intelligence,behavior therapy,Behavior Therapy,behavioral health,Behavioral Health,body weight,Body Weight,cardiovascular,Cardiovascular,cardiovascular health,Cardiovascular Health,cardiovascular risk,Cardiovascular Risk,controlled study,Controlled Study,diabetes,Diabetes,Diabetes Mellitus Type 2,diastolic blood pressure,Diastolic Blood Pressure,Dm,DM,exercise,Exercise,female,Female,glucose,Glucose,glucose blood level,Glucose Blood Level,glycated hemoglobin,Glycated Hemoglobin,Glycated Hemoglobin/analysis,Greenhabit,health care,Health Care,healthy diet,Healthy Diet,healthy lifestyle,Healthy Lifestyle,hemoglobin A1c,Hemoglobin A1c,high density lipoprotein cholesterol,High Density Lipoprotein Cholesterol,human,Human,Humans,intervention,Intervention,leisure,Leisure,Life Style,lifestyle intervention,Lifestyle Intervention,lifestyle modification,Lifestyle Modification,major clinical study,Major Clinical Study,male,Male,medication,Medication,mHealth,Mhealth,middle aged,Middle Aged,mobile application,Mobile Application,Mobile Applications,mobile health,Mobile Health,non insulin dependent diabetes mellitus,Non Insulin Dependent Diabetes Mellitus,nutrition,Nutrition,oral antidiabetic agent,Oral Antidiabetic Agent,primary medical care,Primary Medical Care,procedures,Procedures,psychology,Psychology,quality of life,Quality Of Life,randomized controlled trial,Randomized Controlled Trial,Rct,RCT,self care,Self Care,self-care,Self-care,self-management,Self-management,Self-Management,single blind procedure,Single Blind Procedure,Single-blind Method,Single-Blind Method,social environment,Social Environment,Spain,telemedicine,Telemedicine,therapy,Therapy,treatment,Treatment,triacylglycerol,Triacylglycerol,type 2 diabetes,Type 2 Diabetes,urine sampling,Urine Sampling,waist circumference,Waist Circumference,work-life balance,Work-life Balance}
}

@article{ryuScreeningModelEstimating2020,
  title = {Screening Model for Estimating Undiagnosed Diabetes among People with a Family History of Diabetes Mellitus: {{A}} Knhanes-Based Study},
  author = {Ryu, K.S. and Kang, H.Y.J. and Lee, S.W. and Park, H.W. and You, N.Y. and Kim, J.H. and Hwangbo, Y. and Choi, K.S. and Cha, H.S.},
  year = 2020,
  journal = {International Journal of Environmental Research and Public Health},
  volume = {17},
  number = {23},
  pages = {1--16},
  publisher = {MDPI AG},
  issn = {16604601 (ISSN); 16617827 (ISSN)},
  doi = {10.3390/ijerph17238903},
  abstract = {A screening model for estimating undiagnosed diabetes mellitus (UDM) is important for early medical care. There is minimal research and a serious lack of screening models for people with a family history of diabetes (FHD), especially one which incorporates gender characteristics. Therefore, the primary objective of our study was to develop a screening model for estimating UDM among people with FHD and enable its validation. We used data from the Korean National Health and Nutrition Examination Survey (KNHANES). KNAHNES (2010--2016) was used as a developmental cohort (n = 5939) and was then evaluated in a validation cohort (n = 1047) KNHANES (2017). We developed the screening model for UDM in male (SMM), female (SMF), and male and female combined (SMP) with FHD using backward stepwise logistic regression analysis. The SMM and SMF showed an appropriate performance (area under curve (AUC) = 76.2\% and 77.9\%) compared with SMP (AUC = 72.9\%) in the validation cohort. Consequently, simple screening models were developed and validated, for the estimation of UDM among patients in the FHD group, which is expected to reduce the burden on the national health care system. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,antidiabetic agent,Antidiabetic Agent,Area Under Curve,area under the curve,Area Under The Curve,Article,blood examination,Blood Examination,body mass,Body Mass,cohort analysis,Cohort Analysis,controlled study,Controlled Study,creatinine,Creatinine,depression,Depression,diabetes,Diabetes,diabetes mellitus,Diabetes Mellitus,Diabetes Mellitus Type 2,family history,Family History,Family History Of Diabetes,female,Female,health care,Health Care,health care system,Health Care System,health survey,Health Survey,human,Human,Humans,insulin,Insulin,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,mass screening,Mass Screening,middle aged,Middle Aged,modeling,Modeling,non insulin dependent diabetes mellitus,Non Insulin Dependent Diabetes Mellitus,nutrition,Nutrition,Nutrition Surveys,risk factor,Risk Factor,Risk Factors,screening,Screening,Screening Model,Undiagnosed Diabetes Mellitus,undiagnosed disease,Undiagnosed Disease,validation study,Validation Study}
}

@incollection{s.porkodi8SmartHealth2020,
  title = {8. {{Smart}} Health Care Service Evolution with {{Internet}} of Things},
  booktitle = {Predictive {{Intelligence}} in {{Biomedical}} and {{Health Informatics}}},
  author = {{S. Porkodi} and {D. Kesavaraja}},
  year = 2020,
  pages = {145--164},
  publisher = {De Gruyter},
  abstract = {Internet of things (IoT) has gained a global interest in the past decade and is a growing technology in the current world. The main problems faced in the traditional healthcare methods are increasing demands, limited resource and long-term care. So the healthcare in the present world are focusing to adopt the IoT technology by using new sensors and healthcare devices for easy interactions and services. In this chapter, smart healthcare system with IoT evolution and secure data sharing are discussed. The smart healthcare system consists of sensors to collect data from the patients, blockchain technology is used to give security in which transaction of data takes place, then the data are analyzed using analytical tools which process and evaluate patient's health condition and later artificial intelligence is used to make correct decision according to the patient's health condition. Based on the proposed work, self-caring applications such as sleep monitor, nutrition monitor, health monitor, smart pillbox and glucose monitor can be developed. The real-time vitals of the patients can be monitored and patients in remote areas can also be monitored. The major goal is to improve patient engagement, better long-term care, improve decision- making, manage better service and to reduce the expenses of the healthcare.},
  isbn = {978-3-11-067614-3},
  keywords = {Aging,Biomedical monitoring,Government,Hospitals,Intelligent sensors,Internet of Things,Medical diagnostic imaging,Medical services,Monitoring,Sensors}
}

@article{sahooAutomaticImageRecognition2025,
  title = {Automatic {{Image Recognition Meal Reporting Among Young Adults}}: {{Randomized Controlled Trial}}},
  author = {Sahoo, P.K. and {Yueh-Hsia Chiu}, S. and Lin, Y.-S. and Chen, C.-H. and Irianti, D. and Chen, H.-Y. and Sarkar, M. and Liu, Y.-C.},
  year = 2025,
  journal = {JMIR mHealth and uHealth},
  volume = {13},
  publisher = {JMIR Publications Inc.},
  issn = {22915222 (ISSN)},
  doi = {10.2196/60070},
  abstract = {Background: Advances in artificial intelligence technology have raised new possibilities for the effective evaluation of daily dietary intake, but more empirical study is needed for the use of such technologies under realistic meal scenarios. This study developed an automated food recognition technology, which was then integrated into its previous design to improve usability for meal reporting. The newly developed app allowed for the automatic detection and recognition of multiple dishes within a single real-time food image as input. App performance was tested using young adults in authentic dining conditions. Objective: A 2-group comparative study was conducted to assess app performance using metrics including accuracy, efficiency, and user perception. The experimental group, named the automatic image-based reporting (AIR) group, was compared against a control group using the previous version, named the voice input reporting (VIR) group. Each application is primarily designed to facilitate a distinct method of food intake reporting. AIR users capture and upload images of their selected dishes, supplemented with voice commands where appropriate. VIR users supplement the uploaded image with verbal inputs for food names and attributes. Methods: The 2 mobile apps were subjected to a head-to-head parallel randomized evaluation. A cohort of 42 young adults aged 20-25 years (9 male and 33 female participants) was recruited from a university in Taiwan and randomly assigned to 2 groups, that is, AIR (n=22) and VIR (n=20). Both groups were assessed using the same menu of 17 dishes. Each meal was designed to represent a typical lunch or dinner setting, with 1 staple, 1 main course, and 3 side dishes. All participants used the app on the same type of smartphone, with the interfaces of both using uniform user interactions, icons, and layouts. Analysis of the gathered data focused on assessing reporting accuracy, time efficiency, and user perception. Results: For the AIR group, 86\% (189/220) of dishes were correctly identified, whereas 68\% (136/200) of dishes were accurately reported. The AIR group exhibited a significantly higher degree of identification accuracy compared to the VIR group (P{$<$}.001). The AIR group also required significantly less time to complete food reporting (P{$<$}.001). System usability scale scores showed both apps were perceived as having high usability and learnability (P=.20). Conclusions: The AIR group outperformed the VIR group concerning accuracy and time efficiency for overall dish reporting within the meal testing scenario. While further technological enhancement may be required, artificial intelligence vision technology integration into existing mobile apps holds promise. Our results provide evidence-based contributions to the integration of automatic image recognition technology into existing apps in terms of user interaction efficacy and overall ease of use. Further empirical work is required, including full-scale randomized controlled trials and assessments of user perception under various conditions. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {accuracy,Accuracy,adult,Adult,artificial intelligence,Artificial Intelligence,automatic food image recognition,Automatic Food Image Recognition,controlled study,Controlled Study,efficacy,Efficacy,female,Female,human,Human,Humans,image recognition,Image Recognition,male,Male,meal,Meal,Meals,mHealth,Mhealth,mobile application,Mobile Application,Mobile Applications,nutrition,Nutrition,psychology,Psychology,randomized controlled trial,Randomized Controlled Trial,recognition,Recognition,speech recognition,Speech Recognition,Taiwan,usability evaluation,Usability Evaluation,user interaction,User Interaction,user perception,User Perception,vision technology,Vision Technology,young adult,Young Adult}
}

@article{sakalPredictingPoorPerformance2024,
  title = {Predicting Poor Performance on Cognitive Tests among Older Adults Using Wearable Device Data and Machine Learning: A Feasibility Study},
  author = {Sakal, C. and Li, T. and Li, J. and Li, X.},
  year = 2024,
  journal = {npj Aging},
  volume = {10},
  number = {1},
  publisher = {Nature Research},
  issn = {27316068 (ISSN)},
  doi = {10.1038/s41514-024-00177-x},
  abstract = {Timely implementation of interventions to slow cognitive decline among older adults requires accurate monitoring to detect changes in cognitive function. Factors known to be associated with cognition that can be gathered from accelerometers, user interfaces, and other sensors within wearable devices could be used to train machine learning models and develop wearable-based cognitive monitoring systems. Using data from over 2400 older adults in the National Health and Nutrition Examination Survey (NHANES) we developed prediction models to differentiate older adults with normal cognition from those with poor cognition based on outcomes from three cognitive tests measuring different domains of cognitive function. During repeated cross-validation CatBoost, XGBoost, and Random Forest models performed best when predicting poor cognition based on tests measuring processing speed, working memory, and attention (median AUCs {$\geq$}0.82) compared to immediate and delayed recall (median AUCs {$\geq$}0.72) and categorical verbal fluency (median AUC {$\geq$} 0.68). Activity and sleep parameters were also more strongly associated with poor cognition based on tests assessing processing speed, working memory, and attention compared to other cognitive subdomains. Our work provides proof of concept that data collatable through wearable devices such as age, education, sleep parameters, activity summaries, and light exposure metrics could be used to differentiate between older adults with normal versus poor cognition. We further identified metrics that could be targets in future causal studies seeking to better understand how sleep and activity parameters influence cognitive function among older adults. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {DEMENTIA,DEPRESSION,RISK,SEDENTARY}
}

@article{salvioniMECKIScoreInitiative2020,
  title = {The {{MECKI}} Score Initiative: {{Development}} and State of the Art},
  author = {Salvioni, E. and Bonomi, A. and Re, F. and Massimo, M. and Mattavelli, I. and Vitale, G. and Sarullo, F.M. and Palermo, P. and Veglia, F. and Agostoni, P.},
  year = 2020,
  journal = {European Journal of Preventive Cardiology},
  volume = {27},
  number = {2\_suppl},
  pages = {5--11},
  publisher = {SAGE Publications Inc.},
  issn = {20474873 (ISSN); 20474881 (ISSN)},
  doi = {10.1177/2047487320959010},
  abstract = {The high morbidity and poor survival rates associated with chronic heart failure still represent a big challenge, despite improvements in treatments and the development of new therapeutic opportunities. The prediction of outcome in heart failure is gradually moving towards a multiparametric approach in order to obtain more accurate models and to tailor the prognostic evaluation to the individual characteristics of a single subject. The Metabolic Exercise test data combined with Cardiac and Kidney Indexes (MECKI) score was developed 10 years ago from 2715 patients and subsequently validated in a different population. The score allows an accurate evaluation of the risk of heart failure patients using only six variables that include the evaluation of the exercise capacity (peak oxygen uptake and ventilation/CO{$<$}inf{$>$}2{$<$}/inf{$>$} production slope), blood samples (haemoglobin, Na+, Modification of Diet in Renal Disease) and echocardiography (left ventricular ejection fraction). Over the following years, the MECKI score was tested taking into account therapies and specific markers of heart failure, and it proved to be a simple, useful tool for risk stratification and for therapeutic strategies in heart failure patients. The close connection between the centres involved and the continuous updating of the data allow the participating sites to propose substudies on specific subpopulations based on a common dataset and to put together and develop new ideas and perspectives. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {acute heart failure,Acute Heart Failure,adult,Adult,aged,Aged,Article,atrial fibrillation,Atrial Fibrillation,beta adrenergic receptor blocking agent,Beta Adrenergic Receptor Blocking Agent,biological marker,Biological Marker,Biomarkers,blood,Blood,body mass,Body Mass,breathing rate,Breathing Rate,cardiac resynchronization therapy,Cardiac Resynchronization Therapy,Cardiopulmonary Exercise Test,cardiorespiratory fitness,Cardiorespiratory Fitness,cardiovascular mortality,Cardiovascular Mortality,decision support system,Decision Support System,Decision Support Techniques,echocardiography,Echocardiography,exercise,Exercise,exercise test,Exercise Test,exercise tolerance,Exercise Tolerance,female,Female,follow up,Follow Up,Heart Disease Risk Factors,heart failure,Heart Failure,heart left ventricle ejection fraction,Heart Left Ventricle Ejection Fraction,heart left ventricle endsystolic volume,Heart Left Ventricle Endsystolic Volume,heart muscle revascularization,Heart Muscle Revascularization,heart rate,Heart Rate,hemoglobin,Hemoglobin,human,Human,Humans,left ventricular systolic dysfunction,Left Ventricular Systolic Dysfunction,lung gas exchange,Lung Gas Exchange,machine learning,Machine Learning,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,mitral valve disease,Mitral Valve Disease,mitral valve stenosis,Mitral Valve Stenosis,morbidity,Morbidity,mortality,Mortality,New York Heart Association class,New York Heart Association Class,oxygen consumption,Oxygen Consumption,pathophysiology,Pathophysiology,physical activity,Physical Activity,predictive value,Predictive Value,Predictive Value of Tests,Predictive Value Of Tests,priority journal,Priority Journal,prognosis,Prognosis,Prognostic Score,reproducibility,Reproducibility,Reproducibility of Results,Reproducibility Of Results,risk assessment,Risk Assessment,risk factor,Risk Factor,sudden cardiac death,Sudden Cardiac Death,systolic blood pressure,Systolic Blood Pressure,tidal volume,Tidal Volume}
}

@inproceedings{samagaioChatbotRecipeRecommendation2021,
  title = {A {{Chatbot}} for {{Recipe Recommendation}} and {{Preference Modeling}}},
  booktitle = {Lecture {{Notes}} in {{Computer Science}}},
  author = {Samagaio, {\'A}. and Lopes Cardoso, H. and Ribeiro, D.},
  editor = {Marreiros, G. and Melo, F.S. and Lau, N. and Lopes Cardoso, H. and Reis, L.P.},
  year = 2021,
  volume = {12981 LNAI},
  pages = {389--402},
  publisher = {{Springer Science and Business Media Deutschland GmbH}},
  doi = {10.1007/978-3-030-86230-5_31},
  abstract = {This paper describes the main steps and challenges in building a chatbot for a nutritional recommendation system addressed to the elderly population. We identified 4 main components: Natural Language Understanding (NLU), Dialogue Management, Preference Modeling and Ingredient Matching and Extraction. To address the specific challenges of a chatbot for this domain we have tested transformer-based models both in the development of the NLU component and the Dialogue Management component. Moreover, we explored word embeddings and nutritional knowledge bases combined with sentiment analysis for user preferences modeling. The sentiment analysis algorithms used to model food preferences showed to correctly match the real feeling of the users. Each one of these components were evaluated individually using appropriate metrics. Moreover, the developed chatbot was successfully tested by users and its opinions were recorded by means of usability and user experience questionnaires. The results of usability tests show that the components were well integrated. The scores obtained were higher than the benchmark values for both the System Usability and the User Experience Questionnaires. \copyright{} 2021 Elsevier B.V., All rights reserved.},
  isbn = {16113349 (ISSN); 03029743 (ISSN); 9789819698936 (ISBN); 9789819698042 (ISBN); 9789819698110 (ISBN); 9789819698905 (ISBN); 9789819512324 (ISBN); 9783032026019 (ISBN); 9783032008909 (ISBN); 9783031915802 (ISBN); 9789819698141 (ISBN); 9783031984136 (ISBN)},
  langid = {english},
  keywords = {Chatbot,Chatbots,Dialogue management,Dialogue Management,Elderly populations,Elderly Populations,In-buildings,Knowledge Base,Knowledge based systems,Knowledge Based Systems,Management components,Management Components,Matchings,Modeling languages,Modeling Languages,Natural Language Processing,Natural language understanding,Natural Language Understanding,Preference models,Preference Models,Sentiment analysis,Sentiment Analysis,Surveys,Users' experiences,Users' Experiences},
  file = {C:\Users\fabian\Zotero\storage\FRFKHGAV\Samagaio et al. - 2021 - A Chatbot for Recipe Recommendation and Preference Modeling.pdf}
}

@article{samitinjayUnderstandingClinicalComplexity2024,
  title = {Understanding Clinical Complexity in Organ and Organizational Systems: {{Challenges}} Local and Global},
  author = {Samitinjay, A. and Vaishnavi, K. and Gongireddy, R. and Kulakarni, S.C. and Panuganti, R. and Vishwanatham, C. and Manikanta, A.K. and Biswas, R.},
  year = 2024,
  journal = {Journal of Evaluation in Clinical Practice},
  volume = {30},
  number = {2},
  pages = {316--329},
  publisher = {{John Wiley and Sons Inc}},
  issn = {13652753 (ISSN); 13561294 (ISSN)},
  doi = {10.1111/jep.13886},
  abstract = {Introduction: Complexity in healthcare systems has been arbitrarily defined as tasks or systems ranging from complicated to intractable, with a general view of these not being `simple'. Complexity in healthcare systems in first-world countries has been well elucidated, however, data from third-world countries is still scant. Materials and~Methods: We present four cases each from three different organ systems---chronic kidney disease, alcohol use disorder, and heart failure---in the backdrop of our healthcare organization. We present our analysis of the complexities faced clinically and, in our local healthcare system which led to these events. Results: Analysis of these cases showed that patients with chronic kidney disease had vertebral--spinal pathologies due to poor infection control measures during haemodialysis. All these patients were young with a long history of secondary hypertension. In patients with alcohol use disorder, a common theme of how government regulations and peer pressure promote alcohol use is analysed. In the four patients with unexplained heart failure, vascular health is viewed as a fractal dimension and the various factors affecting vascular health are elaborated. Conclusion: Complexities exist clinically in making a diagnosis, and organizationally, in the variables and nodes dictating patient outcomes. Clinical complexities cannot be simplified but have to be navigated in an optimized way to improve clinical outcomes. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {abdominal pain,Abdominal Pain,access to treatment,Access To Treatment,acute pancreatitis,Acute Pancreatitis,adult,Adult,alcohol abuse,Alcohol Abuse,Alcohol Use Disorder,alcoholism,Alcoholism,analgesic agent,Analgesic Agent,anasarca,Anasarca,anemia,Anemia,anhedonia,Anhedonia,anorexia,Anorexia,antihypertensive agent,Antihypertensive Agent,appetite disorder,Appetite Disorder,arteriovenous fistula,Arteriovenous Fistula,Article,ascites,Ascites,awareness,Awareness,axial spondyloarthritis,Axial Spondyloarthritis,bleeding,Bleeding,blood transfusion,Blood Transfusion,case study,Case Study,catheter infection,Catheter Infection,Chronic Kidney Diseaseand Heart Failure,chronic kidney failure,Chronic Kidney Failure,chronic pancreatitis,Chronic Pancreatitis,clinical article,Clinical Article,Clinical Complexity,clinical feature,Clinical Feature,clinical outcome,Clinical Outcome,Delivery of Health Care,Delivery Of Health Care,diabetes mellitus,Diabetes Mellitus,diabetic complication,Diabetic Complication,dietary intake,Dietary Intake,disease severity,Disease Severity,diskitis,Diskitis,dyspnea,Dyspnea,empathy,Empathy,erythropoietin,Erythropoietin,faintness,Faintness,family support,Family Support,female,Female,fever,Fever,foot edema,Foot Edema,glucose,Glucose,glucose blood level,Glucose Blood Level,glycemic control,Glycemic Control,health care complexity,Health Care Complexity,health care delivery,Health Care Delivery,health care system,Health Care System,health education,Health Education,health promotion,Health Promotion,Healthcare Systems,heart failure,Heart Failure,heart failure with preserved ejection fraction,Heart Failure With Preserved Ejection Fraction,heart palpitation,Heart Palpitation,hemodialysis,Hemodialysis,hemorrhagic ascites,Hemorrhagic Ascites,hepatic encephalopathy,Hepatic Encephalopathy,human,Human,Humans,hypertension,Hypertension,infection control,Infection Control,job stress,Job Stress,kidney transplantation,Kidney Transplantation,lifestyle modification,Lifestyle Modification,liver cirrhosis,Liver Cirrhosis,low back pain,Low Back Pain,malaise,Malaise,male,Male,medical history,Medical History,middle aged,Middle Aged,neck pain,Neck Pain,Neural Network,New York Heart Association class,New York Heart Association Class,nutritional counseling,Nutritional Counseling,peer pressure,Peer Pressure,primary medical care,Primary Medical Care,public policy,Public Policy,pyelonephritis,Pyelonephritis,qualitative research,Qualitative Research,Renal Dialysis,Renal Insufficiency Chronic,renal osteodystrophy,Renal Osteodystrophy,secondary health care,Secondary Health Care,self care,Self Care,sleep disorder,Sleep Disorder,social status,Social Status,spinal cord infection,Spinal Cord Infection,Spondylodiscitis,stiff neck,Stiff Neck,suicide attempt,Suicide Attempt,tertiary health care,Tertiary Health Care,thematic analysis,Thematic Analysis,therapeutic misconception,Therapeutic Misconception,tobacco dependence,Tobacco Dependence,urine volume,Urine Volume}
