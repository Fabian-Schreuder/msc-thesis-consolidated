  title = {Feasibility of Obtaining Measures of Lifestyle from a Smartphone App: {{The MyHeart Counts}} Cardiovascular Health Study},
  author = {McConnell, M.V. and Shcherbina, A. and Pavlovic, A. and Homburger, J.R. and Goldfeder, R.L. and Waggot, D. and Cho, M.K. and Rosenberger, M.E. and Haskell, W.L. and Myers, J.},
  year = 2017,
