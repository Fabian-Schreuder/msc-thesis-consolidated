  author = {Wang, Ying and Chen, Yuhang},
  year = 2024,
  month = dec,
  pages = {89--92},
  issn = {2473-3547},
  doi = {10.1109/ISCID63852.2024.00029},
  abstract = {With the aging population in China, dietary health management is becoming a significant concern for elderly individuals. This study assessed two approaches: the effectiveness of nutritional labels and education methods, and the potential use of ChatGPT for dietary management. Results showed that MTL labels were the most preferred, with classroom education proving the most effective in enhancing label comprehension. ChatGPT demonstrated strong food recognition abilities in structured environments but struggled with more complex and unstructured food scenarios. These findings highlight the need for improved educational interventions and AI tools to support healthier eating habits among the elderly.},
