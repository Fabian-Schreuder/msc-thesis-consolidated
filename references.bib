  booktitle = {{{ACM International Conference Proceeding Series}}},
  author = {Araujo, C.S. and Azoube, L.M.A. and Filho, A.K.D.B. and Junior, C.M.S. and Sousa, N.P.S. and Pereira, C.L. and Rosa, C.R.A.A. and Santana, E.E.C.},
  year = 2021,
  pages = {63--69},
  publisher = {Association for Computing Machinery},
  doi = {10.1145/3487027.3487037},
  abstract = {An intelligent system for predicting the body fat percentage (\%BF) in adolescents was developed based on socio-demographic and clinical variables that were easily measurable through a database of 770 adolescents of both masculine and feminine genders, aged between 10 and 19 years, from the public educational system in S\~ao Lu\'is Maranh\~ao - Brazil. Predictive performance was assessed by the following metrics: precision, sensitivity, specificity, and area under the ROC curve (AUROC). The performance of the method was compared to the usual anthropometric parameters: body mass index and waist-to-height ratio. The predictive performance of the proposed method showed significantly better results than the anthropometric indicators BMI and WHtR, according to AUROC: 0.83, 0.62, and 0.56, respectively. With regard to the metrics of accuracy, sensitivity, and specificity, the intelligent system showed, respectively: 86\%, 73\%, and 93\%. Moreover, the proposed method showed a high correlation r = 0.87 (0.83-0.91) with the\% GC values obtained by bioimpedance. Thus, the proposed model based on the machine learning technique performed better to predict excess body fat in adolescents than the anthropometric indicators evaluated, presenting itself as a low-cost and easy application for tracking obesity in adolescents. \copyright{} 2021 Elsevier B.V., All rights reserved.},
  isbn = {9781450385855 (ISBN); 9781450314398 (ISBN); 9781450396387 (ISBN); 9781450390019 (ISBN); 9781450390217 (ISBN); 9781450348270 (ISBN); 9781450381963 (ISBN); 9781450322485 (ISBN); 9781450348201 (ISBN); 9781450364454 (ISBN)},
  langid = {english},
  keywords = {Adolescence,and Specificity,And specificity,And Specificity,Anthropometrics,Anthropometry,Area under the ROC curve,Area Under The Roc Curve,Body fats,Body Fats,Forecasting,Intelligent systems,Intelligent Systems,Machine learning,Machine Learning,Masculine and feminines,Masculine And Feminines,Neural-networks,Nutrition,Obesity,Predictive performance,Predictive Performance,Sensitivity,Sociodemographics}
}

