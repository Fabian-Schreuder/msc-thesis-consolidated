  author = {Nourse, R. and Dingler, T. and Kelly, J. and Kwasnicka, D. and Maddison, R.},
  year = 2023,
  journal = {Journal of Medical Internet Research},
  volume = {25},
  number = {1},
  publisher = {JMIR Publications Inc.},
  issn = {14388871 (ISSN)},
  doi = {10.2196/44265},
  abstract = {The effective management of chronic conditions requires an approach that promotes a shift in care from the clinic to the home, improves the efficiency of health care systems, and benefits all users irrespective of their needs and preferences. Digital health can provide a solution to this challenge, and in this paper, we provide our vision for a smart health ecosystem. A smart health ecosystem leverages the interoperability of digital health technologies and advancements in big data and artificial intelligence for data collection and analysis and the provision of support. We envisage that this approach will allow a comprehensive picture of health, personalization, and tailoring of behavioral and clinical support; drive theoretical advancements; and empower people to manage their own health with support from health care professionals. We illustrate the concept with 2 use cases and discuss topics for further consideration and research, concluding with a message to encourage people with chronic conditions, their caregivers, health care professionals, policy and decision makers, and technology experts to join their efforts and work toward adopting a smart health ecosystem. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,Ambulatory Care Facilities,anamnesis,Anamnesis,artificial intelligence,Artificial Intelligence,Behavior Change,big data,Big Data,body mass,Body Mass,body weight loss,Body Weight Loss,caregiver support,Caregiver Support,case report,Case Report,Chronic Condition,chronic disease,Chronic Disease,Chronic Illness,clinical article,Clinical Article,clinical assessment,Clinical Assessment,clinical decision making,Clinical Decision Making,clinical effectiveness,Clinical Effectiveness,Cost,daily life activity,Daily Life Activity,data collection method,Data Collection Method,Data Storage,diet composition,Diet Composition,Digital Health,digital technology,Digital Technology,diuretic agent,Diuretic Agent,dyspnea,Dyspnea,Economic,ecosystem,Ecosystem,fasting blood glucose level,Fasting Blood Glucose Level,feedback system,Feedback System,fluid retention,Fluid Retention,food preference,Food Preference,Health,health care access,Health Care Access,health care personnel,Health Care Personnel,health care policy,Health Care Policy,health care system,Health Care System,heart failure,Heart Failure,heart rate,Heart Rate,hospital admission,Hospital Admission,hospital cost,Hospital Cost,hospital discharge,Hospital Discharge,hospital readmission,Hospital Readmission,human,Human,Humans,Implementation,insulin,Insulin,length of stay,Length Of Stay,lifestyle modification,Lifestyle Modification,medical information,Medical Information,motivation,Motivation,non insulin dependent diabetes mellitus,Non Insulin Dependent Diabetes Mellitus,outpatient department,Outpatient Department,patient monitoring,Patient Monitoring,personality assessment,Personality Assessment,physical activity,Physical Activity,physiological stress,Physiological Stress,quality of life,Quality Of Life,questionnaire,Questionnaire,Security,self monitoring,Self Monitoring,Short Survey,sitting,Sitting,sleep time,Sleep Time,Smart Health,smart health ecosystem,Smart Health Ecosystem,Smart Home,Smart Technology,Technology,treatment planning,Treatment Planning,waist circumference,Waist Circumference,Wearable}
