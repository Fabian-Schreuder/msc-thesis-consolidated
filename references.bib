@article{priceDetectingMajorDepressive2024,
  title = {Detecting Major Depressive Disorder Presence Using Passively-Collected Wearable Movement Data in a Nationally-Representative Sample},
  author = {Price, G.D. and Heinz, M.V. and Collins, A.C. and Jacobson, N.C.},
  year = 2024,
  journal = {Psychiatry Research},
  volume = {332},
  publisher = {Elsevier Ireland Ltd},
  issn = {18727123 (ISSN); 01651781 (ISSN)},
  doi = {10.1016/j.psychres.2023.115693},
  abstract = {Major Depressive Disorder (MDD) is a heterogeneous disorder, resulting in challenges with early detection. However, changes in sleep and movement patterns may help improve detection. Thus, this study aimed to explore the utility of wrist-worn actigraphy data in combination with machine learning (ML) and deep learning techniques to detect MDD using a commonly used screening method: Patient Health Questionnaire-9 (PHQ-9). Participants (N = 8,378; MDD Screening = 766 participants) completed the and wore Actigraph GT3X+ for one week as part of the National Health and Nutrition Examination Survey (NHANES). Leveraging minute-level, actigraphy data, we evaluated the efficacy of two commonly used ML approaches and identified actigraphy-derived biomarkers indicative of MDD. We employed two ML modeling strategies: (1) a traditional ML approach with theory-driven feature derivation, and (2) a deep learning Convolutional Neural Network (CNN) approach, coupled with gramian angular field transformation. Findings revealed movement-related features to be the most influential in the traditional ML approach and nighttime movement to be the most influential in the CNN approach for detecting MDD. Using a large, nationally-representative sample, this study highlights the potential of using passively-collected, actigraphy data for understanding MDD to better improve diagnosing and treating MDD. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {Actigraphy,actimetry,Actimetry,adult,Adult,Article,cohort analysis,Cohort Analysis,controlled study,Controlled Study,convolutional neural network,Convolutional Neural Network,Depression Presence,Depressive Disorder Major,diagnostic accuracy,Diagnostic Accuracy,diagnostic test accuracy study,Diagnostic Test Accuracy Study,female,Female,human,Human,Humans,machine learning,Machine Learning,major clinical study,Major Clinical Study,major depression,Major Depression,Major Depressive Disorder,male,Male,middle aged,Middle Aged,movement (physiology),Movement (physiology),Movement Behavior,nutrition,Nutrition,Nutrition Surveys,Patient Health Questionnaire 9,procedures,Procedures,Sedentary Behavior,sleep,Sleep,Sleep Behavior,Wearable Electronic Devices}
}

@article{pyrkovExtractingBiologicalAge2018,
  title = {Extracting Biological Age from Biomedical Data via Deep Learning: {{Too}} Much of a Good Thing?},
  author = {Pyrkov, T.V. and Slipensky, K. and Barg, M. and Kondrashin, A. and Zhurov, B. and Zenin, A. and Pyatnitskiy, M. and Men'shikov, L. and Markov, S. and Fedichev, P.O.},
  year = 2018,
  journal = {Scientific Reports},
  volume = {8},
  number = {1},
  publisher = {Nature Publishing Group Houndmills Basingstoke, Hampshire RG21 6XS},
  issn = {20452322 (ISSN)},
  doi = {10.1038/s41598-018-23534-9},
  abstract = {Age-related physiological changes in humans are linearly associated with age. Naturally, linear combinations of physiological measures trained to estimate chronological age have recently emerged as a practical way to quantify aging in the form of biological age. In this work, we used one-week long physical activity records from a 2003-2006 National Health and Nutrition Examination Survey (NHANES) to compare three increasingly accurate biological age models: the unsupervised Principal Components Analysis (PCA) score, a multivariate linear regression, and a state-of-the-art deep convolutional neural network (CNN). We found that the supervised approaches produce better chronological age estimations at the expense of a loss of the association between the aging acceleration and all-cause mortality. Consequently, we turned to the NHANES death register directly and introduced a novel way to train parametric proportional hazards models suitable for out-of-the-box implementation with any modern machine learning software. As a demonstration, we produced a separate deep CNN for mortality risks prediction that outperformed any of the biological age or a simple linear proportional hazards model. Altogether, our findings demonstrate the emerging potential of combined wearable sensors and deep learning technologies for applications involving continuous health risk monitoring and real-time feedback to patients and care providers. \copyright{} 2018 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Software,adolescent,Adolescent,adult,Adult,age,Age,Age Factors,aged,Aged,Aged 80 and over,Aged 80 And Over,aging,Aging,Aging/genetics/*physiology,algorithm,Algorithm,Algorithms,artificial neural network,Artificial Neural Network,Deep Learning,exercise,Exercise,Exercise/*physiology,female,Female,follow up,Follow Up,Follow-up Studies,Follow-Up Studies,genetics,Genetics,human,Human,Humans,machine learning,Machine Learning,male,Male,middle aged,Middle Aged,Neural Networks (computer),Neural Networks (Computer),Neural Networks Computer,nutrition,Nutrition,Nutrition Surveys,Nutrition Surveys/*statistics & numerical data,physiology,Physiology,principal component analysis,Principal Component Analysis,software,Software,very elderly,Very Elderly,young adult,Young Adult}
}

