@article{susnjakClinicalPredictionTransparency2025,
  title = {Towards Clinical Prediction with Transparency: {{An}} Explainable {{AI}} Approach to Survival Modelling in Residential Aged Care},
  author = {Su{\v s}njak, T. and Griffin, E.},
  year = 2025,
  journal = {Computer Methods and Programs in Biomedicine},
  volume = {263},
  publisher = {Elsevier Ireland Ltd},
  issn = {01692607 (ISSN); 18727565 (ISSN)},
  doi = {10.1016/j.cmpb.2025.108653},
  abstract = {Background and Objective: Scalable, flexible and highly interpretable tools for predicting mortality in residential aged care facilities for the purpose of informing and optimizing palliative care decisions, do not exist. This study is the first and most comprehensive work applying machine learning to address this need while seeking to offer a transformative approach to integrating AI into palliative care decision-making. The objective is to predict survival in elderly individuals six months post-admission to residential aged care facilities with patient-level interpretability for transparency and support for clinical decision-making for palliative care options. Methods: Data from 11,944 residents across 40 facilities, with a novel combination of 18 features was used to develop predictive models, comparing standard approaches like Cox Proportional Hazards, Ridge and Lasso Regression with machine learning algorithms, Gradient Boosting (GB) and Random Survival Forest. Model calibration was performed together with ROC and a suite of evaluation metrics to analyze results. Explainable AI (XAI) tools were used to demonstrate both the cohort-level and patient-level model interpretability to enable transparency in the clinical usage of the models. TRIPOD reporting guidelines were followed, with model parameters and code provided publicly. Results: GB was the top performer with a Dynamic AUROC of 0.746 and a Concordance Index of 0.716 for six-month survival prediction. Explainable AI tools provided insights into key features such as comorbidities, cognitive impairment, and nutritional status, revealing their impact on survival outcomes and interactions that inform clinical decision-making. The calibrated model showed near-optimal performance with adjustable clinically relevant thresholds. The integration of XAI tools proved effective in enhancing the transparency and trustworthiness of predictions, offering actionable insights that support informed and ethically responsible end-of-life (EoL) care decisions in aged care settings. Conclusion: This study successfully applied machine learning to create viable survival models for aged care residents, demonstrating their usability for clinical settings via a suite of interpretable tools. The findings support the introduction into clinical trials of machine learning with explainable AI tools in geriatric medicine for mortality prediction to enhance the quality of EoL care and informed discussions regarding palliative care. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Artificial Intelligence,*Homes for the Aged,aged,Aged,Aged 80 and over,Aged 80 And Over,Aged care,Aged Care,algorithm,Algorithm,Algorithms,anticoagulant agent,Anticoagulant Agent,antithrombocytic agent,Antithrombocytic Agent,Article,artificial intelligence,Artificial Intelligence,clinical decision making,Clinical Decision Making,clinical decision support system,Clinical Decision Support System,Clinical decision support systems,Clinical Decision Support Systems,Clinical Decision-making,Clinical Decision-Making,cognitive defect,Cognitive Defect,comorbidity,Comorbidity,controlled study,Controlled Study,DEATH,dementia,Dementia,diabetes mellitus,Diabetes Mellitus,DIAGNOSIS,DISCUSSIONS,END,End of lives,End Of Lives,Event analysis,Event Analysis,Explainable Ai (xai) In Geriatric Palliative Care,Explainable AI (XAI) in geriatric palliative care,explainable artificial intelligence,Explainable Artificial Intelligence,Explainable clinical decision support system for end-of-life care,Explainable Clinical Decision Support System For End-of-life Care,Explainable clinical decision support systems,Explainable clinical decision support systems for end-of-life care,Explainable Clinical Decision Support Systems For End-of-life Care,female,Female,for end-of-life care,geriatric care,Geriatric Care,Geriatrics,Gynecology,HEALTH,heart disease,Heart Disease,home for the aged,Home For The Aged,Homes for the Aged,Homes For The Aged,human,Human,Humans,lung disease,Lung Disease,machine learning,Machine Learning,machine learning algorithm,Machine Learning Algorithm,Machine-learning,major clinical study,Major Clinical Study,male,Male,malignant neoplasm,Malignant Neoplasm,medical decision making,Medical Decision Making,mortality prediction,MORTALITY-RELATED FACTORS,nursing assessment,Nursing Assessment,nursing home,Nursing Home,NURSING-HOME RESIDENTS,nutritional status,Nutritional Status,Oncology,Palliative care,Palliative Care,palliative therapy,Palliative Therapy,practice guideline,Practice Guideline,prediction,Prediction,Prediction models,Prediction Models,predictive model,Predictive Model,procedures,Procedures,PROGNOSIS,proportional hazards model,Proportional Hazards Model,Proportional Hazards Models,random forest,Random Forest,receiver operating characteristic,Receiver Operating Characteristic,residential care,Residential Care,Roc Curve,ROC Curve,survival,Survival,survival analysis,Survival analysis,Survival Analysis,Survival analysis machine learning aged care,Survival analysis machine learning aged care mortality prediction,Survival Analysis Machine Learning Aged Care Mortality Prediction,Survival analyze machine learning aged care mortality prediction,Survival Analyze Machine Learning Aged Care Mortality Prediction,survival prediction,Survival Prediction,terminal care,Terminal Care,Time to events,Time To Events,Time-to-event analysis,Time-to-event Analysis,Time-to-event analyze,Time-to-event Analyze,trustworthiness,Trustworthiness,VALIDATION,VALIDITY,very elderly,Very Elderly}
