@article{seokFeasibilityEfficacyTouchCare2022,
  title = {Feasibility and Efficacy of {{TouchCare}} System Using Application for Older Adults Living Alone: A Pilot Pre-Experimental Study},
  author = {Seok, J.W. and Kwon, Y.-J. and Lee, H.},
  year = 2022,
  journal = {BMC Geriatrics},
  volume = {22},
  number = {1},
  publisher = {BioMed Central Ltd},
  issn = {14712318 (ISSN)},
  doi = {10.1186/s12877-022-03482-w},
  abstract = {Background: With the number of older people living alone continuously rising, health-monitoring systems using information and communication technology (ICT) have been developed to manage their health issues. Life logging and human body communication sensor, types of ICT, have been adapted to manage and monitor health status of the elderly. However, its feasibility and efficacy remain unclear. This study aimed to examine the feasibility of TouchCare system which combined life logging with human body communication technology and its effect on the physical and psychological status of older adults living alone. Methods: The TouchCare system, which consisted of a wearable watch, touchpad sensors, TouchCare application, and context-aware artificial intelligence, was developed by DNX Co. Ltd and used by the participants for 5 months. Out of the 111 selected participants, 91 replied to the satisfaction survey, and 22 participated in further investigation regarding their physical and psychological status. Finally, health assessment from 14 participants and sensor data from 13 participants (mean age = 77.4; SD = 3.8) were analyzed to compare their health status and health-related behaviors before and after use of the system. Results: Out of the 91 participants who took the survey, 51.6\% were satisfied with the system. Nutritional status (pre-intervention (10.6 \textpm{} 2.0) vs. post-intervention (11.8 \textpm{} 1.9), P = 0.04) and fall efficacy (pre-intervention (89.2 \textpm{} 15.3) vs. post-intervention (99.9 \textpm{} 0.5), P = 0.001) significantly improved after use of the system. Chronic pain (pre-intervention (4.8 \textpm{} 2.5) vs. post-intervention (4.4 \textpm{} 3.7), P = 0.78) and depressive symptoms (pre-intervention (5.7 \textpm{} 3.9) vs. post-intervention (5.4 \textpm{} 3.1), P = 0.60) reduced, while cognitive function (pre-intervention (4.1 \textpm{} 1.4) vs. post-intervention (4.6 \textpm{} 1.1), P = 0.15) and physical performance related to walking improved (pre-intervention (3.9 \textpm{} 0.2) vs. post-intervention (4.0 \textpm{} 0), P = 0.35), but were not significant. Behaviors related to physical activity and gait improved after use of the system; touch counts of refrigerator and microwave also increased with a decrease in night touch counts. Conclusions: The TouchCare system was acceptable to older people living alone, and it efficiently managed their daily living while promoting their health-related behaviors. Further experimental studies are required to verify the effectiveness of the system, and to develop the system which meet the individualized needs of older people living alone. \copyright{} 2022 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Artificial Intelligence,*Exercise,AGE,aged,Aged,Ambient intelligence,Ambient Intelligence,artificial intelligence,Artificial Intelligence,BEHAVIOR,CARE,Context-aware artificial intelligence,Context-aware Artificial Intelligence,Elderly,exercise,Exercise,FRAILTY,Health care,Health Care,HEALTH MONITORING-SYSTEM,health status,Health Status,human,Human,Human body communication,Human Body Communication,Humans,Life logging,Life Logging,MANAGEMENT,PEOPLE,RISK,TOOL,walking,Walking,Wearable device,Wearable Device},
  file = {C:\Users\fabian\Zotero\storage\PTEIV3K8\Seok et al. - 2022 - Feasibility and efficacy of TouchCare system using application for older adults living alone a pilo.pdf}
}

@article{serinPhysicianPerspectivesArtificial2025,
  title = {Physician Perspectives on {{Artificial Intelligence}} in Healthcare: A Cross-Sectional Study of Child-Focused Care in a {{Turkish}} Tertiary Hospital},
  author = {Serin, O. and Y{\i}ld{\i}r{\i}m, B.F. and Duman, F. and Ercorumlu, K. and Yavas, R. and Ta{\c s}ar, M.A. and Celik, M.},
  year = 2025,
  journal = {International Journal of Medical Informatics},
  volume = {203},
  publisher = {Elsevier Ireland Ltd},
  issn = {18728243 (ISSN); 13865056 (ISSN)},
  doi = {10.1016/j.ijmedinf.2025.106003},
  abstract = {Background: Artificial intelligence (AI) is transforming healthcare, yet many physicians struggle with its understanding and adoption. Existing research often overlooks developing countries like Turkey and rarely focuses on physicians caring for pediatric populations, where caregiver involvement and patient vulnerability add further complexity to AI integration. Methods: This cross-sectional study employed a self-administered questionnaire distributed to 155 physicians from the Family Medicine and Pediatrics departments of a single tertiary hospital in Turkey to evaluate their knowledge, expectations, and concerns regarding AI in healthcare. Results: Most participants (73.6 \%) reported limited AI knowledge, but showed significant interest in AI education. A preference for human involvement in medical decision making was indicated, with only 8.3 \% expressing trust in a fully autonomous AI system. Ethical concerns, particularly regarding accountability, were prominent, with the majority attributing responsibility to algorithm designers (64.5 \%) and regulatory bodies (27.7 \%) rather than physicians. Several barriers to AI adoption, specific to the Turkish healthcare context, were identified, including educational gaps, cultural resistance, financial/technical constraints, and digital health policies. Conclusion: Turkish physicians favor the potential of AI to enhance healthcare outcomes. Physicians should be empowered with AI education to improve their trust and confidence in shaping the development of responsible AI while maintaining human involvement. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,algorithm,Algorithm,Article,artificial intelligence,Artificial Intelligence,Attitude of Health Personnel,Attitude Of Health Personnel,caregiver,Caregiver,child,Child,controlled study,Controlled Study,Cross-sectional Studies,Cross-Sectional Studies,cross-sectional study,Cross-sectional study,Cross-sectional Study,deep learning,Deep Learning,Delivery of Health Care,Delivery Of Health Care,developing country,Developing Country,digital health,Digital Health,Diseases,family medicine,Family Medicine,female,Female,health care delivery,Health Care Delivery,health care policy,Health Care Policy,health personnel attitude,Health Personnel Attitude,Healthcare,human,Human,Humans,informed consent,Informed Consent,Intelligence integration,Intelligence Integration,Likert scale,Likert Scale,male,Male,medical decision making,Medical decision making,Medical Decision Making,medical practice,Medical practice,Medical Practice,middle aged,Middle Aged,Nutrition,Pediatric population,Pediatric Population,pediatrics,Pediatrics,physician,Physician,Physician Adoption,Physician adoptions,Physician Adoptions,Physicians,professional knowledge,Professional Knowledge,psychology,Psychology,questionnaire,Questionnaire,responsible artificial intelligence,Responsible Artificial Intelligence,Self-administered questionnaire,Self-administered Questionnaire,social aspect,Social Aspect,Surgery,Surveys and Questionnaires,Surveys And Questionnaires,tertiary care center,Tertiary Care Center,Tertiary Care Centers,Turk (people),Turkey,turkey (bird),Turkey (bird),Turkishs,workload,Workload}
}

@article{serranoCharacterizingUserEngagement2017,
  title = {Characterizing User Engagement with Health App Data: A Data Mining Approach},
  author = {Serrano, K.J. and Coa, K.I. and Yu, M. and {Wolff-Hughes}, D.L. and Atienza, A.A.},
  year = 2017,
  journal = {Translational Behavioral Medicine},
  volume = {7},
  number = {2},
  pages = {277--285},
  publisher = {Springer New York LLC barbara.b.bertram@gsk.com},
  issn = {16139860 (ISSN); 18696716 (ISSN)},
  doi = {10.1007/s13142-017-0508-y},
  abstract = {The use of mobile health applications (apps) especially in the area of lifestyle behaviors has increased, thus providing unprecedented opportunities to develop health programs that can engage people in real-time and in the real-world. Yet, relatively little is known about which factors relate to the engagement of commercially available apps for health behaviors. This exploratory study examined behavioral engagement with a weight loss app, Lose It! and characterized higher versus lower engaged groups. Cross-sectional, anonymized data from Lose It! were analyzed (n~=~12,427,196). This dataset was randomly split into 24 subsamples and three were used for this study (total n~=~1,011,008). Classification and regression tree methods were used to identify subgroups of user engagement with one subsample, and descriptive analyses were conducted to examine other group characteristics associated with engagement. Data mining validation methods were conducted with two separate subsamples. On average, users engaged with the app for 29~days. Six unique subgroups were identified, and engagement for each subgroup varied, ranging from 3.5 to 172~days. Highly engaged subgroups were primarily distinguished by the customization of diet and exercise. Those less engaged were distinguished by weigh-ins and the customization of diet. Results were replicated in further analyses. Commercially-developed apps can reach large segments of the population, and data from these apps can provide insights into important app features that may aid in user engagement. Getting users to engage with a mobile health app is critical to the success of apps and interventions that are focused on health behavior change. \copyright{} 2017 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Mobile Applications,*Patient Participation,*Telemedicine/methods,*Weight Reduction Programs/methods,adolescent,Adolescent,adult,Adult,aged,Aged,Article,Big data,Big Data,classification,Classification,Classification and regression tree,Classification And Regression Tree,Cross-sectional Studies,Cross-Sectional Studies,cross-sectional study,Cross-sectional Study,data mining,Data mining,Data Mining,Data Mining/methods,exercise,Exercise,female,Female,health behavior,Health Behavior,human,Human,Humans,lifestyle,Lifestyle,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,mobile application,Mobile Application,Mobile Applications,Mobile health application,Mobile Health Application,Mobile health technology,Mobile Health Technology,patient participation,Patient Participation,priority journal,Priority Journal,procedures,Procedures,self report,Self Report,smartphone,Smartphone,Smartphone app,Smartphone App,social participation,Social Participation,telemedicine,Telemedicine,tool use,Tool Use,User engagement,User Engagement,weight loss program,Weight Loss Program,weight reduction,Weight Reduction,Weight Reduction Programs,young adult,Young Adult}
}

@article{serranoMiningHealthApp2016,
  title = {Mining Health App Data to Find More and Less Successful Weight Loss Subgroups},
  author = {Serrano, K.J. and Yu, M. and Coa, K.I. and Collins, L.M. and Atienza, A.A.},
  year = 2016,
  journal = {Journal of Medical Internet Research},
  volume = {18},
  number = {6},
  publisher = {JMIR Publications Inc.},
  issn = {14388871 (ISSN)},
  doi = {10.2196/jmir.5473},
  abstract = {Background: More than half of all smartphone app downloads involve weight, diet, and exercise. If successful, these lifestyle apps may have far-reaching effects for disease prevention and health cost-savings, but few researchers have analyzed data from these apps. Objective: The purposes of this study were to analyze data from a commercial health app (Lose It!) in order to identify successful weight loss subgroups via exploratory analyses and to verify the stability of the results. Methods: Cross-sectional, de-identified data from Lose It! were analyzed. This dataset (n=12,427,196) was randomly split into 24 subsamples, and this study used 3 subsamples (combined n=972,687). Classification and regression tree methods were used to explore groupings of weight loss with one subsample, with descriptive analyses to examine other group characteristics. Data mining validation methods were conducted with 2 additional subsamples. Results: In subsample 1, 14.96\% of users lost 5\% or more of their starting body weight. Classification and regression tree analysis identified 3 distinct subgroups: "the occasional users" had the lowest proportion (4.87\%) of individuals who successfully lost weight; "the basic users" had 37.61\% weight loss success; and "the power users" achieved the highest percentage of weight loss success at 72.70\%. Behavioral factors delineated the subgroups, though app-related behavioral characteristics further distinguished them. Results were replicated in further analyses with separate subsamples. Conclusions: This study demonstrates that distinct subgroups can be identified in "messy" commercial app data and the identified subgroups can be replicated in independent samples. Behavioral factors and use of custom app features characterized the subgroups. Targeting and tailoring information to particular subgroups could enhance weight loss success. Future studies should replicate data mining analyses to increase methodology rigor. \copyright{} 2020 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Cell Phone,*Mobile Applications,*Weight Loss,adolescent,Adolescent,adult,Adult,aged,Aged,body weight,Body Weight,Body Weight/*physiology,Cell Phones,classification,Classification,Cross-sectional Studies,Cross-Sectional Studies,cross-sectional study,Cross-sectional Study,data mining,Data Mining,Data Mining/*methods,Datasets as Topic,Datasets As Topic,diet,Diet,Diet/*methods/*statistics & numerical data,exercise,Exercise,female,Female,human,Human,Humans,information processing,Information Processing,male,Male,middle aged,Middle Aged,mobile app,Mobile App,mobile application,Mobile Application,Mobile Applications,mobile health,Mobile Health,mobile phone,Mobile Phone,physiology,Physiology,procedures,Procedures,Random Allocation,randomization,Randomization,statistics and numerical data,Statistics And Numerical Data,weight loss,Weight Loss,weight reduction,Weight Reduction,young adult,Young Adult}
}

@article{shangDSMSTCNOtagoExercises2024,
  title = {{{DS-MS-TCN}}: {{Otago Exercises Recognition With}} a {{Dual-Scale Multi-Stage Temporal Convolutional Network}}},
  author = {Shang, M. and Dedeyne, L. and Dupont, J. and Vercauteren, L. and Amini, N. and Lapauw, L. and Gielen, E. and Verschueren, S. and Varon, C. and De Raedt, W.},
  year = 2024,
  journal = {IEEE Journal of Biomedical and Health Informatics},
  volume = {28},
  number = {12},
  pages = {7138--7150},
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  issn = {21682208 (ISSN); 21682194 (ISSN)},
  doi = {10.1109/JBHI.2024.3455426},
  abstract = {The Otago Exercise Program (OEP) represents a crucial rehabilitation initiative tailored for older adults, aimed at enhancing balance and strength. Despite previous efforts utilizing wearable sensors for OEP recognition, existing studies have exhibited limitations in terms of accuracy and robustness. This study addresses these limitations by employing a single waist-mounted Inertial Measurement Unit (IMU) to recognize OEP exercises among community-dwelling older adults in their daily lives. A cohort of 36 older adults participated in laboratory settings, supplemented by an additional 7 older adults recruited for at-home assessments. The study proposes a Dual-Scale Multi-Stage Temporal Convolutional Network (DS-MS-TCN) designed for two-level sequence-to-sequence classification, incorporating them in one loss function. In the first stage, the model focuses on recognizing each repetition of the exercises (micro labels). Subsequent stages extend the recognition to encompass the complete range of exercises (macro labels). The DS-MS-TCN model surpasses existing state-of-the-art deep learning models, achieving f1-scores exceeding 80\% and Intersection over Union (IoU) f1-scores surpassing 60\% for all four exercises evaluated. Notably, the model outperforms the prior study utilizing the sliding window technique, eliminating the need for post-processing stages and window size tuning. To our knowledge, we are the first to present a novel perspective on enhancing Human Activity Recognition (HAR) systems through the recognition of each repetition of activities. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {accelerometry,Accelerometry,aged,Aged,Aged 80 and over,Aged 80 And Over,Article,artificial intelligence,Artificial Intelligence,artificial neural network,Artificial Neural Network,Convolutional networks,Convolutional Networks,convolutional neural network,Convolutional Neural Network,Convolutional neural networks,Convolutional Neural Networks,deep learning,Deep learning,Deep Learning,Dual scale,Dual Scale,Dual-scale Multi-stage Temporal Convolutional Network,Dual-Scale Multi-Stage Temporal Convolutional Network,entropy,Entropy,exercise,Exercise,Exercise programs,Exercise Programs,Exercise Therapy,female,Female,food intake,Food Intake,gyroscope sensor,Gyroscope Sensor,human,Human,Human activity recognition,Human Activity Recognition,Human Activity Recognition (har),Humans,kinesiotherapy,Kinesiotherapy,knee function,Knee Function,learning algorithm,Learning Algorithm,long short term memory network,Long Short Term Memory Network,machine learning,Machine Learning,male,Male,measurement accuracy,Measurement Accuracy,Micro Activities,Micro activity,Micro Activity,Multi-stages,nerve cell network,Nerve Cell Network,Neural Networks Computer,Older adults,Older Adults,Otago exercise,Otago Exercise,Otago Exercises,physical activity,Physical Activity,physiology,Physiology,procedures,Procedures,sensitivity and specificity,Sensitivity And Specificity,speech intelligibility,Speech Intelligibility,Temporal convolutional network,Temporal Convolutional Network,time series analysis,Time Series Analysis,very elderly,Very Elderly,wearable computer,Wearable Computer,Wearable Electronic Devices,Wearable sensors,Wearable Sensors}
}

@inproceedings{shaoAssessmentRiskFactors2019,
  title = {Assessment of the Risk Factors in the Daily Life of Stroke Patients Based on an Optimized Decision Tree},
  booktitle = {Technology and {{Health Care}}},
  author = {Shao, Z. and Chen, C. and Li, W. and Ren, H. and Chen, W.},
  year = 2019,
  volume = {27},
  pages = {S317-S329},
  publisher = {IOS Press Nieuwe Hemweg 6B Amsterdam 1013 BG},
  doi = {10.3233/THC-199030},
  abstract = {BACKGROUND: Stroke is a leading cause of mortality and disability, which can be affected by people's daily living habits. OBJECTIVE: To investigate the effects of main daily living habits (smoking, drinking, diet, vegetable and fruits consumption, and exercise) on stroke risk in patients and provide the scientific basis for the assessment of the risk factors, a novel risk analysis model of the stroke is proposed. METHODS: A data mining method using decision trees which adopted the optimized C4.5 algorithm is presented. It is able to deal with the unbalanced data problem of the classification. Meanwhile, the proposed method has been verified on a clinical dataset of 23,682 patients with 21 risk factors. RESULTS: The overall accuracy and kappa coefficient for stroke risk classification has reached 84.88\% and 0.7763, respectively. Through the generated knowledge rules, it demonstrates that the behavioral habits in daily life have an indirect effect on the risk of stroke. While, it has an obvious effect on stroke when hypertension, diabetes mellitus, hypercholesterolemia, and BMI risk factors exist. In addition, it was observed that the aforementioned five daily living habits have a decreased impact on the stroke. CONCLUSIONS: It is anticipated that the proposed system could help in reducing the risk, mortality, and disability of stroke, and provide clinical decision support for the treatment of stroke. \copyright{} 2019 Elsevier B.V., All rights reserved.},
  isbn = {18787401 (ISSN); 09287329 (ISSN)},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,body mass,Body Mass,cerebrovascular accident,Cerebrovascular Accident,Conference Paper,daily life activity,Daily Life Activity,data mining,Data Mining,Databases Factual,decision support system,Decision Support System,decision tree,Decision Tree,Decision Trees,diabetes mellitus,Diabetes Mellitus,diet,Diet,drinking,Drinking,exercise,Exercise,factual database,Factual Database,female,Female,food intake,Food Intake,fruit,Fruit,health behavior,Health Behavior,human,Human,Humans,hypercholesterolemia,Hypercholesterolemia,hypertension,Hypertension,major clinical study,Major Clinical Study,male,Male,middle aged,Middle Aged,mortality risk,Mortality Risk,priority journal,Priority Journal,risk assessment,Risk Assessment,risk factor,Risk Factor,Risk Factors,smoking,Smoking,Stroke,stroke patient,Stroke Patient,vegetable,Vegetable}
}

@article{sharmaArtificialIntelligenceBasedAssessment2025,
  title = {Artificial {{Intelligence-Based Assessment}} of {{Preoperative Body Composition Is Associated}} with {{Early Complications}} after {{Radical Cystectomy}}},
  author = {Sharma, V. and Fadel, A. and Tollefson, M.K. and Psutka, S.P. and Blezek, D.J. and Frank, I. and Thapa, P. and Tarrell, R. and Viers, L.D. and Potretzke, A.M.},
  year = 2025,
  journal = {Journal of Urology},
  volume = {213},
  number = {2},
  pages = {228--237},
  publisher = {Wolters Kluwer Health},
  issn = {15273792 (ISSN); 00225347 (ISSN)},
  doi = {10.1097/JU.0000000000004292},
  abstract = {Purpose:We aimed to use a validated artificial intelligence (AI) algorithm to extract muscle and adipose areas from CT images before radical cystectomy (RCx) and then correlate these measures with 90-day post-RCx complications.Materials and Methods:A tertiary referral center's cystectomy registry was queried for patients who underwent RCx between 2009 and 2017 for bladder cancer. Eight hundred forty-three RCx patients with CT imaging within 90 days of preceding surgery were included, to allow for extraction of body composition parameters by AI. We assessed complications within 90 days of surgery including wound, infectious, and major complications; readmission; and death. Multivariable logistic regressions associated pre-RCx measures with post-RCx complications.Results:Increasing subcutaneous adipose tissue was associated with more wound complications, while patients with increasing visceral adipose tissue had greater odds of infectious-related complications. After adjusting for patient characteristics, every 10 cm2 increases in fat mass index were associated with more infectious (odds ratio [OR], 1.04; P =.002) and wound (OR, 1.06; P {$<$}.001) complications. On multivariable analysis, a higher preoperative skeletal muscle index was associated with lower odds of major complications (OR, 0.75 for every 10 cm2; P =.008), while higher intramuscular adipose was associated with higher odds of major complications (OR, 1.93; P =.008).Conclusions:Automated AI body composition measurements preoperatively are associated with post-RCx complications. These measurements, in addition to patient (Eastern Cooperative Oncology Group performance status and smoking status) and surgical (robotic approach and continent diversion) characteristics, can then be used to individualize patient counseling and facilitate triage of nutritional and rehabilitation efforts. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {*Artificial Intelligence,*Body Composition,*Cystectomy/adverse effects/methods,*Postoperative Complications/epidemiology/etiology,*Tomography X-Ray Computed,*Urinary Bladder Neoplasms/surgery,abdominal radiography,Abdominal Radiography,adult,Adult,adverse event,Adverse Event,aged,Aged,antineoplastic agent,Antineoplastic Agent,Article,artificial intelligence,Artificial Intelligence,bladder tumor,Bladder Tumor,BLADDER-CANCER,body composition,Body Composition,body fat,Body Fat,cancer surgery,Cancer Surgery,cohort analysis,Cohort Analysis,COMPUTED-TOMOGRAPHY,computer assisted tomography,Computer Assisted Tomography,controlled study,Controlled Study,correlation analysis,Correlation Analysis,cystectomy,Cystectomy,epidemiology,Epidemiology,etiology,Etiology,extraction,Extraction,FAT,fat mass,Fat Mass,female,Female,frailty,Frailty,hospital readmission,Hospital Readmission,human,Human,Humans,IMPACT,incisional hernia,Incisional Hernia,infectious complication,Infectious Complication,INFLAMMATION,intra-abdominal fat,Intra-abdominal Fat,intramuscular fat,Intramuscular Fat,learning algorithm,Learning Algorithm,major clinical study,Major Clinical Study,male,Male,MASS,middle aged,Middle Aged,mortality,Mortality,MORTALITY,muscle tissue,Muscle Tissue,neoadjuvant chemotherapy,Neoadjuvant Chemotherapy,OBESITY,patient counseling,Patient Counseling,patient triage,Patient Triage,pelvis radiography,Pelvis Radiography,postoperative complication,Postoperative Complication,Postoperative Complications,postoperative period,Postoperative Period,preoperative evaluation,Preoperative Evaluation,preoperative period,Preoperative Period,procedures,Procedures,radical cystectomy,Radical Cystectomy,register,Register,Retrospective Studies,retrospective study,Retrospective Study,robot assisted surgery,Robot Assisted Surgery,sarcopenia,Sarcopenia,SARCOPENIA,sex difference,Sex Difference,skeletal muscle,Skeletal Muscle,subcutaneous fat,Subcutaneous Fat,surgery,Surgery,tertiary care center,Tertiary Care Center,Tomography X-ray Computed,Tomography X-Ray Computed,transitional cell carcinoma of the bladder,Transitional Cell Carcinoma Of The Bladder,Urinary Bladder Neoplasms,validation process,Validation Process,wound dehiscence,Wound Dehiscence,wound seroma,Wound Seroma,x-ray computed tomography,X-ray Computed Tomography}
}

@inproceedings{sharmaPrivacyPreservingTechniquesAIBased2024,
  title = {Privacy-{{Preserving Techniques}} in {{AI-Based Healthcare}}: {{A Comprehensive Review}}},
  author = {Sharma, N. and Yadav, P.},
  year = 2024,
  publisher = {{Institute of Electrical and Electronics Engineers Inc.}},
  doi = {10.1109/UPCON62832.2024.10983387},
  abstract = {The incorporation of Artificial Intelligence (AI) in the healthcare has transformed patient care, diagnostics, and personalized Medicare in the today's era. As a result, it also increases significant privacy concerns due to sensitive healthcare data. This paper provides the comprehensive review of privacy-preserving methods, including federated learning, homomorphic encryption, differential privacy, blockchain, and secure multiparty computation that analyzing them in terms of privacy guarantees, computational complexity, scalability, and real-time applicability. Future work focuses on developing hybrid frameworks, lightweight privacy solutions for edge computing, and quantum-resistant cryptography to address evolving security threats. These advancements will play the pivotal role in ensuring secure, scalable, and ethically sound AI-driven healthcare systems. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9798350378726 (ISBN)},
  langid = {english},
  keywords = {Anonymity,Artificial Intelligence,Assisted living,Assisted Living,Block-chain,Complexity scalability,Complexity Scalability,Differential privacies,Differential Privacies,Differential privacy,Differential Privacy,Federated learning,Federated Learning,Health Care,Health insurance,Health Insurance,Ho-momorphic encryptions,Ho-momorphic Encryptions,Homomorphic-encryptions,Hybrid technology,Hybrid Technology,Independent living systems,Independent Living Systems,mHealth,Mhealth,Np-hard,NP-hard,Nursing,Nutrition,Patient care,Patient Care,Patient treatment,Patient Treatment,Privacy by design,Privacy By Design,Privacy concerns,Privacy Concerns,Privacy preserving,Privacy Preserving,Privacy-preserving techniques,Privacy-preserving Techniques,Secure multi-party computation,Secure Multi-party Computation,Sensitive data,Sensitive Data}
}

@incollection{sharmaRoleComputerScience2025,
  title = {The {{Role}} of {{Computer Science}} in {{Advancing Sustainable Development Goals}}: {{A Comprehensive Analysis}}},
  author = {Sharma, P.},
  year = 2025,
  volume = {2},
  pages = {531--546},
  publisher = {Springer Nature},
  doi = {10.1007/978-981-97-5177-8_29},
  abstract = {This chapter delves into the multifaceted applications of Computer Science in driving progress toward sustainable development goals (SDGs) across diverse domains. Leveraging advancements in machine learning, Internet of Things (IoT), and data analytics, researchers, policymakers, and organizations can monitor and model environmental patterns to inform proactive strategies for ecosystem conservation and mitigate environmental threats. Educational technologies, powered by Computer Science, extend educational opportunities to underserved communities, bridging the digital divide and fostering lifelong learning to empower individuals with relevant skills for sustainable development. Additionally, data analytics and machine learning algorithms optimize agricultural practices, predict food crises, and enhance supply chain management, thereby bolstering food security and reducing poverty. Health informatics, a product of Computer Science, revolutionizes healthcare delivery by facilitating electronic health records, telemedicine, and healthcare data analytics, resulting in improved disease surveillance, early outbreak detection, and better healthcare access, ultimately leading to enhanced health outcomes and increased life expectancy. Computer Science initiatives promoting gender equality encompass a wide range of efforts, from encouraging girls' participation in STEM education to developing technology solutions addressing gender-based violence and promoting women's economic empowerment, all of which contribute to building more resilient and equitable societies. Furthermore, Computer Science tools and algorithms facilitate efficient water management, optimizing water distribution systems, and monitoring water quality, thus aiding in water resource conservation, improving sanitation infrastructure, and enhancing water access in water-stressed regions. Smart city technologies, underpinned by Computer Science innovations, drive the development of interconnected urban systems, including smart transportation, energy-efficient buildings, and intelligent waste management, leading to resource efficiency, emission reduction, and the creation of sustainable, liveable urban environments. Moreover, Computer Science plays a vital role in climate modeling, weather forecasting, and climate change impact assessment, further supporting the development of innovative green technologies, such as renewable energy solutions and energy-efficient systems, in the global fight against climate change. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  isbn = {9789819751778 (ISBN); 9789819751761 (ISBN)},
  langid = {english},
  keywords = {Agricultural technology,Agricultural Technology,Assisted living,Assisted Living,Climate modeling,Climate Modeling,Comprehensive analysis,Comprehensive Analysis,Computer Science,Copyrights,Data analytics,Data Analytics,Data organization,Data Organization,Diseases,Diverse domains,Diverse Domains,Educational Technologies,Educational technology,Educational Technology,Electronic health record,Electronic Health Record,Food storage,Food Storage,Food technology,Food Technology,Food waste,Food Waste,Gender equality,Gender Equality,Green Technologies,Green technology,Green Technology,Health informatics,Health Informatics,Independent living systems,Independent Living Systems,Information systems,Information Systems,Informatization,Internet Of Things,Machine Learning,Machine-learning,mHealth,Mhealth,Nutrition,Patient treatment,Patient Treatment,Policy makers,Policy Makers,Smart Cities,Sustainable Development Goals}
}

@article{sharpEffectivenessChatbotSingleSession2025,
  title = {The {{Effectiveness}} of a {{Chatbot Single-Session Intervention}} for {{People}} on {{Waitlists}} for {{Eating Disorder Treatment}}: {{Randomized Controlled Trial}}},
  author = {Sharp, G. and Dwyer, B. and Randhawa, A. and McGrath, I. and Hu, H.},
  year = 2025,
  journal = {Journal of Medical Internet Research},
  volume = {27},
  publisher = {JMIR Publications Inc.},
  issn = {14388871 (ISSN)},
  doi = {10.2196/70874},
  abstract = {Background: Early treatment is critical for improving eating disorder prognosis. Single-session interventions (SSIs) can provide short-term support to people on waitlists for eating disorder treatment; however, it is not always possible to access SSIs. We co-designed and developed a rule-based chatbot called ED ESSI (Eating Disorder Electronic Single-Session Intervention), which delivered an SSI and demonstrated its acceptability and feasibility. However, the effectiveness of ED ESSI is yet to be investigated. Objective: This study aimed to investigate the effectiveness of an SSI delivered by ED ESSI. We examined the chatbot's impact on eating disorder pathology, psychosocial impairment, depression, anxiety, stress, and motivation for change or treatment in individuals aged {$\geq$}16 years on waitlists for treatment for all types of eating disorders. Methods: This multicenter 2-armed randomized controlled trial included 60 people on waitlists for eating disorder treatment in the chatbot intervention group (n=30, 50\%) or the control group (n=30, 50\%). The ED ESSI chatbot guided participants through a 30-minute SSI of assessment and psychoeducation, while the control group received web-based information on the same core topics covered in the SSI. There were 4 time points: before intervention or baseline (time point 1 [T1]), after intervention within 72 hours of baseline (T2), 1 month after baseline (T3), and 3 months after baseline (T4). Eating disorder pathology (primary outcome) and psychosocial impairment, depression, anxiety, and stress (secondary outcomes) were measured at T1, T3, and T4, and motivation for change or treatment (secondary outcome) was measured at all 4 time points. Furthermore, the System Usability Scale was implemented at T2 for the chatbot intervention group only. Results: ED ESSI induced significantly greater reductions compared to the control group in the primary outcome of eating disorder pathology (P=.003) and secondary outcomes of psychosocial impairment (P=.008), depression (P=.002), and anxiety (P=.040) over the 1- and 3-month time points, with small to moderate effects (Cohen d=0.15-0.53). Chatbot use also induced an increase in participants' confidence in their ability to change (secondary outcome) immediately after use (T2), with a moderate effect (P{$<$}.001; Cohen d=0.74). The chatbot was rated as ``excellent'' in terms of usability. A significantly higher proportion of participants in the chatbot group (28/30, 93\%) entered treatment by 3 months upon the opportunity being offered to them, compared to the control group, with a moderate effect (21/30, 70\%; P=.042; {$\phi$}=0.30). Conclusions: ED ESSI promptly induced improvements in eating disorder pathology, psychosocial impairment, depression, and anxiety, which were detectable at 1 month and maintained to 3 months. ED ESSI potentially represents an effective, accessible, and scalable form of early intervention for people aged {$\geq$}16 years waiting for eating disorder treatment. Further research is needed to determine the longer-term effectiveness of ED ESSI. \copyright{} 2025 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adolescent,Adolescent,adult,Adult,Ai,anorexia nervosa,Anorexia Nervosa,anxiety,Anxiety,Article,Artificial Intelligence,Australia,avoidant restrictive food intake disorder,Avoidant Restrictive Food Intake Disorder,binge eating disorder,Binge Eating Disorder,bulimia,Bulimia,Chatbot,clinical effectiveness,Clinical Effectiveness,clinical trial,Clinical Trial,Cognitive Behavioral Therapy,controlled study,Controlled Study,Conversational Agent,depression,Depression,Depression Anxiety and Stress Scale-21,Depression Anxiety And Stress Scale-21,Digital Health,eating disorder,Eating Disorder,Eating Disorder Examination Questionnaire,Enhanced Cognitive Behavioral Therapy,Feeding and Eating Disorders,Feeding And Eating Disorders,female,Female,generative artificial intelligence,Generative Artificial Intelligence,hospital admission,Hospital Admission,human,Human,Humans,major clinical study,Major Clinical Study,male,Male,Mental Health,mental stress,Mental Stress,middle aged,Middle Aged,motivation,Motivation,multicenter study,Multicenter Study,outcome assessment,Outcome Assessment,parallel design,Parallel Design,psychoeducation,Psychoeducation,psychology,Psychology,randomized controlled trial,Randomized Controlled Trial,single session intervention,Single Session Intervention,Single-session Intervention,social psychology,Social Psychology,therapy,Therapy,treatment outcome,Treatment Outcome,usability,Usability,Waiting Lists,web-based intervention,Web-based Intervention,young adult,Young Adult}
}

@article{sheffer-hilelAttitudesKnowledgeFamily2024,
  title = {The Attitudes and Knowledge of Family Physicians Regarding Malnutrition in the Elderly: A Call for Action},
  author = {{Sheffer-Hilel}, G. and Kachal, J. and Biderman, A. and Shahar, D.R. and Amar, S.},
  year = 2024,
  journal = {Israel Journal of Health Policy Research},
  volume = {13},
  number = {1},
  publisher = {BioMed Central Ltd},
  issn = {20454015 (ISSN)},
  doi = {10.1186/s13584-024-00631-x},
  abstract = {Background: Malnutrition in the elderly places a significant burden on healthcare, social, and aged-care systems, yet it often remains undiagnosed and untreated. This study aims to evaluate family physicians' knowledge and attitudes towards the diagnosis and treatment of malnutrition in the elderly. Methods: Based on a literature review, an online questionnaire was developed, comprised of seven knowledge-related items and eight attitude-related questions regarding malnutrition in elderly populations. We also assessed the feasibility of including two malnutrition screening questions in regular clinic visits for individuals aged {$\geq$} 70 years. Results: Surveys were completed by 126 physicians (35\% response rate), mean age 47.2 \textpm{} 12.6 years; 15.6 \textpm{} 12.5 years of practice; 67\% females; and 92\% board-certified family physicians. Moreover, 77.6\% agreed that diagnosing malnutrition is important in patients with decreased appetite. Most respondents demonstrated knowledge of nutritional screening principles (63.5\%) and recognized that even obese elderly individuals could be malnourished (83.2\%). There was partial agreement (60\%) that normal BMI values in the elderly differ from those in younger populations. Almost complete agreement was seen for incorporating two nutritional status questions in medical visits (91\%), with physicians expressing willingness to receive training in malnutrition identification and screening tools. Despite challenges such as time constraints and limited knowledge, participants were open to conducting biannual malnutrition risk screening for elderly patients. Conclusion: We recommend malnutrition screening in primary care followed by malnutrition diagnosis and referral of malnourished patients to the proper intervention. \copyright{} 2024 Elsevier B.V., All rights reserved.},
  langid = {english},
  keywords = {adult,Adult,aged,Aged,Article,artificial intelligence,Artificial Intelligence,attitude,Attitude,Attitude of Health Personnel,Attitude Of Health Personnel,attitude to health,Attitude To Health,body mass,Body Mass,body weight loss,Body Weight Loss,clinical assessment,Clinical Assessment,diagnosis,Diagnosis,e-mail,E-mail,Elderly,Family Physician,female,Female,general practitioner,General Practitioner,Glim,Health Knowledge Attitudes Practice,health personnel attitude,Health Personnel Attitude,human,Human,Humans,Israel,knowledge,Knowledge,male,Male,malnutrition,Malnutrition,middle aged,Middle Aged,nutritional assessment,Nutritional Assessment,nutritional disorder,Nutritional Disorder,nutritional status,Nutritional Status,Physicians Family,quality of life,Quality Of Life,questionnaire,Questionnaire,sarcopenia,Sarcopenia,Spss V. 27.0,Surveys and Questionnaires,Surveys And Questionnaires}
}

